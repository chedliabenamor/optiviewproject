{# templates/partials/products/_product_card.html.twig #}
{# Compute matched variant based on selected color/genre (from query) #}
{% set selectedColors = (query is defined and query.color is defined) ? query.color : [] %}
{% set selectedGenres  = (query is defined and query.genre is defined) ? query.genre : [] %}
{% set matchedVariant = null %}
{% if (selectedColors is not empty) or (selectedGenres is not empty) %}
    {% for v in product.productVariants %}
        {% if matchedVariant is not defined or matchedVariant is null %}
            {% set colorOk = (selectedColors is empty) or (v.color and v.color.id in selectedColors) %}
            {% set genreOk = (selectedGenres is empty) or (v.genre and v.genre.id in selectedGenres) %}
            {% if colorOk and genreOk %}
                {% set matchedVariant = v %}
            {% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{# Fallback to product-level offer helper, but prefer variant-level offer if matchedVariant has active offers #}
{% set nowTs = "now"|date('U') %}
{% set vOffer = null %}
{% if matchedVariant and matchedVariant.productOffers|length > 0 %}
    {% for off in matchedVariant.productOffers %}
        {% if vOffer is null %}
            {% set active = (off.isActive() and off.startDate and off.endDate and off.startDate|date('U') <= nowTs and off.endDate|date('U') >= nowTs) %}
            {% if active %}
                {% set vOffer = off %}
            {% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{# Determine image to show: variant image first, else product overview #}
{% set variantImageUrl = (matchedVariant and matchedVariant.firstImageUrl) ? matchedVariant.firstImageUrl : null %}
{# Normalize variant image URL: if relative path without leading '/', use asset() to avoid 404s #}
{% set variantImageSrc = null %}
{% if variantImageUrl %}
    {% set lower = variantImageUrl|lower %}
    {% if lower starts with 'http://' or lower starts with 'https://' or variantImageUrl starts with '/' %}
        {% set variantImageSrc = variantImageUrl %}
    {% else %}
        {% set variantImageSrc = asset(variantImageUrl) %}
    {% endif %}
{% endif %}

{# Determine pricing (variant price overrides product price if present) #}
{% set basePrice = matchedVariant and matchedVariant.price is not null ? matchedVariant.price : product.price %}
{% set hasVariantOffer = vOffer is not null %}
{% if hasVariantOffer %}
    {% if vOffer.discountType == 'percentage' %}
        {% set discountedPrice = (basePrice * (100 - vOffer.discountValue)) / 100 %}
    {% else %}
        {% set discountedPrice = basePrice - vOffer.discountValue %}
    {% endif %}
    {% set originalPrice = basePrice %}
{% else %}
    {% set offerData = product_offer_data(product) %}
{% endif %}
<div class="col-sm-6 col-md-4 col-lg-3 p-b-35 isotope-item
    {{ product.category ? product.category.name|lower|replace({' ':'-'}) : '' }}
    {% if product.brand %} brand-{{ product.brand.name|lower|replace({' ':'-'}) }}{% endif %}
    {% if product.genre %} genre-{{ product.genre.name|lower|replace({' ':'-'}) }}{% endif %}
    {% if product.shape %} shape-{{ product.shape.name|lower|replace({' ':'-'}) }}{% endif %}
    {# Loop colors if product.colors is a collection #}
    {% if product.colors is defined and product.colors|length > 0 %}
        {% for color in product.colors %} color-{{ color.name|lower|replace({' ':'-'}) }}{% endfor %}
    {% endif %}
">
    <div class="block2">
        <div class="block2-pic hov-img0">
            {# Use VichUploader for the overview image if available, else fallback #}
            {% if variantImageSrc %}
                <img src="{{ variantImageSrc }}" alt="{{ product.name }}">
            {% elseif product.overviewImage %}
                <img src="{{ vich_uploader_asset(product, 'overviewImageFile') }}" alt="{{ product.name }}">
            {% else %}
                <img src="{{ asset('assets/images/no-image.webp') }}" alt="No image">
            {% endif %}
            {# Discount Badge (prefer variant offer, else product offer) #}
            {% if hasVariantOffer %}
                <div class="discount-badge" style="position: absolute; top: 10px; left: 10px; background: #e74c3c; color: white; padding: 5px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; z-index: 2;">
                    {% if vOffer.discountType == 'percentage' %}-{{ vOffer.discountValue|number_format(0) }}%{% else %}-{{ vOffer.discountValue|number_format(2, '.', '') }}€{% endif %}
                </div>
            {% elseif offerData is defined and offerData.has_offer %}
                <div class="discount-badge" style="position: absolute; top: 10px; left: 10px; background: #e74c3c; color: white; padding: 5px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; z-index: 2;">
                    {{ discount_label(product) }}
                </div>
            {% endif %}
            <a href="#" 
               class="block2-btn flex-c-m stext-103 cl2 size-102 bg0 bor2 hov-btn1 p-lr-15 trans-04 js-show-modal1"
                data-product-id="{{ product.id }}"
                data-product-name="{{ product.name|e('js') }}"
               data-product-price="{{ hasVariantOffer ? discountedPrice|number_format(2, '.', '') : (offerData is defined and offerData.has_offer ? offerData.discounted_price|number_format(2, '.', '') : basePrice|number_format(2, '.', '') ) }}"
               data-product-original-price="{{ hasVariantOffer ? originalPrice|number_format(2, '.', '') : (offerData is defined and offerData.has_offer ? offerData.original_price|number_format(2, '.', '') : '') }}"
               data-product-has-offer="{{ hasVariantOffer ? '1' : (offerData is defined and offerData.has_offer ? '1' : '0') }}"
                data-product-currency="EUR"
                data-product-description="{{ product.description|default('')|e('js') }}"
               data-product-image="{{ variantImageSrc ?: (product.overviewImage ? vich_uploader_asset(product, 'overviewImageFile') : asset('assets/images/no-image.webp')) }}">
                Quick View
            </a>
        </div>
        <div class="block2-txt flex-w flex-t p-t-14">
            <div class="block2-txt-child1 flex-col-l ">
                <a href="{{ path('product_show', {id: product.id}) }}" class="stext-104 cl4 hov-cl1 trans-04 js-name-b2 p-b-6">
                    {{ product.name }}
                </a>
                <div class="price-container">
                    {% if hasVariantOffer %}
                        <span class="stext-105 cl3 js-card-price" style="font-weight: bold; color: #e74c3c;" data-price-eur="{{ discountedPrice|number_format(2, '.', '') }}">
                            €{{ discountedPrice|number_format(2, '.', '') }}
                        </span>
                        <span class="stext-105 cl6 js-card-original" data-original-eur="{{ originalPrice|number_format(2, '.', '') }}" style="text-decoration: line-through; margin-left: 8px; font-size: 0.9em;">
                            €{{ originalPrice|number_format(2, '.', '') }}
                        </span>
                    {% elseif offerData is defined and offerData.has_offer %}
                        <span class="stext-105 cl3 js-card-price" style="font-weight: bold; color: #e74c3c;" data-price-eur="{{ offerData.discounted_price|number_format(2, '.', '') }}">
                            €{{ offerData.discounted_price|number_format(2, '.', '') }}
                        </span>
                        <span class="stext-105 cl6 js-card-original" data-original-eur="{{ offerData.original_price|number_format(2, '.', '') }}" style="text-decoration: line-through; margin-left: 8px; font-size: 0.9em;">
                            €{{ offerData.original_price|number_format(2, '.', '') }}
                        </span>
                    {% else %}
                        <span class="stext-105 cl3 js-card-price" data-price-eur="{{ basePrice|number_format(2, '.', '') }}">
                            €{{ basePrice|number_format(2, '.', '') }}
                        </span>
                    {% endif %}
                </div>
            </div>
            <div class="block2-txt-child2 flex-r p-t-3">
                <a href="#" class="btn-addwish-b2 dis-block pos-relative js-addwish-b2"
    data-product-id="{{ product.id }}"
    data-product-name="{{ product.name|e('js') }}"
    data-product-image="{{ variantImageSrc ?: (product.overviewImage ? vich_uploader_asset(product, 'overviewImageFile') : asset('assets/images/no-image.webp')) }}"
    data-product-price="€{{ hasVariantOffer ? discountedPrice|number_format(2, '.', '') : (offerData is defined and offerData.has_offer ? offerData.discounted_price|number_format(2, '.', '') : basePrice|number_format(2, '.', '') ) }}"
    data-product-original-price="{{ hasVariantOffer ? '€' ~ originalPrice|number_format(2, '.', '') : (offerData is defined and offerData.has_offer ? '€' ~ offerData.original_price|number_format(2, '.', '') : '') }}"
    data-product-has-offer="{{ hasVariantOffer ? '1' : (offerData is defined and offerData.has_offer ? '1' : '0') }}">
    <img class="icon-heart1 dis-block trans-04" src="{{ asset('assets/images/icons/icon-heart-01.png') }}" alt="ICON">
    <img class="icon-heart2 dis-block trans-04 ab-t-l" src="{{ asset('assets/images/icons/icon-heart-02.png') }}" alt="ICON">
</a>
            </div>
        </div>
    </div>
</div>

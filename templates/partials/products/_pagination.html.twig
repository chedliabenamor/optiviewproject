{# Pagination partial expects 'pagination' and 'query' #}
{% if pagination is defined and pagination.pages > 1 %}
<nav class="flex-c-m p-t-45" aria-label="Shop pagination" id="shop-pagination">
    <ul class="pagination">
        <li class="page-item{% if not pagination.hasPrev %} disabled{% endif %}">
            <a class="page-link" href="{{ path('product_shop', query|merge({'page': pagination.prev})) }}" data-ajax="1" tabindex="-1">Previous</a>
        </li>
        {% for i in 1..pagination.pages %}
            <li class="page-item{% if i == pagination.page %} active{% endif %}">
                <a class="page-link" href="{{ path('product_shop', query|merge({'page': i})) }}" data-ajax="1">{{ i }}</a>
            </li>
        {% endfor %}
        <li class="page-item{% if not pagination.hasNext %} disabled{% endif %}">
            <a class="page-link" href="{{ path('product_shop', query|merge({'page': pagination.next})) }}" data-ajax="1">Next</a>
        </li>
    </ul>
</nav>
{% endif %}

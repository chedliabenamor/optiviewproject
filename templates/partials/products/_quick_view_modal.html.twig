{# Quick View Modal #}
<div class="wrap-modal1 js-modal1 p-t-60 p-b-20">
    <div class="overlay-modal1 js-hide-modal1"></div>

    <div class="container">
        <div class="bg0 p-t-60 p-b-30 p-lr-15-lg how-pos3-parent">
            <button class="how-pos3 hov3 trans-04 js-hide-modal1">
                <img src="{{ asset('assets/images/icons/icon-close.png') }}" alt="CLOSE">
            </button>

            <div class="row">
                <div class="col-md-6 col-lg-7 p-b-30">
                    <div class="p-l-25 p-r-30 p-lr-0-lg">
                        <div class="wrap-slick3 flex-sb flex-w">
                            <div class="wrap-slick3-dots"></div>
                            <div class="wrap-slick3-arrows flex-sb-m flex-w"></div>

                            <div class="slick3 gallery-lb">
                             
                               
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-5 p-b-30">
                    <div class="p-r-50 p-t-5 p-lr-0-lg">
                        <!-- Category above product name -->
                        <div class="js-product-category-top stext-102 cl6 m-b-8" style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500;">
                            <!-- Category will be loaded here -->
                        </div>

                        <h4 class="mtext-105 cl2 js-product-name p-b-8">
                            <!-- Product name will be loaded here -->
                        </h4>

                        <!-- Brand below product name -->
                        <div class="js-product-brand-below stext-102 cl3 m-b-15" style="font-size: 1rem; font-weight: 600;">
                            <!-- Brand name will be loaded here -->
                        </div>

                        <!-- Price -->
                        <div class="m-b-15">
                            <h2 class="product-title" id="quick-view-product-title"></h2>
                            <div class="product-category" id="quick-view-product-category" style="font-size: 0.9rem; color: #6c757d; margin-bottom: 1rem;"></div>
                            
                            <!-- Offer Badge -->
                            <div class="js-offer-badge" style="display: none; margin-bottom: 10px;">
                                <span class="offer-badge" style="background: #e74c3c; color: white; padding: 4px 8px; border-radius: 3px; font-size: 12px; font-weight: bold;">
                                    <!-- Discount label will be loaded here -->
                                </span>
                            </div>
                            
                            <!-- Price Container -->
                            <div class="price-container">
                                <span class="mtext-106 cl2 js-product-price">
                                    <!-- Price will be loaded here -->
                                </span>
                                <span class="strike-text js-original-price m-l-10" style="text-decoration: line-through; color: #999; display: none;">
                                    <!-- Original price for discounted items -->
                                </span>
                                <span class="js-product-currency">
                                    <!-- Currency will be loaded here -->
                                </span>
                            </div>
                            
                            <!-- Countdown Timer -->
                            <div class="js-offer-countdown" style="display: none; margin-top: 10px; padding: 10px; background: #f8f9fa; border-radius: 5px; border-left: 4px solid #e74c3c;">
                                <div style="font-size: 14px; font-weight: 600; color: #e74c3c; margin-bottom: 5px;">⏰ Limited Time Offer</div>
                                <div class="countdown-timer" style="font-size: 16px; font-weight: bold; color: #333;">
                                    <span class="js-countdown-days">00</span>d 
                                    <span class="js-countdown-hours">00</span>h 
                                    <span class="js-countdown-minutes">00</span>m 
                                    <span class="js-countdown-seconds">00</span>s
                                </div>
                                <div class="js-countdown-expired" style="display: none; color: #999; font-style: italic;">
                                    Offer expired
                                </div>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="js-product-description stext-102 cl3 p-t-10 p-b-20">
                            <!-- Description will be loaded here -->
                        </div>

                        <!-- Stock Status -->
                        <div class="p-b-10">
                            <span class="js-stock-status" style="font-size: 14px; font-weight: 500;">
                                <!-- Stock status will be loaded here -->
                            </span>
                        </div>

                        {# Size selector removed #}

                        <!-- Color Selector -->
                        <div class="js-color-selector" style="display: none;">
                            <div class="flex-w flex-r-m p-b-10">
                                <div class="size-203 flex-c-m respon6">
                                    Color
                                </div>
                                <div class="size-204 respon6-next">
                                    <div class="rs1-select2 bor8 bg0">
                                        <select class="js-select2 js-select-color" name="color">
                                            <option>Choose an option</option>
                                            <!-- Colors will be loaded here -->
                                        </select>
                                        <div class="dropDownSelect2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Variant Selection -->
                        <div class="p-t-33">
                            <!-- This container will be populated by JS if variants exist -->
                            <div class="js-variant-selectors-container"></div>

                            <div class="flex-w flex-r-m p-b-10">
                                <div class="size-204 flex-w flex-m respon6-next">
                                    <div class="wrap-num-product flex-w m-r-20 m-tb-10">
                                        <div class="btn-num-product-down cl8 hov-btn3 trans-04 flex-c-m">
                                            <i class="fs-16 zmdi zmdi-minus"></i>
                                        </div>
                                        <input class="mtext-104 cl3 txt-center num-product" type="number" name="num-product" value="1">
                                        <div class="btn-num-product-up cl8 hov-btn3 trans-04 flex-c-m">
                                            <i class="fs-16 zmdi zmdi-plus"></i>
                                        </div>
                                    </div>

                                    <button class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04 js-addcart-detail" data-product-id="">
                                        {{ 'Add to cart'|trans }}
                                    </button>
                                    <button type="button" class="flex-c-m stext-101 cl0 size-101 bg3 bor1 hov-btn1 p-lr-15 trans-04 m-l-10 js-tryon" data-overlay="">
                                        Try On
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Stock info -->
                        <div class="js-stock-info p-b-10" style="display: none;">
                            <span class="stext-102 cl6">
                                <span class="js-stock-quantity">0</span> {{ 'in stock'|trans }}
                            </span>
                        </div>

                        <!-- Product meta -->
                        <div class="product-meta p-t-20">
                            
                            <div class="meta-item js-meta-style" style="display: none; margin-bottom: 8px;">
                                <span class="meta-label stext-102 cl6" style="font-weight: 600; margin-right: 8px;">{{ 'Style'|trans }}:</span>
                                <span class="meta-value js-product-style stext-102 cl3"></span>
                            </div>
                            <div class="meta-item js-meta-shape" style="display: none; margin-bottom: 8px;">
                                <span class="meta-label stext-102 cl6" style="font-weight: 600; margin-right: 8px;">{{ 'Shape'|trans }}:</span>
                                <span class="meta-value js-product-shape stext-102 cl3"></span>
                            </div>
                            <div class="meta-item js-meta-genre" style="display: none; margin-bottom: 8px;">
                                <span class="meta-label stext-102 cl6" style="font-weight: 600; margin-right: 8px;">{{ 'Genre'|trans }}:</span>
                                <span class="meta-value js-product-genre stext-102 cl3"></span>
                            </div>
                             <div class="meta-item js-meta-loyalty-points" style="display: none; margin-bottom: 8px;">
                                <span class="meta-label stext-102 cl6" style="font-weight: 600; margin-right: 8px;">{{ 'Loyalty Points'|trans }}:</span>
                                <span class="meta-value js-product-loyalty-points stext-102 cl3"></span>
                            </div>
                        </div>

                        <!-- Wishlist and Share -->
                        <div class="flex-w flex-m p-t-20 respon7">
                            <div class="flex-m bor9 p-r-10 m-r-11">
                                <button type="button" class="fs-14 cl3 hov-cl1 trans-04 lh-10 p-lr-5 p-tb-2 js-addwish-detail tooltip100 bg-transparent border-0" data-tooltip="Add to Wishlist">
                                    <i class="zmdi zmdi-favorite"></i>
                                </button>
                            </div>

                            <a href="#" class="fs-14 cl3 hov-cl1 trans-04 lh-10 p-lr-5 p-tb-2 m-r-8 tooltip100" data-tooltip="Facebook">
                                <i class="fa fa-facebook"></i>
                            </a>

                            <a href="#" class="fs-14 cl3 hov-cl1 trans-04 lh-10 p-lr-5 p-tb-2 m-r-8 tooltip100" data-tooltip="Twitter">
                                <i class="fa fa-twitter"></i>
                            </a>

                            <a href="#" class="fs-14 cl3 hov-cl1 trans-04 lh-10 p-lr-5 p-tb-2 m-r-8 tooltip100" data-tooltip="Google Plus">
                                <i class="fa fa-google-plus"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

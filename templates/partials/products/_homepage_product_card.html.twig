{# Product Card for Homepage Tabs - _homepage_product_card.html.twig #}
{% set offerData = product_offer_data(product) %}
<div class="block2">
    <div class="block2-pic hov-img0">
         {% if product.overviewImage %}
                <img src="{{ vich_uploader_asset(product, 'overviewImageFile') }}" alt="{{ product.name }}">
            {% else %}
                <img src="{{ asset('assets/images/no-image.webp') }}" alt="No image">
            {% endif %}
        
        {# Discount Badge #}
        {% if offerData.has_offer %}
            <div class="discount-badge" style="position: absolute; top: 10px; left: 10px; background: #e74c3c; color: white; padding: 5px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; z-index: 2;">
                {{ discount_label(product) }}
            </div>
        {% endif %}
        
        <div class="block2-actions" style="position:absolute; left:50%; transform:translateX(-50%); bottom:10px; display:flex; flex-direction:column; align-items:center; gap:8px; z-index:3;">
            <a href="#"
        class="block2-btn flex-c-m stext-103 cl2 size-102 bg0 bor2 hov-btn1 p-lr-15 trans-04 js-show-modal1 quickViewBtn"
        data-product-id="{{ product.id }}"
        data-product-name="{{ product.name|e('html_attr') }}"
        data-product-image="{{ product.overviewImage ? vich_uploader_asset(product, 'overviewImageFile') : asset('assets/images/no-image.webp') }}"
        data-product-price="{{ offerData.has_offer ? offerData.discounted_price|number_format(2, '.', '') : product.price|number_format(2, '.', '') }}"
        data-product-original-price="{{ offerData.has_offer ? offerData.original_price|number_format(2, '.', '') : '' }}"
        data-product-has-offer="{{ offerData.has_offer ? '1' : '0' }}"
        data-product-currency="EUR">
            Quick View
        </a>
          {% if product.overlayAsset %}
            <button class="flex-c-m stext-101 cl0 size-101 bg3 bor1 hov-btn1 p-lr-15 trans-04 js-tryon m-l-10"
                    data-overlay="{{ asset('uploads/overlays/' ~ product.overlayAsset) }}"
                    title="Try On">
                Try On
            </button>
        {% endif %}
        </div>
    </div>
    <div class="block2-txt flex-w flex-t p-t-14">
        <div class="block2-txt-child1 flex-col-l ">
            <a href="{{ path('product_show', {'id': product.id}) }}" class="stext-104 cl4 hov-cl1 trans-04 js-name-b2 p-b-6">
                {{ product.name }}
            </a>
            <div class="price-container">
                {% if offerData.has_offer %}
                    <span class="stext-105 cl3 js-card-price" style="font-weight: bold; color: #e74c3c;" data-price-eur="{{ offerData.discounted_price|number_format(2, '.', '') }}">
                        €{{ offerData.discounted_price|number_format(2, '.', '') }}
                    </span>
                    <span class="stext-105 cl6 js-card-original" data-original-eur="{{ offerData.original_price|number_format(2, '.', '') }}" style="text-decoration: line-through; margin-left: 8px; font-size: 0.9em;">
                        €{{ offerData.original_price|number_format(2, '.', '') }}
                    </span>
                {% else %}
                    <span class="stext-105 cl3 js-card-price" data-price-eur="{{ product.price|number_format(2, '.', '') }}">
                        €{{ product.price|number_format(2, '.', '') }}
                    </span>
                {% endif %}
            </div>
        </div>
        <div class="block2-txt-child2 flex-r p-t-3">
            <a href="#" class="btn-addwish-b2 dis-block pos-relative js-addwish-b2"
    data-product-id="{{ product.id }}"
    data-product-name="{{ product.name|e('html_attr') }}"
    data-product-image="{{ product.overviewImage ? vich_uploader_asset(product, 'overviewImageFile') : asset('assets/images/no-image.webp') }}"
    data-product-price="{{ offerData.has_offer ? offerData.discounted_price|number_format(2, '.', '') : product.price|number_format(2, '.', '') }}"
    data-product-original-price="{{ offerData.has_offer ? offerData.original_price|number_format(2, '.', '') : '' }}"
    data-product-has-offer="{{ offerData.has_offer ? '1' : '0' }}"
    data-product-currency="€">
    <img class="icon-heart1 dis-block trans-04" src="{{ asset('assets/images/icons/icon-heart-01.png') }}" alt="ICON">
    <img class="icon-heart2 dis-block trans-04 ab-t-l" src="{{ asset('assets/images/icons/icon-heart-02.png') }}" alt="ICON">
</a>
        </div>
    </div>
</div>



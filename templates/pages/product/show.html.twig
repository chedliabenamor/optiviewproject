            var stockStatus = opt.getAttribute('data-stock-status');
            var skuEl = document.getElementById('js-sku');
            var skuFooterEl = document.getElementById('js-sku-footer');
            if (skuEl) skuEl.textContent = sku || defaultSku;
            if (skuFooterEl) skuFooterEl.textContent = sku || defaultSku;
            var genreEl = document.getElementById('js-genre');
            if (genreEl) genreEl.textContent = genreName || defaultGenre;
            var styleEl = document.getElementById('js-style');
            if (styleEl) styleEl.textContent = styleName || defaultStyle;
            var stockEl = document.getElementById('js-stock');
            if (stockEl) {
                var stockText = (stockStatus ? stockStatus : '') + (stockQty ? ' ('+stockQty+')' : '');
                stockEl.textContent = stockText.trim() || defaultStock;
            }
            // Update main gallery when variant changes
            var vid = opt.value;
            var imgs = (vid === 'product') ? defaultImages : ((variantsData[vid] && variantsData[vid].length) ? variantsData[vid] : defaultImages);
            updateGallery(imgs);
            // Update offer/price UI based on selection
            if (vid === 'product') {
                fetch('{{ path('api_product_quick_view', { id: product.id }) }}')
                    .then(function(r){ return r.json(); })
                    .then(function(d){
                        try {
                            updateOfferUI(offerState.productOffer, d.price);
                        } catch(e) { /* noop */ }

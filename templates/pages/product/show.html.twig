        // --- Offer/Price helpers (mirrors quick-view.js) ---
        var offerState = { productOffer: null, variantOffers: {} };
        var countdownTimerId = null;

        function clearCountdown() {
            if (countdownTimerId) { clearInterval(countdownTimerId); countdownTimerId = null; }
        }

        // Reformat product price on currency change (re-uses Quick View API data)
        document.addEventListener('currencyChanged', function(){
            if (!window.Currency) return;
            // Instant local reformat using current state
            try {
                var selNow = document.querySelector('.js-variant-select');
                var vidNow = selNow && selNow.value ? selNow.value : null;
                var ovNow = vidNow && offerState && offerState.variantOffers ? (offerState.variantOffers[vidNow] || null) : (offerState ? offerState.productOffer : null);
                var baseNow = null;
                if (selNow && selNow.options && selNow.selectedIndex >= 0) {
                    var optNow = selNow.options[selNow.selectedIndex];
                    var dp = optNow ? (optNow.getAttribute('data-price') || optNow.dataset.price) : null;
                    if (dp != null && dp !== '') { var n = parseFloat(dp); if (!isNaN(n)) baseNow = n; }
                }
                updateOfferUI(ovNow, baseNow);
            } catch(e){}
            // Then refresh from API for authoritative data
            fetch('{{ path('api_product_quick_view', { id: product.id }) }}')
                .then(function(r){ return r.json(); })
                .then(function(d){
                    var sel = document.querySelector('.js-variant-select');
                    var vid = sel && sel.value ? sel.value : null;
                    var priceEl = document.querySelector('.js-product-price');
                    var originalPriceEl = document.querySelector('.js-original-price');
                    function fmtPair(discounted, original){
                        if (original != null) {
                            if (priceEl) { priceEl.style.color = '#e74c3c'; priceEl.style.fontWeight = '700'; priceEl.textContent = Currency.format(discounted); }
                            if (originalPriceEl) { originalPriceEl.style.display = 'inline'; originalPriceEl.textContent = Currency.format(original); }
                        } else {
                            if (priceEl) { priceEl.style.color = ''; priceEl.style.fontWeight = ''; priceEl.textContent = Currency.format(discounted); }
                            if (originalPriceEl) { originalPriceEl.style.display = 'none'; }
                        }
                    }
                    if (vid) {
                        var v = (d.productVariants || []).find(function(vv){ return String(vv.id) === String(vid); });
                        if (v) {
                            if (v.offer && v.offer.has_offer) {
                                fmtPair(v.offer.discounted_price, v.offer.original_price);
                            } else {
                                fmtPair(v.price, null);
                            }
                        }
                    } else {
                        if (d.offer && d.offer.has_offer) {
                            fmtPair(d.offer.discounted_price, d.offer.original_price);
                        } else {
                            fmtPair(d.price, null);
                        }
                    }
                })
                .catch(function(){
                    // Fallback: reformat whatever text is currently shown
                    try {
                        var priceEl = document.querySelector('.js-product-price');
                        var originalEl = document.querySelector('.js-original-price');
                        if (!priceEl || !window.Currency) return;
                        function toNum(txt){ try { return parseFloat(String(txt).replace(/[^0-9.\-]/g,'')); } catch(e){ return null; } }
                        var p = toNum(priceEl.textContent || '');
                        var o = originalEl && originalEl.style.display !== 'none' ? toNum(originalEl.textContent || '') : null;
                        if (p != null) {
                            if (o != null) {
                                priceEl.style.color = '#e74c3c';
                                priceEl.style.fontWeight = '700';
                                priceEl.textContent = Currency.format(p);
                                if (originalEl) { originalEl.style.display = 'inline'; originalEl.textContent = Currency.format(o); }
                            } else {
                                priceEl.style.color = '';
                                priceEl.style.fontWeight = '';

                    var imgEl = document.querySelector('.slick3 .item-slick3.slick-current img') || document.querySelector('.slick3 .item-slick3 img');
                    var img = imgEl ? imgEl.getAttribute('src') : ({{ product.overviewImage ? (vich_uploader_asset(product, 'overviewImageFile') | json_encode | raw) : 'null' }} || '');
                    var evt = new CustomEvent('addToCart', { detail: { productId: productId, productName: name, productPrice: priceNum, productImage: img, quantity: q, variantId: vId || null, variantName: '' }, bubbles: true });

        if (window.jQuery && window.jQuery.fn.select2) {
            function formatOption(opt) {
                if (!opt.id) return opt.text;
                var img = jQuery(opt.element).data('img');
                var text = opt.text;
                if (img) {
                    return jQuery('<span class="d-flex align-items-center"><img src="'+img+'" style="width:28px;height:28px;object-fit:cover;border-radius:4px;margin-right:8px;" />'+text+'</span>');

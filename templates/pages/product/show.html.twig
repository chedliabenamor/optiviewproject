        function startCountdown(endIso) {
            clearCountdown();
            var container = document.querySelector('.js-offer-countdown');
            var daysEl = document.querySelector('.js-countdown-days');
            var hoursEl = document.querySelector('.js-countdown-hours');
            var minutesEl = document.querySelector('.js-countdown-minutes');
            var secondsEl = document.querySelector('.js-countdown-seconds');
            var expiredEl = document.querySelector('.js-countdown-expired');
            if (!container || !endIso) return;
            function tick() {
                var now = new Date();
                var end = new Date(endIso);
                var diff = end - now;
                if (diff <= 0) {
                    if (expiredEl) expiredEl.style.display = 'block';
                    daysEl.textContent = hoursEl.textContent = minutesEl.textContent = secondsEl.textContent = '00';
                    clearCountdown();
                    return;
                }
                var totalSeconds = Math.floor(diff/1000);
                var days = Math.floor(totalSeconds / 86400);
                var hours = Math.floor((totalSeconds % 86400) / 3600);
                var minutes = Math.floor((totalSeconds % 3600) / 60);
                var seconds = totalSeconds % 60;
                daysEl.textContent = String(days).padStart(2, '0');
                hoursEl.textContent = String(hours).padStart(2, '0');
                minutesEl.textContent = String(minutes).padStart(2, '0');
                secondsEl.textContent = String(seconds).padStart(2, '0');
            }
            container.style.display = 'block';
            if (expiredEl) expiredEl.style.display = 'none';
            tick();
            countdownTimerId = setInterval(tick, 1000);
        }

        function updateOfferUI(offer, basePrice) {

    <script>
    // Wishlist handling on the product detail page (guest + auth, variant-aware)
    document.addEventListener('DOMContentLoaded', function() {
        var wishBtn = document.querySelector('.js-addwish-detail');
        if (!wishBtn) return;

        function isGuest() {
            return !(typeof window.isAuthenticated !== 'undefined' && (window.isAuthenticated === true || window.isAuthenticated === 'true'));
        }

        function getSelectedVariantId() {
            var sel = document.querySelector('.js-variant-select');
            if (!sel) return null;
            var val = sel.value;
            return (val && val !== 'product') ? val : null;
        }

        function updateHeart(filled) {
            var icon = wishBtn.querySelector('i');
            if (!icon) return;
            if (filled) {
                icon.classList.remove('zmdi-favorite-outline');
                icon.classList.add('zmdi-favorite');
                wishBtn.setAttribute('data-tooltip', 'Remove from Wishlist');
            } else {
                icon.classList.remove('zmdi-favorite');
                icon.classList.add('zmdi-favorite-outline');
                wishBtn.setAttribute('data-tooltip', 'Add to Wishlist');
            }
        }

        function checkStatus() {
            var productId = wishBtn.getAttribute('data-product-id');
            var variantId = getSelectedVariantId();
            if (isGuest()) {
                try {
                    var items = JSON.parse(localStorage.getItem('wishlist') || '[]');
                    var found = items.some(function(it){ return String(it.id) === String(productId) && String(it.variantId||'') === String(variantId||''); });
                    updateHeart(found);
                } catch(e) { updateHeart(false); }
            } else {
                var url = '/api/wishlist/check/' + productId + (variantId ? ('?variantId=' + encodeURIComponent(variantId)) : '');
                fetch(url).then(function(r){return r.json();}).then(function(d){ updateHeart(!!d.inWishlist); }).catch(function(){ updateHeart(false); });
            }
        }

        function readPriceInfo() {
            var priceEl = document.querySelector('.js-product-price');
            var originalEl = document.querySelector('.js-original-price');
            var priceText = priceEl ? priceEl.textContent.trim() : '';
            var originalText = (originalEl && originalEl.style.display !== 'none') ? originalEl.textContent.trim() : '';
            var currency = priceText.replace(/[0-9.,\s-]/g, '') || '€';
            function toNumber(txt){ try { return parseFloat(String(txt).replace(/[^0-9.\-]/g,'')); } catch(e){ return null; } }
            return { currency: currency, price: toNumber(priceText), originalPrice: originalText ? toNumber(originalText) : null, hasOffer: !!originalText };
        }

        function toggleWishlist() {
            var productId = wishBtn.getAttribute('data-product-id');
            var variantId = getSelectedVariantId();
            if (isGuest()) {
                var items = [];
                try { items = JSON.parse(localStorage.getItem('wishlist') || '[]'); } catch(e){}
                var idx = items.findIndex(function(it){ return String(it.id) === String(productId) && String(it.variantId||'') === String(variantId||''); });
                var action = 'added';
                if (idx >= 0) { items.splice(idx,1); action = 'removed'; }
                else {
                    var info = readPriceInfo();
                    // Append selected color name to title if available
                    var name = '{{ product.name|e('js') }}';
                    var sel = document.querySelector('.js-variant-select');
                    if (sel && sel.value && sel.value !== 'product') {
                        var txt = sel.options[sel.selectedIndex].textContent.trim();
                        if (txt) name = name + ' - ' + txt;
                    }
                    // Try to pick first gallery image
                    var galImg = document.querySelector('.slick3.gallery-lb .item-slick3 img');
                    var image = galImg ? galImg.getAttribute('src') : '';
                    items.push({ id: productId, variantId: variantId || '', name: name, image: image, price: info.price, originalPrice: info.originalPrice, hasOffer: info.hasOffer, currency: info.currency, priceFormatted: info.currency + (info.price!=null?info.price.toFixed(2):''), originalPriceFormatted: info.originalPrice!=null ? (info.currency + info.originalPrice.toFixed(2)) : '' });
                }
                localStorage.setItem('wishlist', JSON.stringify(items));
                // Update header count
                try { var count = items.length; setHeaderWishlistCount(count); } catch(e){}
                updateHeart(action === 'added');
                // Feedback
                var info2 = readPriceInfo();
                var addedName = (items.find(function(it){return String(it.id)===String(productId)&&String(it.variantId||'')===String(variantId||'');})?.name || '{{ product.name|e('js') }}');
                if (action === 'added') { showWishlistAdded(addedName, info2); } else { showWishlistRemoved(addedName); }
                document.dispatchEvent(new CustomEvent('wishlistUpdated'));
                return;
            }
            // Authenticated users -> API
            fetch('/api/wishlist/toggle/'+productId, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ variantId: variantId }) })
                .then(function(r){return r.json();})
                .then(function(d){ if (!d || !d.success) return; updateHeart(d.inWishlist); if (d.action==='added') { adjustHeaderWishlistCount(1); } else { adjustHeaderWishlistCount(-1); } refreshHeaderWishlistCountAuth(); var baseName='{{ product.name|e('js') }}'; if (d.action==='added') { showWishlistAdded(baseName); } else { showWishlistRemoved(baseName); } document.dispatchEvent(new CustomEvent('wishlistUpdated')); })
                .catch(function(){});
        }

        // Init
        checkStatus();
        // Apply currency formatting on initial load as well (slight delay to ensure Currency is ready)
        try { setTimeout(function(){ if (window.Currency) { document.dispatchEvent(new CustomEvent('currencyChanged')); } }, 150); } catch(e){}
        // Bind click
        wishBtn.addEventListener('click', function(e){ e.preventDefault(); toggleWishlist(); });
        // Re-check when variant changes
        var sel = document.querySelector('.js-variant-select');
        if (sel) {
            sel.addEventListener('change', checkStatus);
            if (window.jQuery && window.jQuery(sel).data('select2')) {
                window.jQuery(sel).on('select2:select', checkStatus);
            }
        }
        // Re-check when wishlist is updated elsewhere (e.g., sidebar removal)
        document.addEventListener('wishlistUpdated', function(){
            try { checkStatus(); } catch(e){}
        });

        // =====================
        // Add to Cart (Detail) 
        // =====================
        (function initDetailAddToCart(){
            var addBtn = document.querySelector('.js-addcart-detail');
            if (!addBtn) return;
            // Ensure product id present
            addBtn.dataset.productId = addBtn.dataset.productId || '{{ product.id }}';

            // Helper: parse number from price text
            function parsePriceText(txt){ try { return parseFloat(String(txt).replace(/[^0-9.\-]/g,'')) || 0; } catch(e){ return 0; } }

            // Track variant selection and stock
            var variantSelect = document.querySelector('.js-variant-select');
            var stockInlineEl = document.querySelector('.js-inline-stock-status');
            function setInlineStockStatus(stock){
                if (!stockInlineEl) return;
                var n = parseInt(stock, 10);
                if (isNaN(n) || n <= 0) {
                    stockInlineEl.textContent = 'Out of stock';
                    stockInlineEl.style.color = '#dc3545';
                } else {
                    stockInlineEl.textContent = 'Available';
                    stockInlineEl.style.color = '#28a745';
                }
            }
            function applyStockStateFromOption(opt){
                var stockAttr = opt ? opt.getAttribute('data-stock') : '{{ product.getTotalStock() }}';
                var stock = stockAttr != null && stockAttr !== '' ? parseInt(stockAttr, 10) : 0;
                if (isNaN(stock)) stock = 0;
                // Disable/enable button
                addBtn.disabled = stock <= 0;
                // Update inline status under price
                setInlineStockStatus(stock);
            }
            function onVariantChange(){
                if (!variantSelect) return;
                var selOpt = variantSelect.options[variantSelect.selectedIndex];
                if (!selOpt) return;
                var val = variantSelect.value;
                if (val && val !== 'product') {
                    addBtn.dataset.variantId = String(val);
                    addBtn.dataset.variantName = selOpt.getAttribute('data-color-name') || '';
                } else {
                    addBtn.dataset.variantId = '';
                    addBtn.dataset.variantName = selOpt.getAttribute('data-color-name') || '';
                }
                applyStockStateFromOption(selOpt);
            }
            if (variantSelect) {
                // Initialize from current selection
                onVariantChange();
                // Bind change handler
                if (typeof window.jQuery !== 'undefined') {
                    jQuery(variantSelect).on('change', onVariantChange);
                } else {
                    variantSelect.addEventListener('change', onVariantChange);
                }
            } else {
                // No variants: apply product-level stock and set inline status
                applyStockStateFromOption(null);
            }

            // Click handler to dispatch global addToCart event
            document.addEventListener('click', function(e){
                var btn = e.target.closest('.js-addcart-detail');
                if (!btn) return;
                // Ensure we are on product detail page button
                if (!btn.isSameNode(addBtn)) return;
                e.preventDefault();
                e.stopPropagation();

                // Block if disabled (out of stock)
                if (btn.disabled) {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({ icon: 'warning', title: 'Out of Stock', text: 'This product is currently unavailable.', timer: 1200, showConfirmButton: false });
                    }
                    return;
                }

                try {
                    var productId = btn.dataset.productId;
                    var variantId = btn.dataset.variantId || '';
                    var variantName = btn.dataset.variantName || '';
                    var qtyInput = document.querySelector('.num-product');
                    var quantity = qtyInput ? (parseInt(qtyInput.value) || 1) : 1;

                    var nameEl = document.querySelector('.js-name-detail') || document.querySelector('.js-product-name');
                    var productName = nameEl ? nameEl.textContent.trim() : '';

                    var priceEl = document.querySelector('.js-product-price');
                    var priceNum = priceEl ? parsePriceText(priceEl.textContent) : 0;

                    var curImg = document.querySelector('.slick3 .item-slick3.slick-current img') || document.querySelector('.slick3 .item-slick3 img');
                    var productImage = curImg ? (curImg.getAttribute('src') || '') : ('{{ product.overviewImage ? vich_uploader_asset(product, 'overviewImageFile') : '' }}');

                    var evt = new CustomEvent('addToCart', { detail: {
                        productId: productId,
                        productName: productName,
                        productPrice: priceNum,
                        productImage: productImage,
                        quantity: quantity,
                        variantId: variantId,
                        variantName: variantName
                    }, bubbles: true });
                    document.dispatchEvent(evt);

                    if (typeof Swal !== 'undefined') {
                        Swal.fire({ position: 'top-center', icon: 'success', title: 'Added to cart!', showConfirmButton: false, timer: 1000 });
                    }
                } catch(err) {
                    console.error('Failed to add to cart from product detail:', err);
                }
            });
        })();
    });
    </script>
    <script>
    // Rating stars UI logic
    document.addEventListener('DOMContentLoaded', function() {
        var containers = document.querySelectorAll('.wrap-rating[data-input-id]');
        containers.forEach(function(container){
            var inputId = container.getAttribute('data-input-id');
            var inputEl = document.getElementById(inputId);
            var stars = Array.prototype.slice.call(container.querySelectorAll('.item-rating'));
            function render(val){
                stars.forEach(function(star){
                    var v = parseInt(star.getAttribute('data-value'));
                    star.classList.toggle('zmdi-star', v <= val);
                    star.classList.toggle('zmdi-star-outline', v > val);
                });
            }
            var current = inputEl && inputEl.value ? parseInt(inputEl.value) : 0;
            render(current);
            stars.forEach(function(star){
                star.addEventListener('click', function(){
                    var v = parseInt(star.getAttribute('data-value'));
                    if (inputEl) { inputEl.value = v; }
                    render(v);
                });
                star.addEventListener('mouseenter', function(){
                    render(parseInt(star.getAttribute('data-value')));
                });
            });
            container.addEventListener('mouseleave', function(){
                var v = inputEl && inputEl.value ? parseInt(inputEl.value) : 0;
                render(v);
            });
        });
    });
    </script>

{% endblock %}

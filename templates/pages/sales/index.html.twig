{% extends 'base.html.twig' %}

{% block title %}Sales{% endblock %}

{% block body %}
<section class="bg0 p-t-40 p-b-60">
  <div class="container">
    <div class="bread-crumb flex-w  p-r-15 p-b-15 p-lr-0-lg">
      <a href="{{ path('app_home') }}" class="stext-109 cl8 hov-cl1 trans-04">Home
        <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
      </a>
      <span class="stext-109 cl4">Sales</span>
    </div>

    <div class="p-b-20 d-flex justify-content-between align-items-center flex-wrap" style="gap:10px;">
      <h2 class="ltext-103 cl5">Current Sales</h2>
      <div class="d-flex align-items-center" style="gap:8px;">
        <span class="stext-113 cl6">Sort by:</span>
        {% set currentSort = app.request.query.get('sort') %}
        <a class="stext-113 {{ currentSort is not defined or currentSort is empty ? 'cl5' : 'cl6' }}" href="{{ path('sales_index') }}">End soon</a>
        <span class="cl12">|</span>
        <a class="stext-113 {{ currentSort == 'discount' ? 'cl5' : 'cl6' }}" href="{{ path('sales_index', { sort: 'discount' }) }}">Discount %</a>
        <span class="cl12">|</span>
        <a class="stext-113 {{ currentSort == 'newest' ? 'cl5' : 'cl6' }}" href="{{ path('sales_index', { sort: 'newest' }) }}">Newest</a>
      </div>
    </div>



    {% if offers is empty %}
      <p>No active sales at the moment. Please check back soon.</p>
    {% else %}
      <div class="row g-4">
        {% for offer in offers %}
          <div class="col-12">
            <div class="offer-card">
              {% set offerImg = vich_uploader_asset(offer, 'imageFile') ?: offer.imageUrl %}
              <div class="offer-ribbon">
                {% if offer.discountType == 'percentage' %}
                  Up to {{ offer.discountValue|number_format(0) }}% off
                {% else %}
                  Save €{{ offer.discountValue|number_format(0) }}
                {% endif %}
              </div>
              <div class="offer-body">
                <div class="offer-left">
                  <div class="offer-title">{{ offer.name }}</div>
                  {% if offer.description %}
                    <div class="offer-desc">{{ offer.description|striptags|replace({'&nbsp;':' '})|trim }}</div>
                  {% endif %}
                  {% set diff = offer.endDate|date('U') - 'now'|date('U') %}
                  {% if diff > 0 and diff < 172800 %}
                    <span class="badge" style="background:#fff1f0;color:#e74c3c;border:1px solid #ffd4cf;margin-bottom:8px;">Ending Soon</span>
                  {% endif %}
                  <a href="{{ path('sales_show', { id: offer.id }) }}" class="offer-cta">Shop now</a>
                  <div class="offer-meta">Valid until {{ offer.endDate|date('M d, Y H:i') }} · <span class="js-offer-timer" data-end="{{ offer.endDate|date('c') }}">--:--:--</span></div>
                </div>
                <div class="offer-right">
                  <div class="image-circle">
                    {% if offerImg %}
                      <img src="{{ offerImg }}" alt="{{ offer.name }}">
                    {% else %}
                      <img src="{{ asset('assets/images/no-image.webp') }}" alt="No image">
                    {% endif %}
                  </div>
                </div>
              </div>

              {# Listing page: no inline grids to keep cards lightweight. Users click CTA to view details. #}

            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
<script>
(function(){
    document.addEventListener('DOMContentLoaded', function() {
        $('header').addClass('header-v4');
    });
  function pad(n){return String(n).padStart(2,'0');}
  function tick(){
    var nodes = document.querySelectorAll('.js-offer-timer');
    var now = new Date();
    nodes.forEach(function(el){
      var endIso = el.getAttribute('data-end');
      if(!endIso) return;
      var end = new Date(endIso);
      var diff = end - now;
      if(diff <= 0){ el.textContent = 'Expired'; return; }
      var s = Math.floor(diff/1000);
      var d = Math.floor(s/86400);
      var h = Math.floor((s%86400)/3600);
      var m = Math.floor((s%3600)/60);
      var sec = s%60;
      el.textContent = (d>0? d+'d ':'') + pad(h)+':'+pad(m)+':'+pad(sec);
    });
  }
  tick();
  setInterval(tick, 1000);
})();
</script>
{% endblock %}

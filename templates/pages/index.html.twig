{% extends 'base.html.twig' %}

{% block title %}Homepage Optiview{% endblock %}

{% block body %}
<section class="section-slide">
		<div class="wrap-slick1">
			<div class="slick1">
				<div class="item-slick1" style="background-image: url({{ asset('assets/images/slide-01.jpg') }});">
					<div class="container h-full">
						<div class="flex-col-l-m h-full p-t-100 p-b-30 respon5">
							<div class="layer-slick1 animated visible-false" data-appear="fadeInDown" data-delay="0">
								<span class="ltext-101 cl2 respon2">
									See Clearly. Shop Stylishly
								</span>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="fadeInUp" data-delay="800">
								<h2 class="ltext-201 cl2 p-t-19 p-b-43 respon1">
									Discover frames that fit your face — and your fashion.
								</h2>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="zoomIn" data-delay="1600">
								<a href="product.html" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">
									Shop Now
								</a>
							</div>
						</div>
					</div>
				</div>

				<div class="item-slick1" style="background-image: url({{ asset('assets/images/slide-02.jpg') }});">
					<div class="container h-full">
						<div class="flex-col-l-m h-full p-t-100 p-b-30 respon5">
							<div class="layer-slick1 animated visible-false" data-appear="rollIn" data-delay="0">
								<span class="ltext-101 cl2 respon2">
									Your Perfect Pair Awaits!
								</span>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="lightSpeedIn" data-delay="800">
								<h2 class="ltext-201 cl2 p-t-19 p-b-43 respon1">
									Trendy, timeless, or bold — find glasses that match your vibe.
								</h2>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="slideInUp" data-delay="1600">
								<a href="product.html" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">
									Shop Now
								</a>
							</div>
						</div>
					</div>
				</div>

				<div class="item-slick1" style="background-image: url({{ asset('assets/images/slide-03.jpg') }});">
					<div class="container h-full">
						<div class="flex-col-l-m h-full p-t-100 p-b-30 respon5">
							<div class="layer-slick1 animated visible-false" data-appear="rotateInDownLeft" data-delay="0">
								<span class="ltext-101 cl2 respon2">
									Look Sharp. Feel Confident.
								</span>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="rotateInUpRight" data-delay="800">
								<h2 class="ltext-201 cl2 p-t-19 p-b-43 respon1">
									Elevate your vision with our handpicked designer eyewear.
								</h2>
							</div>
								
							<div class="layer-slick1 animated visible-false" data-appear="rotateIn" data-delay="1600">
								<a href="product.html" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">
									Shop Now
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Banner -->
	<section class="service">
                <div class="container">
                    <ul class="service-list">
                        <li class="service-item">
                            <div class="service-item-icon">
                                <img src="{{ asset('assets/images/icons/service-icon-1.png') }}" alt="Service icon">
                            </div>

                            <div class="service-content">
                                <p class="service-item-title">Free Shopping</p>
                                <p class="service-item-text">On all irder over $100</p>
                            </div>
                        </li>

                        <li class="service-item">
                            <div class="service-item-icon">
                                <img src="{{ asset('assets/images/icons/service-icon-2.png') }}" alt="Service icon">
                            </div>

                            <div class="service-content">
                                <p class="service-item-title">Easy Returns</p>
                                <p class="service-item-text">30 days return policy</p>
                            </div>
                        </li>

                        <li class="service-item">
                            <div class="service-item-icon">
                                <img src="{{ asset('assets/images/icons/service-icon-3.png') }}" alt="Service icon">
                            </div>

                            <div class="service-content">
                                <p class="service-item-title">Secure payment</p>
                                <p class="service-item-text">100% secure guarantee</p>
                            </div>
                        </li>

                        <li class="service-item">
                            <div class="service-item-icon">
                                <img src="{{ asset('assets/images/icons/service-icon-4.png') }}" alt="Service icon">
                            </div>

                            <div class="service-content">
                                <p class="service-item-title">Special support</p>
                                <p class="service-item-text">24/7 dedicated support</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </section>
	<div class="sec-banner bg0 p-t-80 p-b-50">
		<div class="container">
			<div class="row">
				{% for category in categories %}
				<div class="col-md-6 col-xl-4 p-b-30 m-lr-auto">
					<!-- Block1 -->
					<div class="block1 wrap-pic-w">
						{% if category.imageName %}
							<img src="{{ vich_uploader_asset(category, 'imageFile') }}" alt="{{ category.name }}">
						{% else %}
							<img src="{{ asset('images/banner-01.jpg') }}" alt="IMG-BANNER">
						{% endif %}

						<a href="#" class="block1-txt ab-t-l s-full flex-col-l-sb p-lr-38 p-tb-34 trans-03 respon3">
							<div class="block1-txt-child1 flex-col-l">
								<span class="block1-name ltext-102 trans-04 p-b-8">
									{{ category.name }}
								</span>

								<span class="block1-info stext-102 trans-04">
									New Trend
								</span>
							</div>

							<div class="block1-txt-child2 p-b-4 trans-05">
								<div class="block1-link stext-101 cl0 trans-09">
									Shop Now
								</div>
							</div>
						</a>
					</div>

				</div>
				{% endfor %}
			</div>
		</div>
	</div>

	{# Dynamic Product Tabs Section #}

	<section class="sec-product bg0 p-t-100 p-b-50">
		<div class="container">
			<div class="p-b-32">
				<h3 class="ltext-105 cl5 txt-center respon1">
					Store Overview
				</h3>
			</div>
			<!-- Tab01 -->
			<div class="tab01">
				<!-- Nav tabs -->
				<ul class="nav nav-tabs" role="tablist">
					{% for category in categories %}
						<li class="nav-item p-b-10">
							<a class="nav-link {% if loop.first %}active{% endif %}" data-toggle="tab" href="#tab-{{ category.id }}" role="tab">{{ category.name }}</a>
						</li>
					{% endfor %}
				</ul>
				<!-- Tab panes -->
				<div class="tab-content p-t-50">
					{% for category in categories %}
						<div class="tab-pane fade {% if loop.first %}show active{% endif %}" id="tab-{{ category.id }}" role="tabpanel">
							<div class="wrap-slick2">
								<div class="slick2">
									{% set products = category.products ?? [] %}
									{% for product in products %}
										<div class="item-slick2 p-l-15 p-r-15 p-t-15 p-b-15">
											{% include 'partials/products/_homepage_product_card.html.twig' with { product: product } %}
										</div>
									{% else %}
										<div class="col-12"><p class="text-center">No products found in this category.</p></div>
									{% endfor %}
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			</div>
		</div>
	</section>

	<!-- Blog Section -->
	{% if latestPosts is not empty %}
	<section class="sec-blog bg0 p-t-60 p-b-90">
		<div class="container">
			<div class="p-b-66">
				<h3 class="ltext-105 cl5 txt-center respon1">
					Our Blogs
				</h3>
			</div>

			<div class="row">
				{% for post in latestPosts %}
				<div class="col-sm-6 col-md-4 p-b-40">
					<div class="blog-item">
						<div class="hov-img0">
							<a href="{{ path('blog_post_show', {'slug': post.slug}) }}">
								{% if post.image %}
									<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
								{% else %}
									<img src="{{ asset('assets/images/blog-0' ~ (loop.index) ~ '.jpg') }}" alt="IMG-BLOG">
								{% endif %}
							</a>
						</div>

						<div class="p-t-15">
							<div class="stext-107 flex-w p-b-14">
								<span class="m-r-3">
									<span class="cl4">
										By
									</span>
									<span class="cl5">
										{{ post.author.firstName ?? 'Admin' }} {{ post.author.lastName ?? '' }}
									</span>
								</span>

								<span>
									<span class="cl4">
										on
									</span>
									<span class="cl5">
										{{ post.date ? post.date|date('F j, Y') : post.createdAt|date('F j, Y') }}
									</span>
								</span>
							</div>

							<h4 class="p-b-12">
								<a href="{{ path('blog_post_show', {'slug': post.slug}) }}" class="mtext-101 cl2 hov-cl1 trans-04">
									{{ post.title }}
								</a>
							</h4>

							<p class="stext-108 cl6">
								{{ post.content|striptags|slice(0, 120) }}{% if post.content|length > 120 %}...{% endif %}
							</p>
						</div>
					</div>
				</div>
				{% endfor %}
			</div>
		</div>
	</section>
	{% endif %}

{% endblock %}
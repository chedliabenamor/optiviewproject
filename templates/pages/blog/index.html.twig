{% extends 'base.html.twig' %}

{% block title %}Blog - OptiView{% endblock %}

{% block body %}
<section class="bg-img1 txt-center p-lr-15 p-tb-92" style="background-image: url('{{ asset('assets/images/blog.jpg') }}');background-position: center top 40%;">
		<h2 class="ltext-105 cl0 txt-center">
			Frame Your Look: Glasses Trends & Advice
		</h2>
	</section>	
<section class="bg0 p-t-62 p-b-60">
		<div class="container">
			<div class="row">
				<div class="col-md-8 col-lg-9 p-b-80">
					<div class="p-r-45 p-r-0-lg">
						{% for post in posts %}
						<!-- item blog -->
						<div class="p-b-63">
							<a href="{{ path('blog_post_show', {'slug': post.slug}) }}" class="hov-img0 how-pos5-parent">
								{% if post.image %}
									<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
								{% else %}
									<img src="{{ asset('assets/images/blog-0' ~ (loop.index % 3 + 1) ~ '.jpg') }}" alt="IMG-BLOG">
								{% endif %}

								<div class="flex-col-c-m size-123 bg9 how-pos5">
									<span class="ltext-107 cl2 txt-center">
										{{ (post.date ?? post.createdAt)|date('d') }}
									</span>

									<span class="stext-109 cl3 txt-center">
										{{ (post.date ?? post.createdAt)|date('M Y') }}
									</span>
								</div>
							</a>

							<div class="p-t-32">
								<h4 class="p-b-15">
									<a href="{{ path('blog_post_show', {'slug': post.slug}) }}" class="ltext-108 cl2 hov-cl1 trans-04">
										{{ post.title }}
									</a>
								</h4>

								<p class="stext-117 cl6">
									{{ post.content|striptags|slice(0, 150) }}{% if post.content|length > 150 %}...{% endif %}
								</p>

								<div class="flex-w flex-sb-m p-t-18">
									<span class="flex-w flex-m stext-111 cl2 p-r-30 m-tb-10">
										<span>
											<span class="cl4">By</span> {{ post.author.firstName ?? 'Admin' }} {{ post.author.lastName ?? '' }}
											<span class="cl12 m-l-4 m-r-6">|</span>
										</span>

										<span>
											{% if post.category %}{{ post.category.name }}{% endif %}
											{% if post.tags is not empty %}
												{% for tag in post.tags %}
													{{ tag.name }}{% if not loop.last %}, {% endif %}
												{% endfor %}
											{% endif %}
											<span class="cl12 m-l-4 m-r-6">|</span>
										</span>

										<span>
											{{ post.comments|length }} Comment{{ post.comments|length != 1 ? 's' : '' }}
										</span>
									</span>

									<a href="{{ path('blog_post_show', {'slug': post.slug}) }}" class="stext-101 cl2 hov-cl1 trans-04 m-tb-10">
										Continue Reading

										<i class="fa fa-long-arrow-right m-l-9"></i>
									</a>
								</div>
							</div>
						</div>
						{% else %}
						<div class="p-b-63">
							<p class="stext-117 cl6 txt-center">No blog posts available at the moment.</p>
						</div>
						{% endfor %}

						<!-- Pagination -->
						{% if totalPages > 1 %}
						<div class="flex-l-m flex-w w-full p-t-10 m-lr--7">
							{% set paginationParams = {} %}
							{% if categorySlug %}
								{% set paginationParams = paginationParams|merge({'category': categorySlug}) %}
							{% endif %}
							{% if tagSlug %}
								{% set paginationParams = paginationParams|merge({'tag': tagSlug}) %}
							{% endif %}
							{% if searchQuery %}
								{% set paginationParams = paginationParams|merge({'search': searchQuery}) %}
							{% endif %}

							{% if currentPage > 1 %}
								<a href="{{ path('blog_index', paginationParams|merge({'page': currentPage - 1})) }}" class="flex-c-m how-pagination1 trans-04 m-all-7">
									<i class="fa fa-angle-left"></i>
								</a>
							{% endif %}

							{% for page in 1..totalPages %}
								{% if page == currentPage %}
									<span class="flex-c-m how-pagination1 trans-04 m-all-7 active-pagination1">
										{{ page }}
									</span>
								{% else %}
									<a href="{{ path('blog_index', paginationParams|merge({'page': page})) }}" class="flex-c-m how-pagination1 trans-04 m-all-7">
										{{ page }}
									</a>
								{% endif %}
							{% endfor %}

							{% if currentPage < totalPages %}
								<a href="{{ path('blog_index', paginationParams|merge({'page': currentPage + 1})) }}" class="flex-c-m how-pagination1 trans-04 m-all-7">
									<i class="fa fa-angle-right"></i>
								</a>
							{% endif %}
						</div>
						{% endif %}
					</div>
				</div>

				<div class="col-md-4 col-lg-3 p-b-80">
					<div class="side-menu">
						<form method="GET" action="{{ path('blog_index') }}" class="bor17 of-hidden pos-relative">
							{% if categorySlug %}
								<input type="hidden" name="category" value="{{ categorySlug }}">
							{% endif %}
							{% if tagSlug %}
								<input type="hidden" name="tag" value="{{ tagSlug }}">
							{% endif %}
							<input class="stext-103 cl2 plh4 size-116 p-l-28 p-r-55" type="text" name="search" placeholder="Search" value="{{ searchQuery ?? '' }}">

							<button type="submit" class="flex-c-m size-122 ab-t-r fs-18 cl4 hov-cl1 trans-04">
								<i class="zmdi zmdi-search"></i>
							</button>
						</form>

						<!-- Active Filters -->
						{% if currentCategory or currentTag or searchQuery %}
						<div class="p-t-30">
							<h4 class="mtext-112 cl2 p-b-20">Active Filters</h4>
							{% if currentCategory %}
								<div class="flex-w flex-sb-m p-b-12">
									<span class="stext-103 cl6">Category: {{ currentCategory.name }}</span>
									<a href="{{ path('blog_index', {tag: tagSlug, search: searchQuery}) }}" class="stext-103 cl6 hov-cl1 trans-04">
										<i class="fa fa-times"></i> Clear
									</a>
								</div>
							{% endif %}
							{% if currentTag %}
								<div class="flex-w flex-sb-m p-b-12">
									<span class="stext-103 cl6">Tag: {{ currentTag.name }}</span>
									<a href="{{ path('blog_index', {category: categorySlug, search: searchQuery}) }}" class="stext-103 cl6 hov-cl1 trans-04">
										<i class="fa fa-times"></i> Clear
									</a>
								</div>
							{% endif %}
							{% if searchQuery %}
								<div class="flex-w flex-sb-m p-b-12">
									<span class="stext-103 cl6">Search: "{{ searchQuery }}"</span>
									<a href="{{ path('blog_index', {category: categorySlug, tag: tagSlug}) }}" class="stext-103 cl6 hov-cl1 trans-04">
										<i class="fa fa-times"></i> Clear
									</a>
								</div>
							{% endif %}
						</div>
						{% endif %}

						<div class="p-t-55">
							<h4 class="mtext-112 cl2 p-b-33">
								Categories
								{% if currentCategory %}
									<span class="stext-109 cl6">(Filtered by: {{ currentCategory.name }})</span>
								{% endif %}
							</h4>

							<ul>
								{% if currentCategory %}
								<li class="bor18">
									<a href="{{ path('blog_index') }}" class="dis-block stext-115 cl2 hov-cl1 trans-04 p-tb-8 p-lr-4">
										<i class="fa fa-times m-r-5"></i>Clear Filter
									</a>
								</li>
								{% endif %}
								{% for category in categories %}
								<li class="bor18">
									<a href="{{ path('blog_index') }}?category={{ category.slug }}{% if tagSlug %}&tag={{ tagSlug }}{% endif %}{% if searchQuery %}&search={{ searchQuery }}{% endif %}" class="dis-block stext-115 {% if currentCategory and currentCategory.slug == category.slug %}cl1{% else %}cl6{% endif %} hov-cl1 trans-04 p-tb-8 p-lr-4">
										{{ category.name }}
									</a>
								</li>
								{% endfor %}
							</ul>
						</div>


						
						<div class="p-t-50">
							<h4 class="mtext-112 cl2 p-b-27">
								Tags
								{% if currentTag %}
									<span class="stext-109 cl6">(Filtered by: {{ currentTag.name }})</span>
								{% endif %}
							</h4>

							<div class="flex-w m-r--5">
								{% if currentTag %}
								<a href="{{ path('blog_index') }}" class="flex-c-m stext-107 cl2 size-301 bor7 p-lr-15 hov-tag1 trans-04 m-r-5 m-b-5">
									<i class="fa fa-times m-r-5"></i>Clear Filter
								</a>
								{% endif %}
								{% for tag in tags %}
								<a href="{{ path('blog_index') }}?tag={{ tag.slug }}{% if categorySlug %}&category={{ categorySlug }}{% endif %}{% if searchQuery %}&search={{ searchQuery }}{% endif %}" class="flex-c-m stext-107 {% if currentTag and currentTag.slug == tag.slug %}cl1{% else %}cl6{% endif %} size-301 bor7 p-lr-15 hov-tag1 trans-04 m-r-5 m-b-5">
									{{ tag.name }}
								</a>
								{% endfor %}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
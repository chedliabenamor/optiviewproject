{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - OptiView{% endblock %}

{% block body %}
<section class="bg-img1 txt-center p-lr-15 p-tb-92" style="background-image: url('{{ asset('assets/images/blog.jpg') }}');background-position: center top 40%;">
	<h2 class="ltext-105 cl0 txt-center">
		{{ post.title }}
	</h2>
</section>

<div class="container">
	<div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
		<a href="{{ path('app_home') }}" class="stext-109 cl8 hov-cl1 trans-04">
			Home
			<i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
		</a>

		<a href="{{ path('blog_index') }}" class="stext-109 cl8 hov-cl1 trans-04">
			Blog
			<i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
		</a>

		<span class="stext-109 cl4">
			{{ post.title }}
		</span>
	</div>
</div>

<!-- Content page -->
<section class="bg0 p-t-52 p-b-20">
	<div class="container">
		<div class="row">
			<div class="col-md-8 col-lg-9 p-b-80">
				<div class="p-r-45 p-r-0-lg">
					<!--  -->
					<div class="wrap-pic-w how-pos5-parent">
						{% if post.image %}
							<img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
						{% else %}
							<img src="{{ asset('assets/images/blog-04.jpg') }}" alt="{{ post.title }}">
						{% endif %}

						<div class="flex-col-c-m size-123 bg9 how-pos5">
							<span class="ltext-107 cl2 txt-center">
								{{ (post.date ?? post.createdAt)|date('d') }}
							</span>

							<span class="stext-109 cl3 txt-center">
								{{ (post.date ?? post.createdAt)|date('M Y') }}
							</span>
						</div>
					</div>

					<div class="p-t-32">
						<span class="flex-w flex-m stext-111 cl2 p-b-19">
							<span>
								<span class="cl4">By</span> {{ post.author.name ?? 'Admin' }} {{ post.author.lastname ?? '' }}
											<span class="cl12 m-l-4 m-r-6">|</span>
							</span>

							<span>
								{{ (post.date ?? post.createdAt)|date('d M, Y') }}
								<span class="cl12 m-l-4 m-r-6">|</span>
							</span>

							{% if post.category %}
							<span>
								{{ post.category.name }}
								{% if post.tags|length > 0 %}
									<span class="cl12 m-l-4 m-r-6">|</span>
								{% endif %}
							</span>
							{% endif %}

							{% if post.tags|length > 0 %}
							<span>
								{% for tag in post.tags %}
									{{ tag.name }}{% if not loop.last %}, {% endif %}
								{% endfor %}
							</span>
							{% endif %}
						</span>

						<h4 class="ltext-109 cl2 p-b-28">
							{{ post.title }}
						</h4>

						<div class="stext-117 cl6 p-b-26">
							{{ post.content|raw }}
						</div>
					</div>

					{% if post.tags|length > 0 %}
					<div class="flex-w flex-t p-t-16">
						<span class="size-216 stext-116 cl8 p-t-4">
							Tags
						</span>

						<div class="flex-w size-217">
							{% for tag in post.tags %}
							<a href="{{ path('blog_index', {'tag': tag.slug}) }}" class="flex-c-m stext-107 cl6 size-301 bor7 p-lr-15 hov-tag1 trans-04 m-r-5 m-b-5">
								{{ tag.name }}
							</a>
							{% endfor %}
						</div>
					</div>
					{% endif %}

					<!-- Comments -->
					<div class="p-t-40">
						<h5 class="mtext-113 cl2 p-b-12">
							Comments ({{ comments|length }})
						</h5>

						{% for comment in comments %}
						<div class="flex-w flex-t p-b-30">
							<div class="wrap-pic-s size-109 bor0 of-hidden m-r-18 m-t-6">
								<img src="{{ asset('assets/images/avatar-01.jpg') }}" alt="AVATAR">
							</div>

							<div class="size-207">
								<div class="flex-w flex-sb-m p-b-17">
									<span class="mtext-107 cl2 p-r-20">
										{{ comment.author.name }} {{ comment.author.lastname }}
									</span>

									<span class="fs-18 cl11">
										{{ comment.createdAt|date('M d, Y') }}
									</span>
								</div>

								<p class="stext-102 cl6">
									{{ comment.content }}
								</p>
							</div>
						</div>
						{% else %}
							<p class="stext-102 cl6 p-b-40">
								No comments yet. Be the first to comment!
							</p>
						{% endfor %}

						<!-- Add Comment Form -->
						<div class="p-t-40">
							<h5 class="mtext-113 cl2 p-b-12">
								Leave a Comment
							</h5>

							{% if app.user %}
								<p class="stext-107 cl6 p-b-40">
									Commenting as {{ app.user.name }} {{ app.user.lastname }}
								</p>

								{{ form_start(comment_form, {'action': path('blog_comment_add', {'slug': post.slug})}) }}
								<div class="bor19 m-b-20">
									{{ form_widget(comment_form.comment, {'attr': {'class': 'stext-111 cl2 plh3 size-124 p-lr-18 p-tb-15', 'placeholder': 'Your Comment...'}}) }}
									{{ form_errors(comment_form.comment) }}
								</div>

								<button type="submit" class="flex-c-m stext-101 cl0 size-125 bg3 bor2 hov-btn3 p-lr-15 trans-04">
									Post Comment
								</button>
								{{ form_end(comment_form) }}
							{% else %}
								<p class="stext-107 cl6 p-b-40">
									You must be <a href="{{ path('app_login') }}" class="cl1 hov-cl2">logged in</a> to post a comment.
								</p>
							{% endif %}
						</div>
					</div>
				</div>
			</div>

			<div class="col-md-4 col-lg-3 p-b-80">
				<div class="side-menu">
					<form method="GET" action="{{ path('blog_index') }}" class="bor17 of-hidden pos-relative">
						<input class="stext-103 cl2 plh4 size-116 p-l-28 p-r-55" type="text" name="search" placeholder="Search">

						<button type="submit" class="flex-c-m size-122 ab-t-r fs-18 cl4 hov-cl1 trans-04">
							<i class="zmdi zmdi-search"></i>
						</button>
					</form>

					<div class="p-t-55">
						<h4 class="mtext-112 cl2 p-b-33">
							Categories
						</h4>

						<ul>
							<li class="bor18">
								<a href="{{ path('blog_index') }}" class="dis-block stext-115 cl6 hov-cl1 trans-04 p-tb-8 p-lr-4">
									All Categories
								</a>
							</li>
							{% for category in categories %}
							<li class="bor18">
								<a href="{{ path('blog_index', {'category': category.slug}) }}" class="dis-block stext-115 cl6 hov-cl1 trans-04 p-tb-8 p-lr-4">
									{{ category.name }}
								</a>
							</li>
							{% endfor %}
						</ul>
					</div>

					<div class="p-t-50">
						<h4 class="mtext-112 cl2 p-b-27">
							Tags
						</h4>

						<div class="flex-w m-r--5">
							<a href="{{ path('blog_index') }}" class="flex-c-m stext-107 cl6 size-301 bor7 p-lr-15 hov-tag1 trans-04 m-r-5 m-b-5">
								All Posts
							</a>
							{% for tag in tags %}
							<a href="{{ path('blog_index', {'tag': tag.slug}) }}" class="flex-c-m stext-107 cl6 size-301 bor7 p-lr-15 hov-tag1 trans-04 m-r-5 m-b-5">
								{{ tag.name }}
							</a>
							{% endfor %}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
{% endblock %}
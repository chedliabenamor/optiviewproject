{# templates/admin/category_new_ajax.html.twig #}
{% form_theme form '@EasyAdmin/crud/form_theme.html.twig' %}

{{ form_start(form, { attr: { 'data-ea-form-id': form.vars.id } }) }}
    <div class="modal-body">
        {{ form_widget(form) }}
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">{{ ea_crud_form_submit_button_label|default('Save changes') }}</button>
    </div>
{{ form_end(form) }}

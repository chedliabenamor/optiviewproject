{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}
  Review #{{ entity.instance.id }}
{% endblock %}

{% block main %}
  {% set review = entity.instance %}
  {% set product = review.product %}
  {% set user = review.user %}
  {% set productImage = (product and product.overviewImage) 
    ? asset('uploads/products/' ~ product.overviewImage) 
    : asset('assets/images/placeholder-600x600.png') %}

  <div class="container-fluid">
    <div class="row g-4">
      <div class="col-lg-4">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex align-items-center">
              <img src="{{ productImage }}" alt="{{ product ? product.name : 'Product' }}" class="rounded me-3" style="width:84px;height:84px;object-fit:cover;">
              <div>
                <div class="fw-semibold small text-muted mb-1 mt-3">Product</div>
                <div class="h6 mb-1">{{ product ? product.name : 'N/A' }}</div>
                {% if product %}
                  <a class="btn  btn btn-primary" target="_blank"
                     href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) }}">
                    <i class="fas fa-eye me-1"></i> View Product
                  </a>
                {% endif %}
              </div>
            </div>
            <hr>
            <div class="d-flex align-items-center">
              <div class="fa-stack fa-2x me-3">
                <i class="fas fa-circle fa-stack-2x text-secondary"></i>
                <i class="fas fa-user fa-stack-1x fa-inverse"></i>
              </div>
              <div>
                <div class="fw-semibold small text-muted mb-1">Customer</div>
                <div class="h6 mb-1">{{ user ? user.name ~ ' ' ~ user.lastname : 'N/A' }}</div>
                <div class="small text-muted">{{ user ? user.email : '' }}</div>
                {% if user %}
                  <a class="btn btn-primary btn-sm mt-2" target="_blank"
                     href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('detail').setEntityId(user.id) }}">
                    <i class="fas fa-user me-1"></i> View Customer
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="card shadow-sm h-100">
          <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div class="h5 mb-0">Review Summary</div>
            <div>
              {% set badge = review.isApproved ? 'success' : 'warning' %}
              <span class="badge bg-{{ badge }} text-white">{{ review.isApproved ? 'Approved' : 'Awaiting Approval' }}</span>
            </div>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <div class="fw-semibold small text-muted">Rating</div>
              <div>
                {% set r = review.rating|default(0) %}
                {% for i in 1..5 %}
                  {% if i <= r %}
                    <i class="fas fa-star text-warning"></i>
                  {% else %}
                    <i class="far fa-star text-warning"></i>
                  {% endif %}
                {% endfor %}
                <span class="ms-2 text-muted">({{ r }}/5)</span>
              </div>
            </div>

            <div>
              <div class="fw-semibold small text-muted">Comment</div>
              <div class="p-3 border rounded bg-light">{{ review.comment|nl2br }}</div>
            </div>
          </div>
          <div class="card-footer d-flex justify-content-between small text-muted">
            <div>
              <i class="far fa-calendar me-1"></i> Created: {{ review.createdAt ? review.createdAt|date('Y-m-d H:i') : '—' }}
            </div>
            <div>
              <i class="far fa-clock me-1"></i> Last update: {{ review.updatedAt ? review.updatedAt|date('Y-m-d H:i') : '—' }}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4 d-flex gap-2">
      <a href="{{ ea_url().setAction('index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i> Back to list</a>
      <a href="{{ ea_url().setAction('edit').setEntityId(review.id) }}" class="btn btn-primary"><i class="fas fa-edit me-1"></i> Edit</a>
    </div>
  </div>
{% endblock %}

{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}{{ entity.instance.name }} - Category Details{% endblock %}

{% block main %}
     {{ include('@EasyAdmin/crud/includes/_delete_form.html.twig') }}

    <div class="card">
        <div class="card-header">
            <h4 class="card-title mb-0">Related Products</h4>
        </div>
        <div class="card-body">
            {% if entity.instance.products is not empty and entity.instance.products.count > 0 %}
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th style="width: 150px;">Actions</th> {# Adjusted width for buttons #}
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in entity.instance.products %}
                            <tr>
                                <td>{{ product.id }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) }}">
                                        {{ product.name }}
                                    </a>
                                </td>
                                <td>{{ product.price|format_currency('USD') }}</td> {# Ensure you have 'USD' or your desired currency #}
                                <td>{{ product.quantityInStock }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) }}" class="btn btn-sm btn-info me-1" title="Show"><i class="fas fa-eye"></i></a>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('edit').setEntityId(product.id) }}" class="btn btn-sm btn-primary me-1" title="Edit"><i class="fas fa-edit"></i></a>
                                    {# For delete, a form is safer for CSRF protection. This is a direct link for simplicity. #}
                                    {# Consider implementing a modal confirmation with a form POST for delete. #}
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('delete').setEntityId(product.id) }}"
                                       class="btn btn-sm btn-danger action-delete"
                                       title="Delete"
                                       data-bs-toggle="modal"
                                       data-bs-target="#modal-delete"
                                       data-ea-redirect-url="{{ ea_url().setController(ea.crud.controllerFqcn).setAction(ea.crud.currentAction).setEntityId(entity.instance.id) }}"
                                       data-ea-csrf-token="{{ csrf_token('ea-delete-App\\Entity\\Product-' ~ product.id) }}">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted">No products found for this category.</p>
            {% endif %}
        </div>
    </div>
{% endblock %}

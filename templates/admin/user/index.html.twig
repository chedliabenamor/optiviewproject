{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block content_header %}
    {{ parent() }}
    <div class="row mb-4" style="gap: 0.5rem;">
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Total Users</span>
                        <span class="bg-primary bg-opacity-10 rounded-circle p-2"><i class="fas fa-users text-primary"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ totalUsers|default(0) }}</div>
                    <div class="text-muted small">All registered users</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Active Users</span>
                        <span class="bg-success bg-opacity-10 rounded-circle p-2"><i class="fas fa-user-friends text-sucess"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ activeUsers|default(0) }} </div>
                    <div class="text-muted small">Currently active users</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Inactive Users</span>
                        <span class="bg-warning bg-opacity-10 rounded-circle p-2"><i class="fas fa-user-friends text-warning"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ inactiveUsers|default(0) }} </div>
                    <div class="text-muted small">Currently inactive users</div>
                </div>
            </div>
        </div>
    </div>
    <div class="custom-filters-wrapper" style="margin-top: 1.5rem;">
        <h2 style="margin-bottom: 1rem;">Search Filters</h2>
        <form method="get" class="mb-4 d-flex g-2" >
            <div class="mb-2">
                <select name="role" class="form-select">
                    <option value="">Select Role</option>
                    <option value="ROLE_ADMIN" {{ app.request.get('role') == 'ROLE_ADMIN' ? 'selected' : '' }}>Administrator</option>
                    <option value="ROLE_USER" {{ app.request.get('role') == 'ROLE_USER' ? 'selected' : '' }}>User</option>
                </select>
            </div>
            <div class="mb-2">
                <select name="active" class="form-select">
                    <option value="">Select Status</option>
                    <option value="1" {{ app.request.get('active') == '1' ? 'selected' : '' }}>Active</option>
                    <option value="0" {{ app.request.get('active') == '0' ? 'selected' : '' }}>Inactive</option>
                </select>
            </div>
            <div>
                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'role': null, 'active': null})) }}" class="btn btn-secondary">Reset</a>
            </div>
        </form>
    </div>
{% endblock %}

{% block table_head %}
    {% if batch_actions|length > 0 %}
        <th class="batch-actions-selector">
            <input type="checkbox" class="form-check-input form-batch-checkbox-all">
        </th>
    {% endif %}
    <th class="text-nowrap" data-column-property-name="name" data-column-sortable="true">
       
            USER
            
       
    </th>
    <th class="text-nowrap" data-column-property-name="roles" data-column-sortable="false">
        ROLE
    </th>
    <th class="text-nowrap" data-column-property-name="active" data-column-sortable="true">
        STATUS
    </th>
    <th class="text-nowrap actions-column text-right">
        <span>Actions</span>
    </th>
{% endblock %}

{% block table_body %}
    {% for entity in entities %}
        <tr data-id="{{ entity.primaryKeyValue }}">
            {% if batch_actions|length > 0 %}
                <td class="batch-actions-selector">
                    <input type="checkbox" class="form-check-input form-batch-checkbox" value="{{ entity.primaryKeyValue }}">
                </td>
            {% endif %}

            {% for field in entity.fields %}
                <td data-label="{{ field.label|trans(domain = 'EasyAdminBundle')|e('html_attr') }}" class="{{ field.cssClass }} text-{{ field.textAlign|default('left') }}">
                    {{ field.formattedValue|raw }}
                </td>
            {% endfor %}
            <td class="actions text-right actions-column">
                {% for action_dto in entity.actions %}
                    {{ include(action_dto.templatePath, {
                        'action': action_dto,
                        'entity': entity,
                        'ea': ea,
                        'trans_parameters': ea.i18n.translationParameters,
                        'translation_domain': ea.i18n.translationDomain
                    }, with_context = false) }}
                {% endfor %}
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="{{ entity_list_actions_count + (batch_actions|length > 0 ? 1 : 0) + fields|length }}" class="no-results">
                {{ 'crud.no_results_found'|trans(domain = 'EasyAdminBundle') }}
            </td>
        </tr>
    {% endfor %}
{% endblock %}


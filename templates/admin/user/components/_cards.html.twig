   <div class="row mb-4" style="gap: 0.5rem;">
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Total Users</span>
                        <span class="bg-primary bg-opacity-10 rounded-circle p-2"><i class="fas fa-users text-primary"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ totalUsers|default(0) }}</div>
                    <div class="text-muted small">All registered users</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Active Users</span>
                        <span class="bg-success bg-opacity-10 rounded-circle p-2"><i class="fas fa-user-friends text-sucess"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ activeUsers|default(0) }} </div>
                    <div class="text-muted small">Currently active users</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0" style="background: #f8f9fa;">
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 140px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted">Inactive Users</span>
                        <span class="bg-warning bg-opacity-10 rounded-circle p-2"><i class="fas fa-user-friends text-warning"></i></span>
                    </div>
                    <div class="fw-bold" style="font-size: 2rem;">{{ inactiveUsers|default(0) }} </div>
                    <div class="text-muted small">Currently inactive users</div>
                </div>
            </div>
        </div>
    </div>
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block main %}
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Comment Details</h4>
                        <a href="{{ ea_url().setController('App\\Controller\\Admin\\CommentCrudController').setAction('index') }}" class="btn btn-secondary">
                            <i class="fa fa-arrow-left"></i> Back to list
                        </a>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-2"><strong>Author:</strong></div>
                            <div class="col-md-10">
                                {% set user = entity.instance.author %}
                                {% if user %}
                                 {{ user.name }} {{ user.lastname }}
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('detail').setEntityId(user.id) }}">
                                       ( ({{ user.email }}))
                                    </a>
                                {% else %}
                                    <span class="text-muted">No author</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2"><strong>Post:</strong></div>
                            <div class="col-md-10">
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\PostCrudController').setAction('detail').setEntityId(entity.instance.post.id) }}">
                                    {{ entity.instance.post.title }}
                                </a>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2"><strong>Created At:</strong></div>
                            <div class="col-md-10">{{ entity.instance.createdAt|date('F j, Y, g:i a') }}</div>
                        </div>
                        <hr>
                        <div>
                            <h5>Content</h5>
                            <div class="py-3">
                                {{ entity.instance.content|raw }}
                            </div>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                         <a href="{{ ea_url().setController('App\\Controller\\Admin\\CommentCrudController').setAction('edit').setEntityId(entity.instance.id) }}" class="btn btn-primary">
                            <i class="fa fa-edit"></i> Edit
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

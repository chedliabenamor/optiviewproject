{# templates/admin/components/_paginated_products_table.html.twig #}
<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                <th>SKU</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th>Brand</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in pagination %}
                    <tr>
                        <td>{{ product.sku|default('N/A') }}</td>
                        <td>{{ product.name }}</td>
                        <td>
                            {% if product.price is not empty %}
                                €{{ product.price|number_format(2, '.', ',') }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if product.category is defined and product.category is not null %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('detail').setEntityId(product.category.id) }}">
                                    {{ product.category.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if product.brand is defined and product.brand is not null %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\BrandCrudController').setAction('detail').setEntityId(product.brand.id) }}">
                                    {{ product.brand.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="actions">
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) }}" class="btn btn-secondary me-1" title="Show"><i class="fa fa-eye"></i></a>
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('edit').setEntityId(product.id) }}" class="btn btn-primary me-1" title="Edit"><i class="fa fa-pen-to-square"></i></a>
                              
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">No associated products found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="navigation d-flex justify-content-center mt-3">
            {{ knp_pagination_render(pagination) }}
        </div>
    </div>
</div>

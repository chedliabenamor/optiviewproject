{# templates/admin/components/_product_variants_table.html.twig #}
<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                  
                    <th>SKU</th>
                    <th>Product</th>
                    <th>Color</th>
                    <th>Style</th>
                    <th>Genre</th>
                    <th>Price</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for variant in variants %}
                    <tr>
                       
                        <td>{{ variant.sku|default('N/A') }}</td>
                        <td>{{ variant.product.name|default('N/A') }}</td>
                        <td>
                            {% if variant.color is defined and variant.color is not null %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ColorCrudController').setAction('detail').setEntityId(variant.color.id) }}">
                                    {{ variant.color.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if variant.style is defined and variant.style is not null %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\StyleCrudController').setAction('detail').setEntityId(variant.style.id) }}">
                                    {{ variant.style.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if variant.genre is defined and variant.genre is not null %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\GenreCrudController').setAction('detail').setEntityId(variant.genre.id) }}">
                                    {{ variant.genre.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                        <td>
                            {% if variant.price is not empty %}
                                €{{ variant.price|number_format(2, '.', ',') }}
                            {% else %}
                                N/A
                            {% endif %}
                        </td>
                       
                        <td class="text-end">
                            <div class="actions">
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('detail').setEntityId(variant.id) }}" class="btn btn-secondary me-1" title="Show"><i class="fa fa-eye"></i></a>
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('edit').setEntityId(variant.id) }}" class="btn btn-primary me-1" title="Edit"><i class="fa fa-pen-to-square"></i></a>
                              
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center">No product variants associated.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

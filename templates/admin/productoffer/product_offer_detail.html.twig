{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %} Offer Details{% endblock %}

{% block main %}
    <div class="d-flex justify-content-end align-items-center mb-3">
       
        <div>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductOfferCrudController').setAction('edit').setEntityId(entity.instance.id) }}" class="btn btn-primary me-2">
                <i class="fa fa-pen-to-square"></i> Edit Offer
            </a>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductOfferCrudController').setAction('index') }}" class="btn btn-light">Back to list</a>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title mb-0">Offer: {{ entity.instance.name }}</h3>
        </div>
        <div class="card-body">
            <p><strong>Description:</strong> {{ entity.instance.description|raw }}</p>
                        <p><strong>Discount:</strong>
                {% if entity.instance.discountType == 'percentage' %}
                    {{ entity.instance.discountValue|number_format(2, '.', ',') }}%
                {% else %}
                    €{{ entity.instance.discountValue|number_format(2, '.', ',') }}
                {% endif %}
            </p>
            <p><strong>Start Date:</strong> {{ entity.instance.startDate ? entity.instance.startDate|date('Y-m-d H:i:s') : 'N/A' }}</p>
            <p><strong>End Date:</strong> {{ entity.instance.endDate ? entity.instance.endDate|date('Y-m-d H:i:s') : 'N/A' }}</p>
        </div>
    </div>

    <div class="mt-4">
        <h4>Associated Products</h4>
        {% include 'admin/components/_paginated_products_table.html.twig' with { 'pagination': pagination } %}
    </div>

    {% if entity.instance.products is empty and entity.instance.productVariants is empty %}
        <div class="alert alert-warning mt-4" role="alert">
            This offer is not associated with any specific products or variants.
        </div>
    {% endif %}
  <div class="mt-4">
        <h4>Associated Products variants</h4>
       {% include 'admin/components/_product_variants_table.html.twig' with { 'variants': entity.instance.productVariants } %}
    </div>
    <div class="row mt-4">
              <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-light text-dark">
                    <h5 class="mb-0 text-dark">Categories</h5>
                </div>
                <div class="card-body">
                    {% if entity.instance.categories|length > 0 %}
                       <div class="d-flex">
                            {% for category in entity.instance.categories %}
                               
                                    {% if category.id is defined and category.name is defined %}
                                        <a class="btn btn-primary me-1" href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('detail').setEntityId(category.id) }}">
                                            {{ category.name }}
                                        </a>
                                    {% else %}
                                        {{ category.name|default('N/A') }}
                                    {% endif %}
                               
                            {% endfor %}
                        </div>
                    {% else %}
                        <span class="text-muted">No categories associated.</span>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-light text-dark">
                    <h5 class="mb-0 text-dark">Brands</h5>
                </div>
                <div class="card-body">
                    {% if entity.instance.brands|length > 0 %}
                        <div class="d-flex">
                            {% for brand in entity.instance.brands %}
                               
                                    {% if brand.id is defined and brand.name is defined %}
                                        <a class="btn btn-primary me-1" href="{{ ea_url().setController('App\\Controller\\Admin\\BrandCrudController').setAction('detail').setEntityId(brand.id) }}">
                                            {{ brand.name }}
                                        </a>
                                    {% else %}
                                        {{ brand.name|default('N/A') }}
                                    {% endif %}
                               
                            {% endfor %}
                        </div>
                    {% else %}
                        <span class="text-muted">No brands associated.</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

{% endblock %}

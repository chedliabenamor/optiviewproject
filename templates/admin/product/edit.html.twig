{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    {# You can use the 'entity' variable to access the Product entity being edited #}
    Edit Product '{{ entity.instance.name }}'
{% endblock %}

{% block main %}
    {# The 'edit_form' variable holds the form for the Product entity #}
    {{ form_start(edit_form) }}
    {{ form_widget(edit_form) }}

    <div class="form-group mt-3">
        <button type="button" class="btn btn-secondary" id="add-category-btn">
            <i class="fas fa-plus"></i> Add New Category
        </button>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary">Save changes</button>
    </div>
    {{ form_end(edit_form) }}
{% endblock %}

{# Include the centralized modal and JS logic #}
{% block body_end_content %}
    {{ parent() }}
    {{ include('admin/product/_category_modal_logic.html.twig') }}
{% endblock %}

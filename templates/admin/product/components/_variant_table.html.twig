{# Paginated and filterable variant table for product detail page #}
<div class="table-responsive overflow-hidden">
    {% set form_prefix = is_archived ? 'filters_archived' : 'filters_active' %}
{% set current_filters = is_archived ? filters_archived : filters_active %}
{% set form_action_url = ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) %}
{# other_tab_params was unused and caused errors due to InputBag::get default typing; removed. #}
{% set reset_url = ea_url()
    .setController('App\\Controller\\Admin\\ProductCrudController')
    .setAction('detail')
    .set('entityId', product.id)
    .set('active_tab', is_archived ? 'archived' : 'active') %}

<form action="{{ form_action_url }}" method="get" class="mb-4 p-3 border rounded bg-light" id="variant-filters-form">
    <input type="hidden" name="active_tab" value="{{ is_archived ? 'archived' : 'active' }}" id="active-tab-input">

    {# Preserve pagination of the other tab #}
    {% if is_archived %}
        <input type="hidden" name="page_active" value="{{ app.request.query.get('page_active', 1) }}">
        {# Also preserve the other tab's filters #}
        {% set preserved_active = app.request.query.all('filters_active') %}
        {% for key, value in preserved_active %}
            <input type="hidden" name="filters_active[{{ key }}]" value="{{ value }}">
        {% endfor %}
    {% else %}
        <input type="hidden" name="page_archived" value="{{ app.request.query.get('page_archived', 1) }}">
        {% set preserved_archived = app.request.query.all('filters_archived') %}
        {% for key, value in preserved_archived %}
            <input type="hidden" name="filters_archived[{{ key }}]" value="{{ value }}">
        {% endfor %}
    {% endif %}

    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="{{ form_prefix }}_sku" class="form-label">SKU</label>
            <input type="text" class="form-control" name="{{ form_prefix }}[sku]" id="{{ form_prefix }}_sku" value="{{ current_filters.sku|default('') }}">
        </div>
        <div class="col-md-3">
            <label for="{{ form_prefix }}_color" class="form-label">Color</label>
            <select class="form-select" name="{{ form_prefix }}[color]" id="{{ form_prefix }}_color">
                <option value="">All</option>
                {% for color in available_colors %}
                    <option value="{{ color.name }}" {% if current_filters.color|default('') == color.name %}selected{% endif %}>{{ color.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-3">
            <label for="{{ form_prefix }}_stock" class="form-label">Stock Status</label>
            <select class="form-select" name="{{ form_prefix }}[stock]" id="{{ form_prefix }}_stock">
                <option value="">All</option>
                <option value="in" {% if current_filters.stock|default('') == 'in' %}selected{% endif %}>In Stock</option>
                <option value="low" {% if current_filters.stock|default('') == 'low' %}selected{% endif %}>Low Stock</option>
                <option value="out" {% if current_filters.stock|default('') == 'out' %}selected{% endif %}>Out of Stock</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
            <a href="#" id="reset-filters-{{ form_prefix }}" class="btn btn-secondary w-100 mt-2">Reset</a>
        </div>
    </div>
</form>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th class="text-center">Image</th>
                <th class="text-center">SKU</th>
                <th class="text-center">Color</th>
                <th class="text-center">Price</th>
                <th class="text-center">Stock</th>
                <th class="text-center">Stock Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for variant in variants %}
                <tr>
                    <td class="text-center">
                        {% set firstImage = variant.productVariantImages|first %}
                        {% if firstImage %}
                            <a href="#" data-bs-toggle="modal" data-bs-target="#imageModal-{{ variant.id }}">
                                <img src="{{ vich_uploader_asset(firstImage, 'imageFile') }}" alt="{{ variant.sku }}" style="max-width: 50px; max-height: 50px;">
                            </a>

                            <!-- Modal -->
                            <div class="modal fade" id="imageModal-{{ variant.id }}" tabindex="-1" aria-labelledby="imageModalLabel-{{ variant.id }}" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="imageModalLabel-{{ variant.id }}">{{ variant.sku }}</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body text-center">
                                            <img src="{{ vich_uploader_asset(firstImage, 'imageFile') }}" alt="{{ variant.sku }}" class="img-fluid">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="img-fluid rounded bg-light d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; border: 1px dashed #ccc; margin: 0 auto">
                                <i class="fas fa-image"></i>
                            </div>
                        {% endif %}
                    </td>
                    <td class="text-center">{{ variant.sku }}</td>
                    <td class="text-center">{{ variant.color ?: 'N/A' }}</td>
                    <td class="text-center">{{ variant.price is not null ? (variant.price|number_format(2, '.', ',') ~ ' €') : 'N/A' }}</td>
                    <td class="text-center">{{ variant.stock }}</td>
                    <td class="text-center">
                        {% set stock = variant.stock %}
                        {% if stock is not null %}
                            {% if stock == 0 %}
                                <span class="badge bg-danger text-white">Out of Stock</span>
                            {% elseif stock > 0 and stock <= 10 %}
                                <span class="badge bg-warning text-dark">Low Stock</span>
                            {% else %}
                                <span class="badge bg-success text-white">In Stock</span>
                            {% endif %}
                        {% else %}
                            <span class="badge bg-secondary text-white">Unknown</span>
                        {% endif %}
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm" role="group">
                                                        <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('detail').setEntityId(variant.id) }}" class="btn btn-secondary"><i class="fas fa-eye"></i></a>
                            <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('edit').setEntityId(variant.id) }}" class="btn btn-primary"><i class="fas fa-edit"></i></a>
                            {% if is_archived %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('restoreVariant').setEntityId(variant.id) }}" class="btn btn-success"><i class="fas fa-undo"></i></a>
                            {% else %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('archiveVariant').setEntityId(variant.id) }}" class="btn btn-warning"><i class="fas fa-archive"></i></a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center">No variants found.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{# Pagination #}
{% if totalPages > 1 %}
    <nav>
        <ul class="pagination justify-content-center">
            {% set page_param = is_archived ? 'page_archived' : 'page_active' %}
            {% for page in 1..totalPages %}
                <li class="page-item {% if page == currentPage %}active{% endif %}">
                    <a class="page-link" href="{{ path(app.request.attributes.get('_route'), app.request.query.all()|merge({ (page_param): page, 'entityId': product.id })) }}">{{ page }}</a>
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endif %}
<script>
function handleVariantTabs() {
    const urlParams = new URLSearchParams(window.location.search);
    let activeTab = urlParams.get('active_tab') || 'active';
    
    // Update the hidden input value
    const activeTabInput = document.getElementById('active-tab-input');
    if (activeTabInput) {
        activeTabInput.value = activeTab;
    }
    
    // Show the correct tab
    const tabId = activeTab === 'archived' ? 'archived-tab' : 'active-tab';
    const tabElement = document.getElementById(tabId);
    
    if (tabElement) {
        // Update tab navigation
        document.querySelectorAll('.nav-link').forEach(link => {
            link.classList.remove('active');
            link.setAttribute('aria-selected', 'false');
        });
        
        tabElement.classList.add('active');
        tabElement.setAttribute('aria-selected', 'true');
        
        // Show the corresponding tab content
        const tabContentId = activeTab === 'archived' ? 'archived-variants' : 'active-variants';
        document.querySelectorAll('.tab-pane').forEach(pane => {
            pane.classList.remove('show', 'active');
        });
        const activePane = document.getElementById(tabContentId);
        if (activePane) {
            activePane.classList.add('show', 'active');
        }
    }
}

// Run the tab handler when the DOM is fully loaded
document.addEventListener('DOMContentLoaded', () => {
    handleVariantTabs();
    
    // Handle reset filters button for the current tab
    const formPrefix = '{{ form_prefix }}';
    const resetButton = document.getElementById(`reset-filters-${formPrefix}`);

    if (resetButton) {
        resetButton.addEventListener('click', (e) => {
            e.preventDefault();

            // Construct a simple URL with the current query params, plus the reset flag.
            // The backend controller will handle clearing the correct filters.
            const currentUrl = new URL(window.location.href);
            currentUrl.searchParams.set('reset', 'true');
            
            // The 'active_tab' parameter is already in the form, so it will be submitted.
            // We just need to ensure we redirect to a URL that triggers the backend logic.
            window.location.href = currentUrl.toString();
        });
    }
});
</script>
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}
    Product Details: {{ product.name }}
{% endblock %}

{% block main %}
    {# Top Buttons: Edit and Back to List #}
    <div class="d-flex justify-content-end mb-3">
        <a href="{{ ea_url().setController(ea.crud.controllerFqcn).setAction('edit').setEntityId(product.id) }}" class="btn btn-primary">
            <i class="fa fa-fw fa-edit"></i> Edit Product
        </a>
        <a href="{{ ea_url().setController(ea.crud.controllerFqcn).setAction('index') }}" class="btn btn-secondary ms-2">
            Back to list
        </a>
    </div>

    {# Product Information Card #}
    <div class="card">
        <div class="card-body">
         
            <div class="row">
                <div class="col-md-4">
    {# Combine main product image and additional images into one list #}
    {% set all_images = [] %}
    {% if product.overviewImage %}
        {% set main_image = { 'id': 'main_' ~ product.id, 'path': asset('uploads/products/' ~ product.overviewImage) } %}
        {% set all_images = all_images|merge([main_image]) %}
    {% endif %}
    {% for p_image in product.productModelImages %}
        {% set model_image = { 'id': p_image.id, 'path': vich_uploader_asset(p_image, 'imageFile') } %}
        {% set all_images = all_images|merge([model_image]) %}
    {% endfor %}

    {% if all_images is not empty %}
        <div id="productImageCarousel" class="carousel slide carousel-dark" data-bs-ride="carousel">
            <div class="carousel-indicators">
                {% for i, image_data in all_images %}
                    <button type="button" data-bs-target="#productImageCarousel" data-bs-slide-to="{{ i }}" class="{{ i == 0 ? 'active' : '' }}" aria-current="{{ i == 0 ? 'true' : 'false' }}" aria-label="Slide {{ i + 1 }}"></button>
                {% endfor %}
            </div>
            <div class="carousel-inner">
                {% for i, image_data in all_images %}
                    <div class="carousel-item {{ i == 0 ? 'active' : '' }}">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#imageGalleryModal" data-bs-slide-to="{{ i }}">
                            <img src="{{ image_data.path }}" class="d-block w-100 rounded" alt="Product Image {{ i + 1 }}" style="max-height: 400px; object-fit: contain;">
                        </a>
                    </div>
                {% endfor %}
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#productImageCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#productImageCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>

        <!-- Modal with Carousel -->
<div class="modal fade" id="imageGalleryModal" tabindex="-1" aria-labelledby="imageGalleryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imageGalleryModalLabel">Product Gallery</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="modalCarousel" class="carousel slide carousel-dark" data-bs-ride="false">
                    <div class="carousel-inner">
                        {% for i, image_data in all_images %}
                            <div class="carousel-item {% if i == 0 %}active{% endif %}">
                                <img src="{{ image_data.path }}" class="d-block w-100" alt="Product Image {{ i + 1 }}" style="max-height: 70vh; object-fit: contain;">
                            </div>
                        {% endfor %}
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#modalCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#modalCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
    {% else %}
        <div class="card">
            <div class="card-body text-center bg-light d-flex align-items-center justify-content-center" style="height: 300px; border: 1px dashed #ccc;">
                <i class="fas fa-image fa-3x text-muted"></i>
            </div>
        </div>
    {% endif %}
</div>
                <div class="col-md-8">
                    <h4>Product Information</h4>
                    <dl class="row">
                        <dt class="col-sm-3">Price</dt>
                        <dd class="col-sm-9">{{ product.price ? ((product.currency == 'EUR' ? '€' : product.currency) ~ product.price|number_format(2, '.', '')) : 'N/A' }}</dd>

                        <dt class="col-sm-3">SKU</dt>
                        <dd class="col-sm-9">{{ product.sku }}</dd>

                        <dt class="col-sm-3">Stock</dt>
                        <dd class="col-sm-9">{{ product.quantityInStock }} piece(s)</dd>

                        {# <dt class="col-sm-3">Active Variants</dt>
                        <dd class="col-sm-9">{{ total_active }}</dd>

                        <dt class="col-sm-3">Archived Variants</dt>
                        <dd class="col-sm-9">{{ total_archived }}</dd> #}

                        <dt class="col-sm-3">Loyalty Points</dt>
                        <dd class="col-sm-9">{{ product.loyaltyPoints }} points</dd>

                        {% if product.style %}
                            <dt class="col-sm-3">Style</dt>
                            <dd class="col-sm-9">{{ product.style.name }}</dd>
                        {% endif %}

                        {% if product.category %}
                            <dt class="col-sm-3">Category</dt>
                            <dd class="col-sm-9"><a href="{{ ea_url().setController('App\\Controller\\Admin\\CategoryCrudController').setAction('detail').setEntityId(product.category.id) }}">{{ product.category.name }}</a></dd>
                        {% endif %}

                        {% if product.brand %}
                            <dt class="col-sm-3">Brand</dt>
                            <dd class="col-sm-9"><a href="{{ ea_url().setController('App\\Controller\\Admin\\BrandCrudController').setAction('detail').setEntityId(product.brand.id) }}">{{ product.brand.name }}</a></dd>
                        {% endif %}

                        <dt class="col-sm-3">Colors</dt>
                        <dd class="col-sm-9">
                            {% for color in product.colors %}
                                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ColorCrudController').setAction('detail').setEntityId(color.id) }}" class="btn btn-sm btn-primary me-1 mb-1">{{ color.name }}</a>
                            {% else %}
                                <span>No specific colors assigned.</span>
                            {% endfor %}
                        </dd>
                    </dl>

                    {% if product.description %}
                        <hr>
                        <h4>Description</h4>
                        <p>{{ product.description|raw }}</p>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>

    {# Product Variants Card with Tabs #}
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <ul class="nav nav-tabs card-header-tabs" id="variant-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="active-tab" data-bs-toggle="tab" data-bs-target="#active-variants" type="button" role="tab" aria-controls="active-variants" aria-selected="true">
                        <i class="fas fa-box me-1"></i> Active Variants ({{ total_active }})
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="archived-tab" data-bs-toggle="tab" data-bs-target="#archived-variants" type="button" role="tab" aria-controls="archived-variants" aria-selected="false">
                        <i class="fas fa-archive me-1"></i> Archived Variants ({{ total_archived }})
                    </button>
                </li>
            </ul>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('edit').setEntityId(product.id) }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Add Variant
            </a>
        </div>
        <div class="card-body">
            <div class="tab-content" id="variant-tabs-content">
                <div class="tab-pane fade show active" id="active-variants" role="tabpanel" aria-labelledby="active-tab">
                    {% include 'admin/product/components/_variant_table.html.twig' with {
                        'variants': active_variants,
                        'totalPages': pages_active,
                        'currentPage': current_page_active,
                        'is_archived': false,
                        'product': product,
                        'filters': filters_active
                    } %}
                </div>
                <div class="tab-pane fade" id="archived-variants" role="tabpanel" aria-labelledby="archived-tab">
                    {% include 'admin/product/components/_variant_table.html.twig' with {
                        'variants': archived_variants,
                        'totalPages': pages_archived,
                        'currentPage': current_page_archived,
                        'is_archived': true,
                        'product': product,
                        'filters': filters_archived
                    } %}
                </div>
            </div>
        </div>
    </div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const imageGalleryModalEl = document.getElementById('imageGalleryModal');
    if (imageGalleryModalEl) {
        const modalCarousel = new bootstrap.Carousel(imageGalleryModalEl.querySelector('#modalCarousel'), {
            interval: false // Disable auto-sliding
        });

        imageGalleryModalEl.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            if (button) {
                const slideToIndex = parseInt(button.getAttribute('data-bs-slide-to'), 10);
                if (!isNaN(slideToIndex)) {
                    modalCarousel.to(slideToIndex);
                }
            }
        });
    }
});
</script>
{% endblock %}

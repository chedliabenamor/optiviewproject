{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}
    Variant Details: {{ entity.instance.sku ?: entity.instance.color ?: ('#' ~ entity.instance.id) }}
{% endblock %}

{% block main %}
    {% set variant = entity.instance %}
    {% set images = variant.productVariantImages %}

    {# Top Buttons: Edit and Back to Product #}
    <div class="d-flex justify-content-end mb-3">
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductVariantCrudController').setAction('edit').setEntityId(variant.id) }}" class="btn btn-primary">
            <i class="fa fa-fw fa-edit"></i> Edit Product Variant
        </a>
        {% if variant.product %}
        <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(variant.product.id) }}" class="btn btn-secondary ms-2">
            <i class="fa fa-fw fa-arrow-left"></i> Back to Product
        </a>
        {% endif %}
    </div>

    <div class="card">
        <div class="card-body">
            <h3 class="card-title mb-4">
                Variant: {{ variant.sku ?: variant.color ?: ('#' ~ variant.id) }}
                {% if variant.product %}
                    <small class="text-muted">(for Product: <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(variant.product.id) }}">{{ variant.product.name }}</a>)</small>
                {% endif %}
            </h3>

            <div class="row">
                <!-- Image Carousel Column -->
                <div class="col-lg-5 mb-4">
                    {% if images is not empty %}
                        <div id="variantImageCarousel" class="carousel slide carousel-dark" data-bs-ride="carousel">
                            <div class="carousel-indicators">
                                {% for i in 0..images|length - 1 %}
                                    <button type="button" data-bs-target="#variantImageCarousel" data-bs-slide-to="{{ i }}" class="{{ i == 0 ? 'active' : '' }}" aria-current="{{ i == 0 ? 'true' : 'false' }}" aria-label="Slide {{ i + 1 }}"></button>
                                {% endfor %}
                            </div>
                            <div class="carousel-inner">
                                {% for image in images %}
                                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                        <a href="#" data-bs-toggle="modal" data-bs-target="#imageGalleryModal" data-bs-slide-to="{{ loop.index0 }}">
                                            <img src="{{ vich_uploader_asset(image, 'imageFile') }}" 
                                                 class="d-block w-100 rounded" 
                                                 alt="Variant Image {{ loop.index }}"
                                                 style="max-height: 400px; object-fit: contain;">
                                        </a>
                                    </div>
                                {% endfor %}
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#variantImageCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#variantImageCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>
                    {% else %}
                        <div class="text-center text-muted border rounded p-5">
                            <i class="fas fa-image fa-3x"></i>
                            <p class="mt-2">No images for this variant.</p>
                        </div>
                    {% endif %}
                </div>

                <!-- Variant Information Column -->
                <div class="col-lg-7">
                    <h4>Variant Information</h4>
                    <dl class="row">
                        <dt class="col-sm-3">SKU</dt>
                        <dd class="col-sm-9"><span class="font-monospace">{{ variant.sku ?: 'N/A' }}</span></dd>

                        <dt class="col-sm-3">Price</dt>
                        <dd class="col-sm-9">
                            {% if variant.price is not null %}
                                {{ '€' ~ (variant.price|number_format(2, '.', '')) }}
                            {% else %}
                                N/A
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Stock</dt>
                        <dd class="col-sm-9">{{ variant.stock }} piece(s)</dd>

                        <dt class="col-sm-3">Stock Status</dt>
                        <dd class="col-sm-9">
                            {% set ss = variant.stockStatus %}
                            {% if ss == 'Out of Stock' %}
                                <span class="badge bg-danger">Out of Stock</span>
                            {% elseif ss == 'Low Stock' %}
                                <span class="badge bg-warning text-dark">Low Stock</span>
                            {% elseif ss == 'In Stock' %}
                                <span class="badge bg-success">In Stock</span>
                            {% else %}
                                <span class="badge bg-secondary">Unknown</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            {% if variant.isActive %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-danger">Inactive</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Color</dt>
                        <dd class="col-sm-9">
                            {% if variant.color %}
                                <a class="btn btn-sm btn-primary me-1 mb-1" href="{{ ea_url().setController('App\\Controller\\Admin\\ColorCrudController').setAction('detail').setEntityId(variant.color.id) }}">
                                    {{ variant.color.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Style</dt>
                        <dd class="col-sm-9">
                            {% if variant.style %}
                                <a class="btn btn-sm btn-primary me-1 mb-1" href="{{ ea_url().setController('App\\Controller\\Admin\\StyleCrudController').setAction('detail').setEntityId(variant.style.id) }}">
                                    {{ variant.style.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </dd>

                        <dt class="col-sm-3">Genre</dt>
                        <dd class="col-sm-9">
                            {% if variant.genre %}
                                <a class="btn btn-sm btn-primary me-1 mb-1" href="{{ ea_url().setController('App\\Controller\\Admin\\GenreCrudController').setAction('detail').setEntityId(variant.genre.id) }}">
                                    {{ variant.genre.name }}
                                </a>
                            {% else %}
                                N/A
                            {% endif %}
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Image Gallery -->
    <div class="modal fade" id="imageGalleryModal" tabindex="-1" aria-labelledby="imageGalleryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="imageGalleryModalLabel">Image Gallery</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    {% if images is not empty %}
                        <div id="modalCarousel" class="carousel slide carousel-dark" data-bs-ride="false">
                            <div class="carousel-inner">
                                {% for image in images %}
                                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                        <img src="{{ vich_uploader_asset(image, 'imageFile') }}" 
                                             class="d-block w-100" 
                                             alt="Variant Image {{ loop.index }}"
                                             style="max-height: 70vh; object-fit: contain;">
                                    </div>
                                {% endfor %}
                            </div>
                            <button class="carousel-control-prev" type="button" data-bs-target="#modalCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#modalCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const imageGalleryModal = document.getElementById('imageGalleryModal');
        if (imageGalleryModal) {
            imageGalleryModal.addEventListener('show.bs.modal', function(event) {
                const button = event.relatedTarget;
                const slideTo = button.getAttribute('data-bs-slide-to');
                const carousel = imageGalleryModal.querySelector('.carousel');
                if (carousel && slideTo !== null) {
                    const bsCarousel = new bootstrap.Carousel(carousel, {interval: false});
                    bsCarousel.to(slideTo);
                }
            });
        }
    });
    </script>
{% endblock %}

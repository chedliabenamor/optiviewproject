{% extends '@EasyAdmin/page/content.html.twig' %}

{# Print-only styling: hide all non-essential UI when printing #}
{% block head_stylesheets %}
    {{ parent() }}
    <style>
      @media print {
        /* Hide EasyAdmin chrome and action areas */
        header, nav, .navbar, .sidebar, .ea-sidebar, .content-header .page-actions, .global-actions, .search-wrapper,
        .no-print, .btn, .action-buttons, .form-actions { display: none !important; }
        /* Hide last Actions column (marked with .no-print) */
        th.no-print, td.no-print { display: none !important; }
        /* Optimize layout */
        body { background: #fff !important; }
        .content { margin: 0 !important; padding: 0 !important; }
        a[href]:after { content: '' !important; } /* don't print URLs */
      }
    </style>
{% endblock %}

{# ✅ Page title #}
{% block page_title %}
    {% set status_badge_class = {
        'pending': 'bg-warning',
        'processing': 'bg-info',
        'shipped': 'bg-primary',
        'delivered': 'bg-success',
        'cancelled': 'bg-danger',
    }[entity.instance.status] ?? 'bg-secondary' %}
    Order Details #{{ entity.instance.id }} <span class="badge text-white {{ status_badge_class }}">{{ entity.instance.status|capitalize }}</span>
{% endblock %}

{# ✅ Page actions #}
{% block page_actions %}
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\OrderCrudController').setAction('edit').setEntityId(entity.instance.id) }}" class="btn btn-primary no-print">
        <i class="fas fa-edit"></i> Edit Order
    </a>
    <a href="{{ ea_url().setController('App\\Controller\\Admin\\OrderCrudController').setAction('index') }}" class="btn btn-secondary no-print">
        <i class="fas fa-arrow-left"></i> Back to list
    </a>
    <button type="button" class="btn btn-secondary no-print" onclick="window.print()">
        <i class="fas fa-print"></i> Print Order
    </button>
{% endblock %}

{# ✅ Main content #}
{% block main %}
    <div class="row mb-4">
        {# Customer Details #}
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><h5 class="card-title">Customer Details</h5></div>
                <div class="card-body">
                    {% if entity.instance.user %}
                        <p><strong>Name:</strong> {{ entity.instance.user.name }} {{ entity.instance.user.lastname }}</p>
                        <p><strong>Email:</strong> {{ entity.instance.user.email }}</p>
                        <p><strong>Phone:</strong> {{ entity.instance.user.phone|default('N/A') }}</p>
                        <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('detail').setEntityId(entity.instance.user.id) }}"
                           class="btn btn-sm btn-primary no-print" target="_blank">
                            <i class="fas fa-user"></i> View Customer
                        </a>
                    {% else %}
                        <p>No customer associated.</p>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card  h-100">
                <div class="card-header"><h5 class="card-title">Shipping Address</h5></div>
                <div class="card-body">
                    <p>{{ entity.instance.shippingAddress|nl2br }}</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header"><h5 class="card-title">Billing Address</h5></div>
                <div class="card-body">
                    <p>{{ entity.instance.billingAddress|nl2br }}</p>
                </div>
            </div>
        </div>
             
        
    </div>

        {# Payment & Status #}
       <div class="col-md-12">
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="card-title mb-0">Payment & Status</h5>
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Currency:</div>
                <div class="col-sm-8">{{ entity.instance.currency|default('EUR') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Total Amount:</div>
                <div class="col-sm-8 text-danger">
                    {{ (entity.instance.getSubtotal() + entity.instance.getTaxAmount() + entity.instance.getShippingFee())|format_currency(entity.instance.currency|default('EUR')) }}
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Subtotal:</div>
                <div class="col-sm-8">{{ entity.instance.getSubtotal()|format_currency(entity.instance.currency|default('EUR')) }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Tax Amount (7%):</div>
                <div class="col-sm-8">{{ entity.instance.getTaxAmount()|format_currency(entity.instance.currency|default('EUR')) }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Shipping Fee:</div>
                <div class="col-sm-8">{{ entity.instance.getShippingFee()|format_currency(entity.instance.currency|default('EUR')) }}</div>
            </div>

            <hr>

            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Shipping Provider:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.shippingProvider|default('N/A') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-6 fw-semibold">Delivery Type:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.deliveryType|default('N/A') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-6 fw-semibold">Destination:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.destination|default('N/A') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Total Points Earned:</div>
                <div class="col-sm-8">{{ entity.instance.totalPointsEarned }} point(s)</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Payment Method:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.paymentMethod|capitalize|default('N/A') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Payment Status:</div>
                <div class="col-sm-8">
                    <span class="badge bg-info text-dark">
                        {{ entity.instance.paymentStatus|default('N/A')|capitalize }}
                    </span>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Transaction ID:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.transactionId|default('N/A') }}</div>
            </div>
            <div class="row mb-2">
                <div class="col-sm-4 fw-semibold">Tracking Number:</div>
                <div class="col-sm-8 text-muted">{{ entity.instance.trackingNumber|default('N/A') }}</div>
            </div>
            {% if entity.instance.notes %}
                <hr>
                <div class="row mb-2">
                    <div class="col-sm-4 fw-semibold">Notes:</div>
                    <div class="col-sm-8">{{ entity.instance.notes|nl2br }}</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
 

   
   

    {# Order Items Table with Image and Links #}
    <div class="card mt-4">
        <div class="card-header">
            <h5 class="card-title">Order Items</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-center" >Unit Price</th>
                        <th class="text-center">Subtotal</th>
                        <th class="text-center">Tax Amount (7%)</th>
                        <th class="text-center">Total</th>
                        <th class="text-center">Points</th>
                        <th class="no-print">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in entity.instance.orderItems %}
                        <tr>
                            <td>
                                {% if item.productVariant %}
                                    {# Prefer the first variant image via getter; fallback to product overview #}
                                    {% set variantImageUrl = item.productVariant.getFirstImageUrl() %}
                                    {% if variantImageUrl %}
                                        <a href="#" class="image-popup-trigger" data-image-url="{{ asset(variantImageUrl) }}">
                                            <img src="{{ asset(variantImageUrl) }}" alt="{{ item.productVariant }}" style="width:50px;height:50px;object-fit:cover;border-radius:4px;">
                                        </a>
                                    {% else %}
                                        {% set product = item.productVariant.product ?? null %}
                                        {% if product and product.overviewImage %}
                                            <a href="#" class="image-popup-trigger" data-image-url="{{ asset('uploads/products/' ~ product.overviewImage) }}">
                                                <img src="{{ asset('uploads/products/' ~ product.overviewImage) }}" alt="{{ product.name }}" style="width:50px;height:50px;object-fit:cover;border-radius:4px;">
                                            </a>
                                        {% else %}
                                            <span class="text-muted">No image</span>
                                        {% endif %}
                                    {% endif %}
                                {% else %}
                                    {% set product = item.product ?: null %}
                                    {% if product and product.overviewImage %}
                                        <a href="#" class="image-popup-trigger" data-image-url="{{ asset('uploads/products/' ~ product.overviewImage) }}">
                                            <img src="{{ asset('uploads/products/' ~ product.overviewImage) }}" alt="{{ product.name }}" style="width:50px;height:50px;object-fit:cover;border-radius:4px;">
                                        </a>
                                    {% else %}
                                        <span class="text-muted">No image</span>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td>{{ item.productVariant ?: 'Product not available' }}</td>
                            <td class="text-center" >{{ item.quantity }}</td>
                            <td class="text-center" >{{ item.unitPrice|format_currency(entity.instance.currency|default('EUR')) }}</td>
                            <td class="text-center">{{ (item.quantity * item.unitPrice)|format_currency(entity.instance.currency|default('EUR')) }}</td>
                            <td class="text-center">{{ item.getVatAmount()|format_currency(entity.instance.currency|default('EUR')) }}</td>
                            <td class="text-center">{{ item.getTotalWithVat()|format_currency(entity.instance.currency|default('EUR')) }}</td>
                            <td class="text-center">{{ item.pointsEarned }} point(s)</td>
                            <td class="no-print">
                                {% if item.productVariant and item.productVariant.product %}
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(item.productVariant.product.id) }}"
                                       class="btn btn-secondary btn-sm no-print" target="_blank">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('edit').setEntityId(item.productVariant.product.id) }}"
                                       class="btn btn-primary btn-sm no-print" target="_blank">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center">No items in this order.</td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="7" class="text-end pe-3"><strong>Subtotal:</strong></td>
                        <td class="text-end"><strong>{{ entity.instance.getSubtotal()|format_currency(entity.instance.currency|default('EUR')) }}</strong></td>
                    </tr>
                    <tr>
                        <td colspan="7" class="text-end pe-3"><strong>Tax Amount (7%):</strong></td>
                        <td class="text-end"><strong>{{ entity.instance.getTaxAmount()|format_currency(entity.instance.currency|default('EUR')) }}</strong></td>
                    </tr>
                    <tr>
                        <td colspan="7" class="text-end pe-3"><strong>Shipping Fee:</strong></td>
                        <td class="text-end"><strong>{{ entity.instance.getShippingFee()|format_currency(entity.instance.currency|default('EUR')) }}</strong></td>
                    </tr>
                    <tr>
                        <td colspan="7" class="text-end pe-3"><strong>Total:</strong></td>
                        <td class="text-end"><strong>{{ (entity.instance.getSubtotal() + entity.instance.getTaxAmount() + entity.instance.getShippingFee())|format_currency(entity.instance.currency|default('EUR')) }}</strong></td>
                    </tr>
                    <tr>
                        <td colspan="7" class="text-end pe-3"><strong>Total Points Earned:</strong></td>
                        <td class="text-end"><strong>{{ entity.instance.totalPointsEarned }} point(s)</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    {# Image Modal #}
    <div class="modal fade" id="image-popup-modal" tabindex="-1" aria-labelledby="image-popup-modal-label" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-body text-center">
                    <img src="" id="popup-image" class="img-fluid" alt="Product Image">
                </div>
            </div>
        </div>
    </div>


{% endblock %}

{# ✅ JS for popup #}
{% block body_javascript %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalElement = document.getElementById('image-popup-modal');
            const popupImage = document.getElementById('popup-image');
            const imagePopupModal = new bootstrap.Modal(modalElement);

            document.querySelectorAll('.image-popup-trigger').forEach(trigger => {
                trigger.addEventListener('click', function (e) {
                    e.preventDefault();
                    popupImage.src = this.dataset.imageUrl;
                    imagePopupModal.show();
                });
            });
        });
    </script>
{% endblock %}

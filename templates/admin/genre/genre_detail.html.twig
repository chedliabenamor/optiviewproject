{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}{{ entity.instance.name }} - Genre Details{% endblock %}

{% block main %}
    {{ include('@EasyAdmin/crud/includes/_delete_form.html.twig') }}
   

    <div class="card">
        <div class="card-header">
            <h4 class="card-title mb-0">Products in Genre: {{ entity.instance.name }}</h4>
        </div>
        <div class="card-body">
            {% if active_products is not empty and active_products|length > 0 %}
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in active_products %}
                            <tr>
                                <td>{{ product.id }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\Controller\Admin\ProductCrudController').setAction('detail').setEntityId(product.id) }}">
                                        {{ product.name }}
                                    </a>
                                </td>
                                <td>{{ product.price|format_currency('EUR') }}</td>
                                <td>{{ product.quantityInStock }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\Controller\Admin\ProductCrudController').setAction('detail').setEntityId(product.id) }}" class="btn btn-sm btn-info me-1" title="Show"><i class="fas fa-eye"></i></a>
                                    <a href="{{ ea_url().setController('App\Controller\Admin\ProductCrudController').setAction('edit').setEntityId(product.id) }}" class="btn btn-sm btn-primary me-1" title="Edit"><i class="fas fa-edit"></i></a>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('archiveProduct').setEntityId(product.id) }}"
                                       class="btn btn-sm btn-warning me-1" title="Archive">
                                       <i class="fas fa-archive"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted">No products found in this genre.</p>
            {% endif %}
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header">
            <h4 class="card-title mb-0">Archived Products</h4>
        </div>
        <div class="card-body">
            {% if archived_products is not empty and archived_products|length > 0 %}
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in archived_products %}
                            <tr>
                                <td>{{ product.id }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('detail').setEntityId(product.id) }}">
                                        {{ product.name }}
                                    </a>
                                </td>
                                <td>{{ product.price|format_currency('EUR') }}</td>
                                <td>{{ product.quantityInStock }}</td>
                                <td>
                                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ProductCrudController').setAction('restoreProduct').setEntityId(product.id) }}" class="btn btn-sm btn-success me-1" title="Restore"><i class="fas fa-undo"></i> Restore</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-muted">No archived products for this genre.</p>
            {% endif %}
        </div>
    </div>
{% endblock %}

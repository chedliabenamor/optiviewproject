{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}{{ entity.instance.name }} - Product Offer Details{% endblock %}

{% block main %}
    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title mb-0">Offer: {{ entity.instance.name }}</h3>
        </div>
        <div class="card-body">
            <p><strong>Description:</strong> {{ entity.instance.description|raw }}</p>
            <p><strong>Discount Price:</strong> {{ entity.instance.discountPrice|format_currency('USD') }}</p>
            <p><strong>Start Date:</strong> {{ entity.instance.startDate ? entity.instance.startDate|date('Y-m-d H:i:s') : 'N/A' }}</p>
            <p><strong>End Date:</strong> {{ entity.instance.endDate ? entity.instance.endDate|date('Y-m-d H:i:s') : 'N/A' }}</p>
        </div>
    </div>

    {% if entity.instance.product %}
        {% set product = entity.instance.product %}
        <div class="card">
            <div class="card-header">
                <h4 class="card-title mb-0">Associated Product</h4>
            </div>
            <div class="card-body">
                <p><strong>Product Name:</strong> 
                    <a href="{{ ea_url().setController('App\Controller\Admin\ProductCrudController').setAction('detail').setEntityId(product.id) }}">
                        {{ product.name }}
                    </a>
                </p>
                <p><strong>Original Price:</strong> {{ product.price|format_currency('USD') }}</p>
                <p><strong>Current Stock:</strong> {{ product.quantityInStock }}</p>
                {# Add more product details as needed #}
            </div>
            <div class="card-footer">
                <a href="{{ ea_url().setController('App\Controller\Admin\ProductCrudController').setAction('edit').setEntityId(product.id) }}" class="btn btn-sm btn-primary me-1" title="Edit Product"><i class="fas fa-edit"></i> Edit Product</a>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning" role="alert">
            No product associated with this offer.
        </div>
    {% endif %}
{% endblock %}

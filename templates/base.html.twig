<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no">
    <title>{% block title %}Welcome OptiView{% endblock %}</title>
    
    <!-- Include Jeeliz VTO Widget Script -->
    <script src="{{ asset('assets/jeeliz/dist/JeelizVTOWidget.js') }}"></script>
    
    <!-- Icons for adjust/resize buttons -->
    <script defer src="https://use.fontawesome.com/releases/v5.0.6/js/all.js"></script>
    
    <!-- Jeeliz VTO Widget CSS -->
    {# <link rel="stylesheet" href="{{ asset('assets/jeeliz/css/JeelizVTOWidget.css') }}"> #}
    
    <!-- Your existing favicon and styles -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    <link rel="icon" type="image/png" href="{{ asset('assets/images/icons/favicon.png') }}">
    
    <link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/animate/animate.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/css-hamburgers/hamburgers.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/animsition/css/animsition.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/select2/select2.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/daterangepicker/daterangepicker.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/slick/slick.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/MagnificPopup/magnific-popup.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/perfect-scrollbar/perfect-scrollbar.css') }}">
    
    <link rel="stylesheet" href="{{ asset('assets/fonts/font-awesome-4.7.0/css/font-awesome.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/fonts/iconic/css/material-design-iconic-font.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/fonts/linearicons-v1.0.0/icon-font.min.css') }}">
    
    <link rel="stylesheet" href="{{ asset('assets/css/util.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
    
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    
    <script>window.isAuthenticated = {{ app.user ? 'true' : 'false' }};</script>
</head>
<body class="animsition">

    <!-- Jeeliz VTO Widget Container - Using same structure as official example -->
    <div id="JeelizVTOWidget" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; background-color: rgba(0,0,0,0.8);">
        <!-- Main Canvas - Must have position: absolute -->
        <canvas id="JeelizVTOWidgetCanvas" style="position: absolute;"></canvas>
        
        <!-- Top Controls -->
        <div class="JeelizVTOWidgetControls JeelizVTOWidgetControlsTop">
            <!-- Adjust Button -->
            <button id="JeelizVTOWidgetAdjust">
                <div class="buttonIcon"><i class="fas fa-arrows-alt"></i></div>Adjust
            </button>

            <!-- Close Button -->
            <button id="JeelizVTOWidgetClose" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">
                <div class="buttonIcon"><i class="fas fa-times"></i></div>Close
            </button>
        </div>

        <!-- Change Model Buttons -->
        <div class="JeelizVTOWidgetControls" id="JeelizVTOWidgetChangeModelContainer">
            <!-- You can add model switching buttons here if needed -->
        </div>

        <!-- Adjust Notice -->
        <div id="JeelizVTOWidgetAdjustNotice">
            Move the glasses to adjust them.
            <button class="JeelizVTOWidgetBottomButton" id="JeelizVTOWidgetAdjustExit">Quit</button>
        </div>

        <!-- Loading Widget -->
        <div id="JeelizVTOWidgetLoading">
            <div class="JeelizVTOWidgetLoadingText">
                LOADING VIRTUAL TRY-ON...
            </div>
        </div>
    </div>

    {% include 'partials/_header.html.twig' %}
    {% include 'partials/_wishlist_cart_panel.html.twig' %}
    
    <main class="main-content">
        {% block body %}{% endblock %}
    </main>
    
    {% include 'partials/_footer.html.twig' %}
    
    <!-- Back to top button -->
    <div class="btn-back-to-top" id="myBtn">
        <span class="symbol-btn-back-to-top">
            <i class="zmdi zmdi-chevron-up"></i>
        </span>
    </div>
    
    <!-- Vendor JS -->
    <script src="{{ asset('assets/vendor/jquery/jquery-3.2.1.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/animsition/js/animsition.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/bootstrap/js/popper.js') }}"></script>
    <script src="{{ asset('assets/vendor/bootstrap/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/select2/select2.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/daterangepicker/moment.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/daterangepicker/daterangepicker.js') }}"></script>
    <script src="{{ asset('assets/vendor/slick/slick.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/parallax100/parallax100.js') }}"></script>
    <script src="{{ asset('assets/vendor/MagnificPopup/jquery.magnific-popup.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/isotope/isotope.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/vendor/sweetalert/sweetalert.min.js') }}"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="{{ asset('assets/vendor/perfect-scrollbar/perfect-scrollbar.min.js') }}"></script>
    
    <!-- Custom JS -->
    <script src="{{ asset('assets/js/slick-custom.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>
    <script src="{{ asset('assets/js/wishlist-cart-panel.js') }}"></script>
    <script src="{{ asset('assets/js/currency.js') }}"></script>
    <script src="{{ asset('assets/js/quick-view.js') }}"></script>
    
    <!-- Quick View Modal -->
    {% include 'partials/products/_quick_view_modal.html.twig' %}
    
    <!-- Initialize plugins -->
    <script>
        $(document).ready(function() {
            // Parallax
            $('.parallax100').parallax100();
            
            // Magnific Popup
            $('.gallery-lb').each(function() {
                $(this).magnificPopup({
                    delegate: 'a',
                    type: 'image',
                    gallery: { enabled:true },
                    mainClass: 'mfp-fade'
                });
            });
            
            // Perfect Scrollbar
            $('.js-pscroll').each(function(){
                $(this).css({'position':'relative', 'overflow':'hidden'});
                var ps = new PerfectScrollbar(this, {
                    wheelSpeed: 1,
                    wheelPropagation: false,
                });
                $(window).on('resize', function(){ ps.update(); });
            });
        });
    </script>

    <!-- Jeeliz VTO Widget Integration - Following official example pattern -->
    <script>
        // Global variable to track current overlay
        let currentOverlayUrl = null;

        // Main VTO initialization function
        function startVTOWidget(overlayUrl) {
            if (!overlayUrl) {
                console.error('No overlay URL provided');
                return;
            }

            currentOverlayUrl = overlayUrl;
            const widgetContainer = document.getElementById('JeelizVTOWidget');
            
            if (!widgetContainer) {
                console.error('VTO Widget container not found');
                return;
            }

            // Show the widget container
            widgetContainer.style.display = 'block';

            // Start the VTO widget
            JEELIZVTOWIDGET.start({
                isShadow: true,
                // Remove the sku parameter since we're loading a custom model
                searchImageMask: '{{ asset('assets/jeeliz/dist/glasses3.png') }}',
                searchImageColor: 0xeeeeee,
                callbackReady: function(){
                    console.log('INFO: JEELIZVTOWIDGET is ready :)');
                    
                    // First, load a basic model (this is required)
                    JEELIZVTOWIDGET.load_modelStandalone('{{ asset('assets/jeeliz/models/glasses1.obj') }}')
                        .then(() => {
                            console.log('Base model loaded');
                            // Then load the custom overlay
                            if (overlayUrl) {
                                return JEELIZVTOWIDGET.load_texture(overlayUrl);
                            }
                        })
                        .then(() => {
                            console.log('Overlay texture loaded');
                        })
                        .catch((error) => {
                            console.error('Error loading model or texture:', error);
                            closeVTOWidget();
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Could not load the 3D model. Please try again later.'
                            });
                        });
                },
                onError: function(errorLabel){
                    console.error('VTO Widget Error:', errorLabel);
                    closeVTOWidget();
                    
                    let errorMessage = 'An error occurred with the Virtual Try-On.';
                    if (errorLabel === 'WEBCAM_UNAVAILABLE') {
                        errorMessage = 'Could not access your webcam. Please check your permissions.';
                    } else if (errorLabel === 'NO_CORS') {
                        errorMessage = 'CORS error. Please make sure the model files are served with the correct CORS headers.';
                    }
                    
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: errorMessage
                    });
                }
            });
        }

        // Close VTO widget
        function closeVTOWidget() {
            const widgetContainer = document.getElementById('JeelizVTOWidget');
            if (widgetContainer) {
                widgetContainer.style.display = 'none';
            }
            
            if (typeof JEELIZVTOWIDGET !== 'undefined' && JEELIZVTOWIDGET.stop) {
                JEELIZVTOWIDGET.stop();
            }
            
            currentOverlayUrl = null;
        }

        // Initialize when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            // Set up close button
            const closeBtn = document.getElementById('JeelizVTOWidgetClose');
            if (closeBtn) {
                closeBtn.addEventListener('click', closeVTOWidget);
            }

            // Global handler for starting VTO
            document.addEventListener('tryon:start', function(e) {
                if (e.detail && e.detail.overlayUrl) {
                    startVTOWidget(e.detail.overlayUrl);
                }
            });

            // Click handler for Try On buttons
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.js-tryon, .js-tryon-card');
                if (!btn) return;

                e.preventDefault();
                let overlayUrl = btn.getAttribute('data-overlay');
                
                // Ensure the URL is properly encoded
                if (overlayUrl) {
                    try {
                        overlayUrl = new URL(overlayUrl, window.location.origin).href;
                    } catch (e) {
                        console.error('Invalid overlay URL:', e);
                        overlayUrl = null;
                    }
                }

                if (!overlayUrl) {
                    Swal.fire({
                        icon: 'info',
                        title: 'Not Available',
                        text: 'Virtual Try-On is not available for this item.'
                    });
                    return;
                }

                // Start the VTO experience
                startVTOWidget(overlayUrl);
            });
        });

        // Handle page unload
        window.addEventListener('beforeunload', function() {
            if (typeof JEELIZVTOWIDGET !== 'undefined' && JEELIZVTOWIDGET.stop) {
                JEELIZVTOWIDGET.stop();
            }
        });
    </script>
    
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
            //         slidesToShow: 1,
            //         slidesToScroll: 1,
            //         arrows: true,
            //         fade: true,
            //         asNavFor: '.wrap-slick3-dots',
            //         speed: 600,
            //         customPaging: function(slider, i) {
            //             return '<div class="slick3-dot" data-role="none"></div>';
            //         },
            //         responsive: [
            //             {
            //                 breakpoint: 1200,
            //                 settings: {
            //                     slidesToShow: 1,
            //                     slidesToScroll: 1,
            //                     infinite: true,

    <style>
        .flash-messages-container {
            position: relative;
            z-index: 1000;
            padding: 0;
            margin: 0;
        }
        .flash-message {
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            border: none;
            margin-bottom: 10px;
            font-size: 14px;
            font-weight: 500;
            animation: slideDown 0.3s ease-out;
        }
        .flash-message .btn-close {
            background: none;
            border: none;
            font-size: 20px;
            font-weight: bold;
            opacity: 0.7;
            cursor: pointer;
            padding: 0;
            margin-left: 10px;
        }
        .flash-message .btn-close:hover {
            opacity: 1;
        }
        .flash-message i {
            margin-right: 8px;
        }
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        /* Ensure flash messages appear above other content */
        .alert-success { background-color: #d4edda; border-color: #c3e6cb; color: #155724; }
        .alert-warning { background-color: #fff3cd; border-color: #ffeaa7; color: #856404; }
        .alert-danger { background-color: #f8d7da; border-color: #f5c6cb; color: #721c24; }
        .alert-info { background-color: #d1ecf1; border-color: #bee5eb; color: #0c5460; }
    </style>

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    
    <script>
        window.isAuthenticated = {{ app.user ? 'true' : 'false' }};
        {% if app.user %}
            window.currentUserId = {{ app.user.id }};
        {% else %}
            window.currentUserId = null;
        {% endif %}
        
        // Clear merge flags when user logs out or when different user logs in
        var lastUserId = sessionStorage.getItem('last_user_id');
        if (!window.isAuthenticated || (window.currentUserId && lastUserId && lastUserId !== String(window.currentUserId))) {
            sessionStorage.removeItem('cart_merged');
            sessionStorage.removeItem('wishlist_merged');
        }
        
        // Store current user ID for next page load
        if (window.currentUserId) {
            sessionStorage.setItem('last_user_id', String(window.currentUserId));
        } else {
            sessionStorage.removeItem('last_user_id');
        }
        
        // Force merge check on every page load for authenticated users
        document.addEventListener('DOMContentLoaded', function() {
            if (window.isAuthenticated) {
                console.log('User is authenticated, attempting merge in 200ms...');
                // Small delay to ensure wishlist-cart-panel.js is loaded
                setTimeout(function() {
                    console.log('Checking for merge functions...');
                    if (typeof window.mergeGuestCartIfNeeded === 'function') {
                        console.log('Calling mergeGuestCartIfNeeded from base template');
                        window.mergeGuestCartIfNeeded();
                    } else {
                        console.log('mergeGuestCartIfNeeded function not found');
                    }
                    if (typeof window.mergeGuestWishlistIfNeeded === 'function') {
                        console.log('Calling mergeGuestWishlistIfNeeded from base template');
                        window.mergeGuestWishlistIfNeeded();
                    } else {
                        console.log('mergeGuestWishlistIfNeeded function not found');
                    }
                }, 200);
            } else {
                console.log('User is not authenticated, skipping merge');
            }
        });
    </script>
</head>
<body class="animsition">

    <!-- FaceMesh VTO Modal -->
    <div id="FaceMeshVTOModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 9999; display: none; justify-content: center; align-items: center; flex-direction: column;">
        <div style="position: relative; width: 90%; max-width: 800px; height: 80%; background: #000; border-radius: 12px; overflow: hidden;">
            <video id="FaceMeshVideo" autoplay playsinline style="width: 100%; height: 100%; object-fit: contain;"></video>
            <canvas id="FaceMeshCanvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; mix-blend-mode: multiply; pointer-events: none;"></canvas>
            
            <!-- Loading indicator -->
            <div id="VTOLoading" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: white; text-align: center; z-index: 5;">
                <div style="margin-bottom: 20px;">Loading Virtual Try-On...</div>
                <div class="spinner"></div>
            </div>
            
            <!-- Error message -->
            <div id="VTOError" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: white; text-align: center; z-index: 5; display: none;">
                <div style="margin-bottom: 20px; font-size: 18px;" id="VTOErrorMessage">Failed to start camera</div>
                <button class="retry-btn" style="background: #4cc9f0; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer;">Retry</button>
            </div>
        </div>
        
        <!-- Controls -->
        <div style="margin-top: 20px; display: flex; gap: 15px; align-items: center; justify-content: center;">
            <button id="VTOClose" class="vto-control-btn" style="background: #e74c3c; color: white; border: none; padding: 12px 25px; border-radius: 8px; cursor: pointer; font-weight: bold;">
                Close
            </button>
        </div>
    </div>

    {% include 'partials/_header.html.twig' %}
    {% include 'partials/_wishlist_cart_panel.html.twig' %}
    
    {# Global flash messages - positioned prominently after header #}
    {% set flashes = app.flashes %}
    {% if flashes|length > 0 %}
        <div class="flash-messages-container" style="position: relative; z-index: 1000; background: transparent;">
            <div class="container-fluid">
                <div class="container">
                    {% for label, messages in flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : (label == 'success' ? 'success' : 'info')) }} alert-dismissible fade show mt-3 mx-auto flash-message" role="alert" style="max-width: 800px; position: relative; z-index: 1001;">
                                <i class="fa fa-{{ label == 'success' ? 'check-circle' : (label == 'warning' ? 'exclamation-triangle' : (label == 'danger' ? 'times-circle' : 'info-circle')) }} me-2"></i>
                                {{ message }}
                                <button type="button" class="btn-close" aria-label="Close" onclick="this.parentElement.style.display='none'">&times;</button>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        {# Debug: Show when no flash messages are present #}
        <script>console.log('No flash messages in template');</script>
    {% endif %}
    
    <main class="main-content">
        {% block body %}{% endblock %}
    </main>
    
    {% include 'partials/_footer.html.twig' %}
    
    <!-- Back to top button -->
    <div class="btn-back-to-top" id="myBtn">
        <span class="symbol-btn-back-to-top">
            <i class="zmdi zmdi-chevron-up"></i>
        </span>
    </div>
    
    <!-- Vendor JS -->
    <script src="{{ asset('assets/vendor/jquery/jquery-3.2.1.min.js') }}"></script>
    <!-- Prevent jQuery 'unload' listeners (Permissions-Policy), map to pagehide -->
    <script>
        (function(){
            if (window.jQuery && jQuery.event && jQuery.event.special) {
                jQuery.event.special.unload = {
                    setup: function() { return false; },
                    teardown: function() {}
                };
            }
            if (window.jQuery && jQuery.fn && jQuery.fn.on) {
                var _on = jQuery.fn.on;
                jQuery.fn.on = function(types){
                    if (typeof types === 'string' && types.indexOf('unload') !== -1) {
                        types = types.replace(/\bunload\b/g, 'pagehide');
                        arguments[0] = types;
                    }
                    return _on.apply(this, arguments);
                };
            }
            // Remap native addEventListener('unload', ...) to 'pagehide'
            try {
                var _origAdd = EventTarget.prototype.addEventListener;
                EventTarget.prototype.addEventListener = function(type, listener, options){
                    if (type === 'unload') type = 'pagehide';
                    return _origAdd.call(this, type, listener, options);
                };
            } catch(e) { /* ignore */ }
        })();
    </script>

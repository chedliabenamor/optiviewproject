    <!-- Global currency formatting for product cards -->
    <script>
    (function(){
        function formatCardPrices(){
            if (!window.Currency) return;
            document.querySelectorAll('.js-card-price').forEach(function(el){
                var eur = parseFloat(el.getAttribute('data-price-eur') || '');
                if (!isNaN(eur)) {
                    el.textContent = window.Currency.format(eur);
                }
            });
            document.querySelectorAll('.js-card-original').forEach(function(el){
                var eur = parseFloat(el.getAttribute('data-original-eur') || '');
                if (!isNaN(eur)) {
                    el.textContent = window.Currency.format(eur);
                }
            });
        }
        document.addEventListener('DOMContentLoaded', formatCardPrices);
        document.addEventListener('currencyChanged', formatCardPrices);
    })();
    </script>

    <!-- Format free shipping threshold text -->
    <script>
    (function(){
        function formatFreeShipping(){
            if (!window.Currency) return;
            document.querySelectorAll('.js-free-ship-amt').forEach(function(el){
                var eur = parseFloat(el.getAttribute('data-amount-eur') || '');
                if (!isNaN(eur)) {
                    el.textContent = window.Currency.format(eur);
                }
            });
        }
        document.addEventListener('DOMContentLoaded', function(){ setTimeout(formatFreeShipping, 100); });
        document.addEventListener('currencyChanged', formatFreeShipping);
    })();
    </script>

    <!-- Merge guest wishlist into user account on login -->
    <script>
    document.addEventListener('DOMContentLoaded', function(){
        // Highlight active currency in header / set selects
        try {
            var cur = (window.Currency && window.Currency.current) || 'EUR';
            // Legacy button support (if any remain)
            var legacyBtns = document.querySelectorAll('.js-currency-option');
            if (legacyBtns.length) {
                legacyBtns.forEach(function(el){
                    if (String(el.getAttribute('data-currency')) === cur) { el.classList.add('active'); } else { el.classList.remove('active'); }
                    el.addEventListener('click', function(e){
                        e.preventDefault();
                        var sel = el.getAttribute('data-currency');
                        if (window.Currency && (sel === 'EUR' || sel === 'USD')) {
                            window.Currency.set(sel);
                            legacyBtns.forEach(function(o){ if (o.getAttribute('data-currency') === sel) { o.classList.add('active'); } else { o.classList.remove('active'); } });
                        }
                    });
                });
            }
            // New <select> controls
            document.querySelectorAll('.js-currency-select').forEach(function(sel){
                try { sel.value = cur; } catch(e){}
                sel.addEventListener('change', function(){
                    var val = sel.value;
                    if (window.Currency && (val === 'EUR' || val === 'USD')) {
                        window.Currency.set(val);
                    }
                });
            });
        } catch(e){}

        var isAuth = (typeof window.isAuthenticated !== 'undefined') && (window.isAuthenticated === true || window.isAuthenticated === 'true');
        if (!isAuth) return;
        try {
            var local = localStorage.getItem('wishlist');
            var items = local ? JSON.parse(local) : [];
            if (!Array.isArray(items) || items.length === 0) return;
            // Build minimal payload {id, variantId}
            var payload = { items: items.map(function(it){ return { id: it.id, variantId: (it.variantId || null) }; }) };
            fetch('/api/wishlist/merge', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(payload)
            })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (d && d.success) {
                    try { localStorage.removeItem('wishlist'); } catch(e){}
                    // Update header count and broadcast refresh
                    try {
                        var cnt = Array.isArray(d.items) ? d.items.length : 0;
                        document.querySelectorAll('.icon-header-noti').forEach(function(icon){
                            if (icon.querySelector('.zmdi-favorite-outline') || icon.querySelector('.zmdi-favorite')) {
                                icon.setAttribute('data-notify', cnt);
                            }
                        });
                        document.dispatchEvent(new CustomEvent('wishlistUpdated'));
                    } catch(e){}
                }
            }).catch(function(){});
        } catch(e){}
    });
    </script>
    

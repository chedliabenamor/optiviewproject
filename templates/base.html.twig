    <!-- Custom JS -->
    <script src="{{ asset('assets/js/slick-custom.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>
    <script src="{{ asset('assets/js/wishlist-cart-panel.js') }}"></script>
    <script src="{{ asset('assets/js/currency.js') }}"></script>
    <script src="{{ asset('assets/js/quick-view.js') }}"></script>
    
    <!-- Quick View Modal -->
    {% include 'partials/products/_quick_view_modal.html.twig' %}
    
    <!-- Initialize plugins -->
    <script>
        $(document).ready(function() {
            // Parallax
            $('.parallax100').parallax100();
            
            // Magnific Popup
            $('.gallery-lb').each(function() {
                $(this).magnificPopup({
                    delegate: 'a',
                    type: 'image',
                    gallery: { enabled:true },
                    mainClass: 'mfp-fade'
                });
            });
            
            // Perfect Scrollbar
            $('.js-pscroll').each(function(){
                $(this).css({'position':'relative', 'overflow':'hidden'});
                var ps = new PerfectScrollbar(this, {
                    wheelSpeed: 1,
                    wheelPropagation: false,
                });
                $(window).on('resize', function(){ ps.update(); });
            });
        });
        
        // Global flash message functionality
        $(document).ready(function() {
            // Debug: Log flash message count
            var flashCount = $('.flash-message').length;
            console.log('Flash messages found:', flashCount);
            if (flashCount > 0) {
                $('.flash-message').each(function(index) {
                    console.log('Flash message ' + (index + 1) + ':', $(this).text().trim());
                });
            }
            
            // Auto-dismiss success messages after 5 seconds
            $('.alert-success.flash-message').each(function() {
                var alert = $(this);
                console.log('Setting auto-dismiss for success message:', alert.text().trim());
                setTimeout(function() {
                    alert.fadeOut(500, function() {
                        alert.remove();
                    });
                }, 5000);
            });
            
            // Manual close functionality
            $('.flash-message .btn-close').click(function() {
                console.log('Manually closing flash message');
                $(this).closest('.alert').fadeOut(300, function() {
                    $(this).remove();
                });
            });
        });
    </script>

  

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>

     {% extends 'base.html.twig' %}

{% block title %}My cart - {{ parent() }}{% endblock %}
     {% block body %}
	<div class="container">
		<div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
			<a href="index.html" class="stext-109 cl8 hov-cl1 trans-04">
				Home
				<i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
			</a>

			<span class="stext-109 cl4">
				Shoping Cart
			</span>
		</div>
	</div>
		

	<!-- Shoping Cart -->
	<form class="bg0 p-t-75 p-b-85">
		<div class="container">
			<div class="row">
				<div class="col-lg-10 col-xl-10 m-lr-auto m-b-50">
					<div class="m-l-25 m-r--38 m-lr-0-xl">
						<div class="wrap-table-shopping-cart">
							<table class="table-shopping-cart">
								<tr class="table_head">
									<th class="column-1">Product</th>
									<th class="column-2"></th>
									<th class="column-3">Price</th>
									<th class="column-4">Quantity</th>
									<th class="column-5">Total</th>
								</tr>
								<tbody id="cart-table-body">
								</tbody>
							</table>
						</div>

						<div class="flex-w flex-sb-m bor15 p-t-18 p-b-15 p-lr-40 p-lr-15-sm">
                    
                            <div class="flex-w flex-t bor12 p-b-13">
                            <div class="">
                                <span class="stext-110 cl2">
                                    Subtotal:
                                </span>
                            </div>

                            <div class="">
                                <span class="mtext-110 cl2" id="cart-subtotal">€0.00</span>
                            </div>
                        </div>

                        

                        <div class="flex-w flex-m p-t-20">
                            <a href="{{ path('app_checkout') }}" class="flex-c-m stext-101 cl0 size-116 bg3 bor14 hov-btn3 p-lr-15 trans-04 pointer">
                                Proceed to Checkout
                            </a>
                        </div>
                        </div>
					</div>
				</div>

			
			</div>
		</div>
	</form>
    <script>
    document.addEventListener('DOMContentLoaded', function(){
        function isAuth(){ return (typeof window.isAuthenticated !== 'undefined') && (window.isAuthenticated === true || window.isAuthenticated === 'true'); }
        function formatCurrency(num){ var n=parseFloat(num); if (window.Currency && typeof window.Currency.format==='function') return window.Currency.format(n); return isNaN(n)?'€0.00':'€'+n.toFixed(2); }
        function getGuestCart(){ try { var raw=localStorage.getItem('cart')||'[]'; var arr=JSON.parse(raw); return Array.isArray(arr)?arr:[]; } catch(e){ return []; } }
        function normalizeServerCart(cart){ try { var items=Array.isArray(cart.items)?cart.items:[]; return items.map(function(it){ return { id: it.productId, variantId: it.variantId||'', name: it.name, variantName: it.variantName||'', image: it.image||'', price: (typeof it.unitPrice==='number'?it.unitPrice:parseFloat(it.unitPrice||0)||0), quantity: (typeof it.quantity==='number'?it.quantity:parseInt(it.quantity||1,10)) }; }); } catch(e){ return []; } }

        var tbody = document.getElementById('cart-table-body');
        var subEl = document.getElementById('cart-subtotal');
        var totalEl = document.getElementById('cart-total');
        var _lastItems = [];

        function render(items){
            if (!tbody) return;
            tbody.innerHTML='';
            var subtotal=0;
            _lastItems = Array.isArray(items) ? items.slice() : [];
            items.forEach(function(ci){
                var price = parseFloat(ci.price||0)||0; var qty = parseInt(ci.quantity||1,10)||1; var line = price*qty; subtotal += line;
                var tr = document.createElement('tr'); tr.className='table_row';
                tr.innerHTML = '\n'
                    + '                    <td class="column-1"><div class="how-itemcart1">'+(ci.image?('<img src="'+ci.image+'" alt="'+(ci.name||'')+'">'):'')+'</div></td>\n'
                    + '                    <td class="column-2">\n'
                    + '                        <div >\n'
                    + '                           <span>'+ (ci.name||'') + (ci.variantName?(' <small class="stext-110 cl2">('+ci.variantName+')</small>'):'') +'</span>\n'
                    + '                           <button class="cartp-remove stext-110 cl2" data-product-id="'+ci.id+'" data-variant-id="'+(ci.variantId||'')+'" title="Remove"><i class="zmdi zmdi-delete" style="color:#e74c3c"></i></button>\n'
                    + '                        </div>\n'
                    + '                    </td>\n'
                    + '                    <td class="column-3">'+ formatCurrency(price) +'</td>\n'
                    + '                    <td class="column-4">\n'
                    + '                        <div class="wrap-num-product flex-w m-l-auto m-r-0">\n'
                    + '                            <button class="btn-num-product-down cl8 hov-btn3 trans-04 flex-c-m cartp-qty-dec" data-product-id="'+ci.id+'" data-variant-id="'+(ci.variantId||'')+'"><i class="fs-16 zmdi zmdi-minus"></i></button>\n'
                    + '                            <input class="mtext-104 cl3 txt-center num-product" type="number" value="'+qty+'" min="0" data-product-id="'+ci.id+'" data-variant-id="'+(ci.variantId||'')+'">\n'
                    + '                            <button class="btn-num-product-up cl8 hov-btn3 trans-04 flex-c-m cartp-qty-inc" data-product-id="'+ci.id+'" data-variant-id="'+(ci.variantId||'')+'"><i class="fs-16 zmdi zmdi-plus"></i></button>\n'
                    + '                        </div>\n'
                    + '                    </td>\n'
                    + '                    <td class="column-5">'+ formatCurrency(line) +'</td>';
                tbody.appendChild(tr);
            });
            if (subEl) subEl.textContent = formatCurrency(subtotal);
            if (totalEl) totalEl.textContent = formatCurrency(subtotal);
        }

        function load(){
            if (isAuth()) {
                fetch('/api/cart').then(function(r){ return r.ok?r.json():Promise.reject(); }).then(function(cart){ render(normalizeServerCart(cart)); }).catch(function(){ render([]); });
            } else {
                render(getGuestCart());
            }
        }

        // Re-render when currency changes
        document.addEventListener('currencyChanged', function(){
            if (_lastItems && _lastItems.length) {
                render(_lastItems);
            } else {
                load();
            }
        });

        // Keep in sync with sidebar cart actions
        document.addEventListener('cartUpdated', function(e){
            if (isAuth()) {
                // Refetch authoritative cart
                fetch('/api/cart')
                    .then(function(r){ return r.ok ? r.json() : Promise.reject(); })
                    .then(function(cart){ render(normalizeServerCart(cart)); })
                    .catch(function(){ /* noop */ });
            } else {
                var items = (e && e.detail && Array.isArray(e.detail.items)) ? e.detail.items : getGuestCart();
                render(items);
            }
        });

        // Delegate quantity changes
        document.body.addEventListener('click', function(e){
            var dec = e.target.closest && e.target.closest('.cartp-qty-dec');
            var inc = e.target.closest && e.target.closest('.cartp-qty-inc');
            if (!dec && !inc) return;
            var btn = dec || inc;
            var pid = btn.getAttribute('data-product-id');
            var vid = btn.getAttribute('data-variant-id') || '';
            var input = tbody.querySelector('input.num-product[data-product-id="'+pid+'"][data-variant-id="'+vid+'"]');
            var cur = input? parseInt(input.value)||1 : 1;
            var next = dec ? (cur-1) : (cur+1);
            if (isAuth()) {
                fetch('/api/cart/update', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify({ productId: pid, variantId: vid||null, quantity: next }) })
                    .then(function(r){ if(!r.ok){ return r.json().then(function(j){ throw new Error(j && j.message ? j.message : 'Update failed'); }); } return r.json(); })
                    .then(function(cart){ render(normalizeServerCart(cart.cart||cart)); })
                    .catch(function(err){ if (window.Swal && Swal.fire) { Swal.fire({ icon:'error', title:'Update failed', text: String(err.message||err) }); } });
            } else {
                var items = getGuestCart();
                var idx = items.findIndex(function(ci){ return String(ci.id)===String(pid) && String(ci.variantId||'')===String(vid||''); });
                if (idx >= 0) {
                    items[idx].quantity = Math.max(0, next);
                    if (items[idx].quantity <= 0) { items.splice(idx,1); }
                    localStorage.setItem('cart', JSON.stringify(items));
                    render(items);
                }
            }
        });

        // Delegate remove button on cart page
        document.body.addEventListener('click', function(e){
            var rm = e.target.closest && e.target.closest('.cartp-remove');
            if (!rm) return;
            var pid = rm.getAttribute('data-product-id');
            var vid = rm.getAttribute('data-variant-id') || '';
            if (isAuth()) {
                fetch('/api/cart/remove', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId: pid, variantId: vid || null }) })
                    .then(function(r){ return r.ok ? r.json() : Promise.reject(); })
                    .then(function(resp){ render(normalizeServerCart(resp.cart || resp)); })
                    .catch(function(){ /* noop */ });
            } else {
                var items = getGuestCart().filter(function(ci){ return !(String(ci.id)===String(pid) && String(ci.variantId||'')===String(vid||'')); });
                localStorage.setItem('cart', JSON.stringify(items));
                render(items);
            }
        });

        // Also handle manual input change
        document.body.addEventListener('change', function(e){
            var inp = e.target.closest && e.target.closest('input.num-product');
            if (!inp) return;
            var pid = inp.getAttribute('data-product-id');
            var vid = inp.getAttribute('data-variant-id') || '';
            var next = parseInt(inp.value)||0;
            if (isAuth()) {
                fetch('/api/cart/update', { method:'POST', headers:{ 'Content-Type':'application/json' }, body: JSON.stringify({ productId: pid, variantId: vid||null, quantity: next }) })
                    .then(function(r){ if(!r.ok){ return r.json().then(function(j){ throw new Error(j && j.message ? j.message : 'Update failed'); }); } return r.json(); })
                    .then(function(cart){ render(normalizeServerCart(cart.cart||cart)); })
                    .catch(function(err){ if (window.Swal && Swal.fire) { Swal.fire({ icon:'error', title:'Update failed', text: String(err.message||err) }); } });
            } else {
                var items = getGuestCart();
                var idx = items.findIndex(function(ci){ return String(ci.id)===String(pid) && String(ci.variantId||'')===String(vid||''); });
                if (idx >= 0) {
                    items[idx].quantity = Math.max(0, next);
                    if (items[idx].quantity <= 0) { items.splice(idx,1); }
                    localStorage.setItem('cart', JSON.stringify(items));
                    render(items);
                }
            }
        });

        load();
    });
    </script>
    {% endblock %}
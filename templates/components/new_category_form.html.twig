<form data-action="live#action:prevent" data-live-action-param="save">
    <div class="mb-3">
        <label for="category-name" class="form-label">Category name</label>
        <input type="text" id="category-name" class="form-control {{ _errors.has('name') ? 'is-invalid' }}" data-model="name" value="{{ name }}">
        {% if _errors.has('name') %}
            <div class="invalid-feedback">{{ _errors.get('name') }}</div>
        {% endif %}
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>

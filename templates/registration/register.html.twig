{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<!-- Title page -->
	<section class="bg-img1 txt-center p-lr-15 p-tb-92" style="background-image: url('{{ asset('assets/images/bg-01.jpg') }}');">
		<h2 class="ltext-105 cl0 txt-center">
			Register ! Your Eyes Deserve the Best Frames.
		</h2>
	</section>	
 <section class="bg0 p-t-104 p-b-116">
		<div class="container">
			<div class="flex-w flex-tr">
				<div class="size-210 bor10 p-lr-70 p-t-55 p-b-70 p-lr-15-lg w-full-md d-table mx-auto">
      
    {{ form_errors(registrationForm) }}

    {{ form_start(registrationForm, {'attr': {'class': 'm-t-15'}}) }}

        {# Name #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_widget(registrationForm.name, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'First Name'}}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/icon-user.png') }}" alt="ICON-USER" style="opacity:0.5; top:calc(50% - 10px); width:20px; height:20px;">
        </div>
        {% if form_errors(registrationForm.name) %}
            <div class="alert alert-danger m-b-15">
                {{ form_errors(registrationForm.name) }}
            </div>
        {% endif %}

        {# Lastname #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_widget(registrationForm.lastname, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'Last Name'}}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/icon-user.png') }}" alt="ICON-USER" style="opacity:0.5; top:calc(50% - 10px); width:20px; height:20px;">
        </div>
        {% if form_errors(registrationForm.lastname) %}
            <div class="alert alert-danger m-b-15">
                {{ form_errors(registrationForm.lastname) }}
            </div>
        {% endif %}

        {# Email #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_widget(registrationForm.email, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'Email Address'}}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/icon-email.png') }}" alt="ICON-EMAIL">
        </div>
        {% if form_errors(registrationForm.email) %}
            <div class="alert alert-danger m-b-15">
                {{ form_errors(registrationForm.email) }}
            </div>
        {% endif %}

        {# Phone #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_widget(registrationForm.phone, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'Phone Number (Optional)'}}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/icon-phone-square.png') }}" alt="ICON-PHONE" style="opacity:0.5; top:calc(50% - 10px); width:20px; height:20px;">
        </div>
        {% if form_errors(registrationForm.phone) %}
            <div class="alert alert-danger m-b-15">
                {{ form_errors(registrationForm.phone) }}
            </div>
        {% endif %}

        {# Password #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_label(registrationForm.plainPassword.first, 'Password', {'label_attr': {'class': 'sr-only'}}) }}
            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'Password', 'id': 'registration_form_plainPassword_first' }}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/locked.png') }}" alt="ICON-LOCK" style="opacity:0.3; top:calc(50% - 14px);">
            <span id="toggleRegisterPasswordButton" class="how-pos4" style="left: auto; right: 15px; cursor: pointer; z-index: 10;" title="Show/Hide password">
                <i class="zmdi zmdi-eye" id="toggleRegisterPasswordIcon"></i>
            </span>
        </div>
        {{ form_errors(registrationForm.plainPassword.first) }}
        
        {# Confirm Password #}
        <div class="bor8 m-b-20 how-pos4-parent">
            {{ form_label(registrationForm.plainPassword.second, 'Confirm Password', {'label_attr': {'class': 'sr-only'}}) }}
            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'stext-111 cl2 plh3 size-116 p-l-62 p-r-30', 'placeholder': 'Confirm Password', 'id': 'registration_form_plainPassword_second' }}) }}
            <img class="how-pos4 pointer-none" src="{{ asset('assets/images/icons/locked.png') }}" alt="ICON-LOCK" style="opacity:0.3; top:calc(50% - 14px);">
            <span id="toggleRegisterConfirmPasswordButton" class="how-pos4" style="left: auto; right: 15px; cursor: pointer; z-index: 10;" title="Show/Hide password">
                <i class="zmdi zmdi-eye" id="toggleRegisterConfirmPasswordIcon"></i>
            </span>
        </div>
        {{ form_errors(registrationForm.plainPassword.second) }}
        {{ form_errors(registrationForm.plainPassword) }}

        {# Sex #}
        <div class="m-b-20">
            {{ form_label(registrationForm.sex) }}
            <div class="rs1-select2 rs2-select2 bor8 bg0 m-b-12 m-t-9">
                {{ form_widget(registrationForm.sex, {'attr': {'class': 'js-select2'}}) }}
                <div class="dropDownSelect2"></div>
            </div>
        </div>
        {{ form_errors(registrationForm.sex) }}

        {# Birthdate #}
        <div class="m-b-20">
            {{ form_label(registrationForm.birthdate) }}
            <div class="d-flex flex-wrap justify-content-between">
                <div class="rs1-select2 rs2-select2 bor8 bg0 m-b-12 m-t-9 flex-fill mr-2" style="min-width: 100px;">
                    {{ form_widget(registrationForm.birthdate.year, {'attr': {'class': 'js-select2'}}) }}
                    <div class="dropDownSelect2"></div>
                </div>
                <div class="rs1-select2 rs2-select2 bor8 bg0 m-b-12 m-t-9 flex-fill mr-2" style="min-width: 100px;">
                    {{ form_widget(registrationForm.birthdate.month, {'attr': {'class': 'js-select2'}}) }}
                    <div class="dropDownSelect2"></div>
                </div>
                <div class="rs1-select2 rs2-select2 bor8 bg0 m-b-12 m-t-9 flex-fill" style="min-width: 100px;">
                    {{ form_widget(registrationForm.birthdate.day, {'attr': {'class': 'js-select2'}}) }}
                    <div class="dropDownSelect2"></div>
                </div>
            </div>
        </div>
        {{ form_errors(registrationForm.birthdate.year) }}
        {{ form_errors(registrationForm.birthdate.month) }}
        {{ form_errors(registrationForm.birthdate.day) }}
        {{ form_errors(registrationForm.birthdate) }} {# For errors on the BirthdayType itself #}

        {# Agree Terms - Checkbox #}
        <div class="p-t-15 p-b-15 form-group form-check">
            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
            {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'form-check-label stext-111 cl2'}}) }}
        </div>
        {{ form_errors(registrationForm.agreeTerms) }}

        <button type="submit" class="flex-c-m stext-101 cl0 size-121 bg3 bor1 hov-btn3 p-lr-15 trans-04 pointer m-t-20">
            Register
        </button>
    {{ form_end(registrationForm) }}

				
	           </div>
		</div>
	</section>	

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Password toggle functionality
            const passwordInput = document.getElementById('registration_form_plainPassword_first');
            const togglePasswordButton = document.getElementById('toggleRegisterPasswordButton');
            const togglePasswordIcon = document.getElementById('toggleRegisterPasswordIcon');

            if (passwordInput && togglePasswordButton && togglePasswordIcon) {
                togglePasswordButton.addEventListener('click', function (e) {
                    e.preventDefault(); 
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);

                    if (type === 'password') {
                        togglePasswordIcon.classList.remove('zmdi-eye-off');
                        togglePasswordIcon.classList.add('zmdi-eye');
                    } else {
                        togglePasswordIcon.classList.remove('zmdi-eye');
                        togglePasswordIcon.classList.add('zmdi-eye-off');
                    }
                });
            }

            // Confirm Password toggle functionality
            const confirmPasswordInput = document.getElementById('registration_form_plainPassword_second');
            const toggleConfirmPasswordButton = document.getElementById('toggleRegisterConfirmPasswordButton');
            const toggleConfirmPasswordIcon = document.getElementById('toggleRegisterConfirmPasswordIcon');

            if (confirmPasswordInput && toggleConfirmPasswordButton && toggleConfirmPasswordIcon) {
                toggleConfirmPasswordButton.addEventListener('click', function (e) {
                    e.preventDefault(); 
                    const type = confirmPasswordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    confirmPasswordInput.setAttribute('type', type);

                    if (type === 'password') {
                        toggleConfirmPasswordIcon.classList.remove('zmdi-eye-off');
                        toggleConfirmPasswordIcon.classList.add('zmdi-eye');
                    } else {
                        toggleConfirmPasswordIcon.classList.remove('zmdi-eye');
                        toggleConfirmPasswordIcon.classList.add('zmdi-eye-off');
                    }
                });
            }

            // Real-time password validation feedback
            if (passwordInput) {
                const passwordRequirements = document.createElement('div');
                passwordRequirements.className = 'password-requirements m-t-10';
                passwordRequirements.innerHTML = `
                    <small class="text-muted">
                        <div class="req-item" id="req-length">✗ At least 8 characters</div>
                        <div class="req-item" id="req-lowercase">✗ One lowercase letter</div>
                        <div class="req-item" id="req-uppercase">✗ One uppercase letter</div>
                        <div class="req-item" id="req-number">✗ One number</div>
                        <div class="req-item" id="req-special">✗ One special character (@$!%*?&)</div>
                    </small>
                `;
                
                passwordInput.parentNode.parentNode.insertBefore(passwordRequirements, passwordInput.parentNode.nextSibling);

                passwordInput.addEventListener('input', function() {
                    const password = this.value;
                    
                    // Length check
                    const lengthReq = document.getElementById('req-length');
                    if (password.length >= 8) {
                        lengthReq.innerHTML = '✓ At least 8 characters';
                        lengthReq.style.color = 'green';
                    } else {
                        lengthReq.innerHTML = '✗ At least 8 characters';
                        lengthReq.style.color = 'red';
                    }
                    
                    // Lowercase check
                    const lowercaseReq = document.getElementById('req-lowercase');
                    if (/[a-z]/.test(password)) {
                        lowercaseReq.innerHTML = '✓ One lowercase letter';
                        lowercaseReq.style.color = 'green';
                    } else {
                        lowercaseReq.innerHTML = '✗ One lowercase letter';
                        lowercaseReq.style.color = 'red';
                    }
                    
                    // Uppercase check
                    const uppercaseReq = document.getElementById('req-uppercase');
                    if (/[A-Z]/.test(password)) {
                        uppercaseReq.innerHTML = '✓ One uppercase letter';
                        uppercaseReq.style.color = 'green';
                    } else {
                        uppercaseReq.innerHTML = '✗ One uppercase letter';
                        uppercaseReq.style.color = 'red';
                    }
                    
                    // Number check
                    const numberReq = document.getElementById('req-number');
                    if (/\d/.test(password)) {
                        numberReq.innerHTML = '✓ One number';
                        numberReq.style.color = 'green';
                    } else {
                        numberReq.innerHTML = '✗ One number';
                        numberReq.style.color = 'red';
                    }
                    
                    // Special character check
                    const specialReq = document.getElementById('req-special');
                    if (/[@$!%*?&]/.test(password)) {
                        specialReq.innerHTML = '✓ One special character (@$!%*?&)';
                        specialReq.style.color = 'green';
                    } else {
                        specialReq.innerHTML = '✗ One special character (@$!%*?&)';
                        specialReq.style.color = 'red';
                    }
                });
            }

            // Password confirmation matching
            if (confirmPasswordInput && passwordInput) {
                function checkPasswordMatch() {
                    const password = passwordInput.value;
                    const confirmPassword = confirmPasswordInput.value;
                    
                    if (confirmPassword.length > 0) {
                        if (password === confirmPassword) {
                            confirmPasswordInput.style.borderColor = 'green';
                        } else {
                            confirmPasswordInput.style.borderColor = 'red';
                        }
                    } else {
                        confirmPasswordInput.style.borderColor = '';
                    }
                }
                
                passwordInput.addEventListener('input', checkPasswordMatch);
                confirmPasswordInput.addEventListener('input', checkPasswordMatch);
            }
        });
    </script>
{% endblock %}

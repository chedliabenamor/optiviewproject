{% extends 'base.html.twig' %}

{% block title %}My Wishlist{% endblock %}

{% block body %}
<section class="bg0 p-t-80 p-b-60">
  <div class="container">
    <div class="row">
      <!-- Profile Sidebar -->
      <div class="col-md-3 m-b-30">
        <div class="list-group">
          <a href="{{ path('app_user_profile_index') }}" class="list-group-item list-group-item-action">Profile Information</a>
          <a href="{{ path('app_user_profile_edit') }}" class="list-group-item list-group-item-action">Edit Profile</a>
          <a href="{{ path('app_user_profile_orders') }}" class="list-group-item list-group-item-action">Order History</a>
          <a href="{{ path('profile_wishlist') }}" class="list-group-item list-group-item-action active" aria-current="true">Wishlist</a>
          <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action">Logout</a>
        </div>
      </div>

      <!-- Wishlist Content -->
      <div class="col-md-9">
        <div class="p-b-24">
          <h2 class="mtext-104 cl2">My Wishlist</h2>
          <p class="stext-110 cl6">Products you saved for later.</p>
        </div>

        {% if items is empty %}
          <div class="p-t-40 p-b-40 text-center">
            <div class="mtext-101 cl2 m-b-12">Your wishlist is empty.</div>
            <a href="/" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">Continue Shopping</a>
          </div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-striped align-middle" id="account-wishlist-list">
              <thead>
                <tr>
                  <th style="width:72px;">Image</th>
                  <th>Product</th>
                  <th style="width:160px;">Variant</th>
                  <th style="width:140px;" class="text-end">Price</th>
                  <th style="width:140px;" class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
              {% for it in items %}
                <tr class="js-wishlist-row" data-product-id="{{ it.productId }}" data-variant-id="{{ it.variantId }}">
                  <td>
                    <a href="{{ it.url }}">
                      <img class="img-thumbnail js-wishlist-image" src="{{ it.image ?: asset('assets/images/placeholder-600x600.png') }}" alt="{{ it.name|e }}" style="width:60px;height:60px;object-fit:cover;">
                    </a>
                  </td>
                  <td>
                    <a href="{{ it.url }}" class="stext-104 cl4 hov-cl1 trans-04">{{ it.name }}</a>
                  </td>
                  <td>
                    {% if it.variantLabel %}
                      <span class="badge bg-light text-dark">{{ it.variantLabel }}</span>
                    {% else %}
                      <span class="text-muted">—</span>
                    {% endif %}
                  </td>
                  <td class="text-end">
                    <span class="js-price" data-price-eur="{{ it.price }}">€{{ it.price|number_format(2, '.', ',') }}</span>
                    <span class="js-original-price" style="display:none;text-decoration:line-through;margin-left:8px;"></span>
                  </td>
                  <td class="text-end">
                    <a href="{{ it.url }}" class="btn btn-sm btn-outline-primary">View</a>
                    <button class="btn btn-sm btn-outline-danger js-remove-wishlist-item" data-product-id="{{ it.productId }}" data-variant-id="{{ it.variantId }}">Remove</button>
                  </td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
// Handle remove buttons (AJAX to existing /wishlist/remove endpoint) and work with table rows
(function(){
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.js-remove-wishlist-item');
    if (!btn) return;
    e.preventDefault();
    var pid = btn.getAttribute('data-product-id');
    if (!pid) return;
    fetch('/wishlist/remove', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'id=' + encodeURIComponent(pid)
    })
    .then(function(r){ return r.json(); })
    .then(function(list){
      // Remove row from DOM
      var row = btn.closest('.js-wishlist-row');
      if (row && row.parentNode) row.parentNode.removeChild(row);
      // Update header count and broadcast
      try {
        var count = Array.isArray(list) ? list.length : 0;
        document.querySelectorAll('.icon-header-noti').forEach(function(icon){
          if (icon.querySelector('.zmdi-favorite-outline') || icon.querySelector('.zmdi-favorite')) {
            icon.setAttribute('data-notify', count);
          }
        });
        document.dispatchEvent(new CustomEvent('wishlistUpdated'));
      } catch(e){}
      // Empty state
      var tableBody = document.querySelector('#account-wishlist-list tbody');
      if (tableBody && tableBody.children.length === 0) {
        var wrapper = document.getElementById('account-wishlist-list').parentNode;
        wrapper.innerHTML = '<div class="p-t-40 p-b-40 text-center">\
          <div class="mtext-101 cl2 m-b-12">Your wishlist is empty.</div>\
          <a href="/" class="flex-c-m stext-101 cl0 size-101 bg1 bor1 hov-btn1 p-lr-15 trans-04">Continue Shopping</a>\
        </div>';
      }
      if (typeof Swal !== 'undefined') {
        Swal.fire({ icon: 'info', title: 'Removed', text: 'Item removed from wishlist.', showConfirmButton: false, timer: 1000 });
      } else if (typeof swal !== 'undefined') {
        swal('Wishlist', 'Item removed from wishlist!', 'info');
      }
    })
    .catch(function(){ /* ignore */ });
  });
})();

// Enrich wishlist cards with variant image and discount pricing using Quick View API
(function(){
  function toNum(txt){ try { return parseFloat(String(txt).replace(/[^0-9.\-]/g,'')); } catch(e){ return null; } }
  document.addEventListener('DOMContentLoaded', function(){
    var rows = document.querySelectorAll('#account-wishlist-list .js-wishlist-row');
    if (!rows || rows.length === 0) return;
    function fmt(n){ return (window.Currency && typeof window.Currency.format==='function') ? window.Currency.format(n) : ('€' + (typeof n==='number'? n.toFixed(2) : n)); }
    rows.forEach(function(row){
      var pid = row.getAttribute('data-product-id');
      var vid = row.getAttribute('data-variant-id');
      if (!pid) return;
      fetch('/api/products/' + pid + '/quick-view')
        .then(function(r){ return r.ok ? r.json() : null; })
        .then(function(data){
          if (!data) return;
          var imgEl = row.querySelector('img.js-wishlist-image');
          var priceEl = row.querySelector('.js-price');
          var origEl = row.querySelector('.js-original-price');
          var showDiscount = function(discounted, original){
            if (!priceEl) return;
            priceEl.textContent = fmt(discounted);
            priceEl.style.color = '#e74c3c';
            priceEl.style.fontWeight = '700';
            if (origEl && original != null) {
              origEl.textContent = fmt(original);
              origEl.style.display = 'inline';
            }
          };
          var showRegular = function(p){
            if (!priceEl) return;
            priceEl.textContent = fmt(p);
            priceEl.style.color = '';
            priceEl.style.fontWeight = '';
            if (origEl) origEl.style.display = 'none';
          };

          if (vid) {
            var v = (data.productVariants || []).find(function(vv){ return String(vv.id) === String(vid); });
            if (v) {
              if (v.productVariantImages && v.productVariantImages.length > 0 && imgEl) {
                imgEl.setAttribute('src', v.productVariantImages[0].imageUrl);
              }
              if (priceEl) priceEl.setAttribute('data-price-eur', v.price != null ? v.price : '');
              if (origEl) origEl.setAttribute('data-original-eur', '');
              if (v.offer && v.offer.has_offer) {
                if (priceEl) priceEl.setAttribute('data-price-eur', v.offer.discounted_price);
                if (origEl) origEl.setAttribute('data-original-eur', v.offer.original_price);
                showDiscount(v.offer.discounted_price, v.offer.original_price);
              } else {
                showRegular(v.price);
              }
            }
          } else {
            if (data.overviewImage && imgEl) {
              imgEl.setAttribute('src', data.overviewImage);
            }
            if (priceEl) priceEl.setAttribute('data-price-eur', data.price != null ? data.price : '');
            if (origEl) origEl.setAttribute('data-original-eur', '');
            if (data.offer && data.offer.has_offer) {
              if (priceEl) priceEl.setAttribute('data-price-eur', data.offer.discounted_price);
              if (origEl) origEl.setAttribute('data-original-eur', data.offer.original_price);
              showDiscount(data.offer.discounted_price, data.offer.original_price);
            } else {
              showRegular(data.price);
            }
          }
          // After setting values, re-apply currency formatting to ensure consistency
          try { if (window.Currency) { var ev = new CustomEvent('currencyChanged'); document.dispatchEvent(ev); } } catch(e){}
        })
        .catch(function(){});
    });
  });
})();

// Reformat prices on currency change using stored EUR values
(function(){
  function applyCurrencyFormatToWishlist(){
    var cards = document.querySelectorAll('#account-wishlist-list .js-wishlist-card');
    if (!cards || !cards.length || !window.Currency) return;
    cards.forEach(function(card){
      var priceEl = card.querySelector('.js-price');
      var origEl = card.querySelector('.js-original-price');
      if (!priceEl) return;
      var p = parseFloat(priceEl.getAttribute('data-price-eur') || '');
      var oAttr = (origEl ? origEl.getAttribute('data-original-eur') : null);
      var o = (oAttr !== null && oAttr !== '') ? parseFloat(oAttr) : NaN;
      var hasO = !isNaN(o);
      if (!isNaN(p)) {
        if (hasO) {
          priceEl.style.color = '#e74c3c';
          priceEl.style.fontWeight = '700';
          priceEl.textContent = window.Currency.format(p);
          if (origEl) { origEl.style.display = 'inline'; origEl.textContent = window.Currency.format(o); }
        } else {
          priceEl.style.color = '';
          priceEl.style.fontWeight = '';
          priceEl.textContent = window.Currency.format(p);
          if (origEl) origEl.style.display = 'none';
        }
      }
    });
  }
  document.addEventListener('currencyChanged', applyCurrencyFormatToWishlist);
  // Also apply once on initial load (after Currency initializes)
  document.addEventListener('DOMContentLoaded', function(){
    setTimeout(function(){ if (window.Currency) applyCurrencyFormatToWishlist(); }, 150);
  });
})();
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}My Orders - {{ parent() }}{% endblock %}

{% block body %}
<div class="container profile-container mt-5 mb-5">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a href="{{ path('app_user_profile_index') }}" class="list-group-item list-group-item-action">Profile Information</a>
                <a href="{{ path('app_user_profile_edit') }}" class="list-group-item list-group-item-action">Edit Profile</a>
                <a href="{{ path('app_user_profile_orders') }}" class="list-group-item list-group-item-action active" aria-current="true">Order History</a>
                <a href="{{ path('profile_wishlist') }}" class="list-group-item list-group-item-action">Wishlist</a>
                <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action">Logout</a>
            </div>
        </div>
        <div class="col-md-9 profile-box">
            <h2>My Orders</h2>
            <hr>
            {% if orders is not empty %}
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th scope="col">Order ID</th>
                            <th scope="col">Date</th>
                            <th scope="col">Subtotal</th>
                            <th scope="col">Tax</th>
                            <th scope="col">Shipping</th>
                            <th scope="col">Total</th>
                            <th scope="col">Points</th>
                            <th scope="col">Shipping Provider</th>
                            <th scope="col">Tracking #</th>
                            <th scope="col">Status</th>
                          
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            {% set sym = order.currency == 'USD' ? '$' : '€' %}
                            <tr>
                                <td>#{{ order.id }}</td>
                                <td>{{ order.createdAt|date('Y-m-d H:i') }}</td>
                                <td>{{ sym }} {{ order.subtotal | number_format(2, '.', ',') }}</td>
                                <td>{{ sym }} {{ order.taxAmount | number_format(2, '.', ',') }}</td>
                                <td>{{ sym }} {{ order.shippingFee | number_format(2, '.', ',') }}</td>
                                <td>{{ sym }} {{ order.totalAmount | number_format(2, '.', ',') }}</td>
                                <td>{{ order.totalPointsEarned }}</td>
                                <td>{{ order.shippingProvider|default('N/A') }}</td>
                                <td>{{ order.trackingNumber|default('N/A') }}</td>
                                {% set s = (order.status|default('pending'))|lower %}
                                {% set badge =
                                    s == 'pending' ? 'badge bg-secondary' :
                                    (s == 'processing' ? 'badge bg-info' :
                                    (s == 'shipped' ? 'badge bg-primary' :
                                    (s == 'delivered' ? 'badge bg-success' :
                                    (s == 'cancelled' ? 'badge bg-warning text-dark' :
                                    (s == 'refunded' ? 'badge bg-danger' : 'badge bg-secondary')))))
                                %}
                                <td><span class="{{ badge }}">{{ s|capitalize }}</span></td>
                               
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p>You have not placed any orders yet.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

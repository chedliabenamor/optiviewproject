{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="container profile-container mt-5 mb-5">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a href="{{ path('app_user_profile_index') }}" class="list-group-item list-group-item-action">Profile Information</a>
                <a href="{{ path('app_user_profile_edit') }}" class="list-group-item list-group-item-action">Edit Profile</a>
                <a href="{{ path('app_user_profile_orders') }}" class="list-group-item list-group-item-action active" aria-current="true">Order History</a>
                <a href="{{ path('profile_wishlist') }}" class="list-group-item list-group-item-action">Wishlist</a>
                <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action">Logout</a>
            </div>
        </div>
        <div class="col-md-9 profile-box">
            <div class="d-flex justify-content-between align-items-center">
                <h2>Order #{{ order.id }}</h2>
                {% set s = (order.status|default('pending'))|lower %}
                {% set badge =
                    s == 'pending' ? 'badge bg-secondary' :
                    (s == 'processing' ? 'badge bg-info' :
                    (s == 'shipped' ? 'badge bg-primary' :
                    (s == 'delivered' ? 'badge bg-success' :
                    (s == 'cancelled' ? 'badge bg-warning text-dark' :
                    (s == 'refunded' ? 'badge bg-danger' : 'badge bg-secondary')))))
                %}
                <span class="{{ badge }}">{{ s|capitalize }}</span>
            </div>
            <hr>

            {% set sym = order.currency == 'USD' ? '$' : '€' %}

            <div class="mb-3">
                <div><strong>Date:</strong> {{ order.createdAt|date('Y-m-d H:i') }}</div>
                <div><strong>Shipping Provider:</strong> {{ order.shippingProvider|default('N/A') }}</div>
                <div><strong>Tracking #:</strong> {{ order.trackingNumber|default('N/A') }}</div>
            </div>

            <h5>Items</h5>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order.orderItems %}
                        <tr>
                            <td>{{ item.productVariant ? item.productVariant : 'N/A' }}</td>
                            <td class="text-center">{{ item.quantity }}</td>
                            <td class="text-end">{{ sym }} {{ item.unitPrice|default('0.00')|number_format(2, '.', ',') }}</td>
                            <td class="text-end">{{ sym }} {{ (item.quantity * item.unitPrice)|number_format(2, '.', ',') }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="text-center">No items in this order.</td></tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="row">
                <div class="col-md-6">
                    {% if s == 'pending' %}
            

                        <form id="cancel-order-form" method="post" action="{{ path('app_user_order_cancel', { id: order.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel-order-' ~ order.id) }}">
                            <button type="submit" class="btn btn-outline-warning">Cancel Order</button>
                        </form>
                    {% endif %}
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">Totals</div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between"><span>Subtotal</span><span>{{ sym }} {{ order.subtotal|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Tax (7%)</span><span>{{ sym }} {{ order.taxAmount|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Shipping</span><span>{{ sym }} {{ order.shippingFee|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Points Earned</span><span>{{ order.totalPointsEarned }}</span></div>
                            <hr>
                            <div class="d-flex justify-content-between fw-bold"><span>Final Total</span><span>{{ sym }} {{ order.finalTotal|number_format(2, '.', ',') }}</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Cancel order
  const cancelForm = document.getElementById('cancel-order-form');
  if (cancelForm) {
    cancelForm.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof Swal !== 'undefined' && Swal.fire) {
        Swal.fire({
          title: 'Are you sure you want to cancel this order?',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonText: 'Yes, cancel it',
          cancelButtonText: 'No, keep it'
        }).then((result) => {
          if (result.isConfirmed) {
            cancelForm.submit();
          }
        });
      } else {
        if (confirm('Are you sure you want to cancel this order?')) {
          cancelForm.submit();
        }
      }
    });
  }

  // Remove item forms
  // Item removal disabled: users can only cancel entire pending orders

  // Add item form
  const addForm = document.getElementById('add-item-form');
  if (addForm) {
    addForm.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof Swal !== 'undefined' && Swal.fire) {
        Swal.fire({
          title: 'Add this item to your order?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: 'Yes, add it',
          cancelButtonText: 'No, go back'
        }).then((result) => {
          if (result.isConfirmed) {
            addForm.submit();
          }
        });
      } else {
        if (confirm('Add this item to your order?')) {
          addForm.submit();
        }
      }
    });
  }
});
</script>
{% endblock %}

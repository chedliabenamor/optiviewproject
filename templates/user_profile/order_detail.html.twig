{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }} - {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .order-item-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }
        .order-item-placeholder {
            width: 60px;
            height: 60px;
            border-radius: 4px;
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
        }
        .cancel-order-section {
            background-color: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
        }
        .order-status-badge {
            font-size: 0.9rem;
            padding: 8px 16px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container profile-container mt-5 mb-5">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a href="{{ path('app_user_profile_index') }}" class="list-group-item list-group-item-action">Profile Information</a>
                <a href="{{ path('app_user_profile_edit') }}" class="list-group-item list-group-item-action">Edit Profile</a>
                <a href="{{ path('app_user_profile_orders') }}" class="list-group-item list-group-item-action active" aria-current="true">Order History</a>
                <a href="{{ path('profile_wishlist') }}" class="list-group-item list-group-item-action">Wishlist</a>
                <a href="{{ path('app_logout') }}" class="list-group-item list-group-item-action">Logout</a>
            </div>
        </div>
        <div class="col-md-9 profile-box">
            <div class="d-flex justify-content-between align-items-center">
                <h2>Order #{{ order.id }}</h2>
                {% set s = (order.status|default('pending'))|lower %}
                {% set badge =
                    s == 'pending' ? 'badge bg-secondary' :
                    (s == 'processing' ? 'badge bg-info' :
                    (s == 'shipped' ? 'badge bg-primary' :
                    (s == 'delivered' ? 'badge bg-success' :
                    (s == 'cancelled' ? 'badge bg-warning text-dark' :
                    (s == 'refunded' ? 'badge bg-danger' : 'badge bg-secondary')))))
                %}
                <span class="{{ badge }} order-status-badge">{{ s|capitalize }}</span>
            </div>
            <hr>

            {% set sym = order.currency == 'USD' ? '$' : '€' %}

            <div class="mb-3">
                <div><strong>Date:</strong> {{ order.createdAt|date('Y-m-d H:i') }}</div>
                <div><strong>Shipping Provider:</strong> {{ order.shippingProvider|default('N/A') }}</div>
                <div><strong>Tracking #:</strong> {{ order.trackingNumber|default('N/A') }}</div>
            </div>

            <h5>Items</h5>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th style="width: 80px;">Image</th>
                        <th>Product</th>
                        <th class="text-center" style="width: 80px;">Qty</th>
                        <th class="text-end" style="width: 120px;">Unit Price</th>
                        <th class="text-end" style="width: 120px;">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in order.orderItems %}
                        <tr>
                            <td>
                                {% set product = item.product %}
                                {% set variant = item.productVariant %}
                                {% set imageUrl = null %}
                                
                                {# Try to get variant image first, then product image #}
                                {% if variant and variant.productVariantImages|length > 0 %}
                                    {% set imageUrl = vich_uploader_asset(variant.productVariantImages|first, 'imageFile') %}
                                {% elseif product and product.overviewImage %}
                                    {% set imageUrl = vich_uploader_asset(product, 'overviewImageFile') %}
                                {% endif %}
                                
                                {% if imageUrl %}
                                    <img src="{{ imageUrl }}" alt="{{ product ? product.name : 'Product' }}" 
                                         class="order-item-image img-thumbnail">
                                {% else %}
                                    <div class="order-item-placeholder d-flex align-items-center justify-content-center">
                                        <i class="fa fa-image text-muted"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                <div>
                                    <strong>{{ product ? product.name : 'N/A' }}</strong>
                                    {% if variant %}
                                        <br><small class="text-muted">
                                            {% if variant.color %}Color: {{ variant.color.name }}{% endif %}
                                            {% if variant.size %}{% if variant.color %}, {% endif %}Size: {{ variant.size.name }}{% endif %}
                                        </small>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="text-center">{{ item.quantity }}</td>
                            <td class="text-end">{{ sym }} {{ item.unitPrice|default('0.00')|number_format(2, '.', ',') }}</td>
                            <td class="text-end">{{ sym }} {{ (item.quantity * item.unitPrice)|number_format(2, '.', ',') }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-center">No items in this order.</td></tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="row">
                <div class="col-md-6">
                    {% if s == 'pending' or s == 'processing' %}
                        <div class="cancel-order-section">
                            <h6 class="mb-3"><i class="fa fa-exclamation-triangle text-warning"></i> Order Cancellation</h6>
                            <p class="mb-3 small">You can cancel this order while it's <strong>{{ s }}</strong>. Once cancelled, this action cannot be undone.</p>
                            <form id="cancel-order-form" method="post" action="{{ path('app_user_order_cancel', { id: order.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cancel-order-' ~ order.id) }}">
                                <button type="submit" class="btn btn-outline-danger">
                                    <i class="fa fa-times"></i> Cancel Order
                                </button>
                            </form>
                        </div>
                    {% elseif s == 'cancelled' %}
                        <div class="alert alert-warning">
                            <i class="fa fa-info-circle"></i> This order has been cancelled.
                        </div>
                    {% elseif s == 'shipped' or s == 'delivered' %}
                        <div class="alert alert-info">
                            <i class="fa fa-info-circle"></i> This order cannot be cancelled as it has already been {{ s }}.
                        </div>
                    {% endif %}
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">Totals</div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between"><span>Subtotal</span><span>{{ sym }} {{ order.subtotal|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Tax (7%)</span><span>{{ sym }} {{ order.taxAmount|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Shipping</span><span>{{ sym }} {{ order.shippingFee|number_format(2, '.', ',') }}</span></div>
                            <div class="d-flex justify-content-between"><span>Points Earned</span><span>{{ order.totalPointsEarned }}</span></div>
                            <hr>
                            <div class="d-flex justify-content-between fw-bold"><span>Final Total</span><span>{{ sym }} {{ order.finalTotal|number_format(2, '.', ',') }}</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  // Cancel order
  const cancelForm = document.getElementById('cancel-order-form');
  if (cancelForm) {
    cancelForm.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof Swal !== 'undefined' && Swal.fire) {
        Swal.fire({
          title: 'Cancel Order #{{ order.id }}?',
          text: 'This action cannot be undone. The order will be cancelled and you will be refunded if payment was processed.',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonText: 'Yes, cancel order',
          cancelButtonText: 'No, keep order',
          confirmButtonColor: '#dc3545'
        }).then((result) => {
          if (result.isConfirmed) {
            cancelForm.submit();
          }
        });
      } else {
        if (confirm('Are you sure you want to cancel this order? This action cannot be undone.')) {
          cancelForm.submit();
        }
      }
    });
  }

  // Remove item forms
  // Item removal disabled: users can only cancel entire pending orders

  // Add item form
  const addForm = document.getElementById('add-item-form');
  if (addForm) {
    addForm.addEventListener('submit', function (e) {
      e.preventDefault();
      if (typeof Swal !== 'undefined' && Swal.fire) {
        Swal.fire({
          title: 'Add this item to your order?',
          icon: 'question',
          showCancelButton: true,
          confirmButtonText: 'Yes, add it',
          cancelButtonText: 'No, go back'
        }).then((result) => {
          if (result.isConfirmed) {
            addForm.submit();
          }
        });
      } else {
        if (confirm('Add this item to your order?')) {
          addForm.submit();
        }
      }
    });
  }
});
</script>
{% endblock %}

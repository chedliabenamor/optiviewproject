{% extends 'base.html.twig' %}

{% block title %}Checkout - {{ parent() }}{% endblock %}

{% block body %}
<div class="container p-t-60 p-b-80">
    <div class="row">
        <div class="col-md-8 m-lr-auto">
            <h2 class="mtext-103 cl2 m-b-24">Checkout</h2>

            {# Flash messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'warning' ? 'warning' : (label == 'success' ? 'success' : 'info')) }}" role="alert">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <form action="{{ path('app_checkout_confirm') }}" method="post" class="bor10 p-4">
                <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
                <div class="row">
                    <div class="col-md-6">
                        <h4 class="stext-301 cl2 m-b-16">Shipping Address</h4>
                        <textarea class="form-control" name="shippingAddress" rows="4" placeholder="Full shipping address" required></textarea>
                    </div>
                    <div class="col-md-6">
                        <h4 class="stext-301 cl2 m-b-16">Billing Address</h4>
                        <textarea class="form-control" name="billingAddress" rows="4" placeholder="Full billing address" required></textarea>
                    </div>
                </div>

                <hr class="m-t-24 m-b-24" />

                <div class="row">
                    <div class="col-md-6">
                        <label class="stext-110 cl2 m-b-8">Delivery Type</label>
                        <select name="deliveryType" class="form-control" required>
                            <option {{ defaults.deliveryType == 'Standard' ? 'selected' : '' }}>Standard</option>
                            <option {{ defaults.deliveryType == 'Express' ? 'selected' : '' }}>Express</option>
                            <option {{ defaults.deliveryType == 'Same-day' ? 'selected' : '' }}>Same-day</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="stext-110 cl2 m-b-8">Destination</label>
                        <select name="destination" class="form-control" required>
                            <option {{ defaults.destination == 'Domestic' ? 'selected' : '' }}>Domestic</option>
                            <option {{ defaults.destination == 'International' ? 'selected' : '' }}>International</option>
                        </select>
                    </div>
                </div>

                <div class="row m-t-16">
                    <div class="col-md-6">
                        <label class="stext-110 cl2 m-b-8">Shipping Provider</label>
                        <select name="shippingProvider" class="form-control" required>
                            <option value="DHL" {{ defaults.shippingProvider == 'DHL' ? 'selected' : '' }}>DHL</option>
                            <option value="UPS" {{ defaults.shippingProvider == 'UPS' ? 'selected' : '' }}>UPS</option>
                            <option value="Poste" {{ defaults.shippingProvider == 'Poste' ? 'selected' : '' }}>Post</option>
                            <option value="GLS" {{ defaults.shippingProvider == 'GLS' ? 'selected' : '' }}>GLS</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="stext-110 cl2 m-b-8">Payment Method</label>
                        <select name="paymentMethod" class="form-control" required>
                            <option value="credit card" {{ defaults.paymentMethod == 'credit card' ? 'selected' : '' }}>Credit Card</option>
                            <option value="paypal" {{ defaults.paymentMethod == 'paypal' ? 'selected' : '' }}>PayPal</option>
                        </select>
                    </div>
                </div>

                <div id="card-section" class="row m-t-16" style="display: none;">
                    <div class="col-md-12">
                        <label class="stext-110 cl2 m-b-8">Card Details</label>
                        <div id="card-element" class="form-control"></div>
                        <div id="card-errors" class="text-danger m-t-8"></div>
                    </div>
                </div>

                <div class="row m-t-16">
                    <div class="col-12">
                        <label class="stext-110 cl2 m-b-8">Order Notes (optional)</label>
                        <textarea class="form-control" name="notes" rows="3" placeholder="Any special instructions"></textarea>
                    </div>
                </div>

                <div class="row m-t-24">
                    <div class="col-md-7">
                        <a href="{{ path('app_cart') }}" class="stext-101 cl2 p-tb-8 m-r-12">Back to cart</a>
                    </div>
                    <div class="col-md-5">
                        <div class="bor10 p-3">
                            <h5 class="stext-301 cl2 m-b-12">Order Summary</h5>
                            <div class="d-flex justify-content-between m-b-6"><span>Subtotal</span><strong id="sum-subtotal">€0.00</strong></div>
                            <div class="d-flex justify-content-between m-b-6"><span>Tax (7%)</span><strong id="sum-tax">€0.00</strong></div>
                            <div class="d-flex justify-content-between m-b-6"><span>Shipping fee</span><strong id="sum-shipping">€0.00</strong></div>
                            <div class="d-flex justify-content-between m-b-6"><span>Loyalty discount</span><strong id="sum-points-discount">-€0.00</strong></div>
                            <hr/>
                            <div class="d-flex justify-content-between m-b-12"><span>Total</span><strong id="sum-total">€0.00</strong></div>
                            <button type="submit" class="w-100 flex-c-m stext-101 cl0 size-116 bg3 bor14 hov-btn3 p-lr-15 trans-04">Place Order</button>
                        </div>
                    </div>
                </div>
                <div class="row m-t-16">
                    <div class="col-md-8">
                        <div class="bor10 p-3">
                            <h5 class="stext-301 cl2 m-b-12">Loyalty Points</h5>
                            <p class="m-b-8">Your balance: <strong id="loyalty-balance">{{ loyaltyBalance }}</strong> points</p>
                            <div class="input-group">
                                <input type="number" min="0" max="{{ loyaltyBalance }}" step="1" class="form-control" name="loyaltyPointsToApply" id="loyaltyPointsToApply" placeholder="Enter points to apply" />
                                <button type="button" class="btn btn-outline-secondary" id="btn-apply-all">Use max</button>
                            </div>
                            <small class="text-muted">1 point = 0.01 EUR. Discount cannot exceed the order total.</small>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function(){
    function sel(name){ return document.querySelector('[name="'+name+'"]'); }
    function fmt(n, cur){
        var v = parseFloat(n||0); if (isNaN(v)) v = 0;
        if (typeof window.Currency !== 'undefined' && window.Currency.format) return window.Currency.format(v);
        return (cur === 'USD' ? '$' : '€') + v.toFixed(2);
    }
    function fetchCartSubtotal(){
        return fetch('/api/cart').then(function(r){ return r.ok?r.json():Promise.reject(); })
            .then(function(cart){
                try { var items = Array.isArray(cart.items)?cart.items:[]; var sub = 0; items.forEach(function(it){ var price=parseFloat(it.unitPrice||0)||0; var qty=parseInt(it.quantity||1,10)||1; sub += price*qty; }); return sub; }
                catch(e){ return 0; }
            }).catch(function(){ return 0; });
    }
    function refreshSummary(){
        var currency = 'EUR';
        var deliveryType = sel('deliveryType') ? sel('deliveryType').value : 'Standard';
        var destination = sel('destination') ? sel('destination').value : 'Domestic';
        var points = document.getElementById('loyaltyPointsToApply') ? parseInt(document.getElementById('loyaltyPointsToApply').value||'0',10) : 0;
        // Ask server for shipping fee (it also returns subtotal/tax/total from current cart)
        var url = '/api/checkout/shipping-fee?currency=' + encodeURIComponent(currency) + '&deliveryType=' + encodeURIComponent(deliveryType) + '&destination=' + encodeURIComponent(destination) + '&points=' + encodeURIComponent(points);
        fetch(url)
            .then(function(r){ return r.ok ? r.json() : Promise.reject(); })
            .then(function(resp){
                var cur = resp.currency || currency;
                document.getElementById('sum-subtotal').textContent = fmt(resp.subtotal, cur);
                document.getElementById('sum-tax').textContent = fmt(resp.tax, cur);
                document.getElementById('sum-shipping').textContent = fmt(resp.shippingFee, cur);
                document.getElementById('sum-points-discount').textContent = '-' + fmt(resp.pointsDiscount || 0, cur);
                document.getElementById('sum-total').textContent = fmt(resp.total, cur);
            })
            .catch(function(){
                // fallback: compute subtotal only
                fetchCartSubtotal().then(function(sub){
                    var tax = sub * 0.07; var ship = (deliveryType==='Standard' && (sub+tax)>=100)?0:(destination==='International'?30.90:20.90) + (deliveryType==='Express'?15:(deliveryType==='Same-day'?20:0));
                    var discount = 0; // offline can't compute points reliably
                    document.getElementById('sum-subtotal').textContent = fmt(sub, currency);
                    document.getElementById('sum-tax').textContent = fmt(tax, currency);
                    document.getElementById('sum-shipping').textContent = fmt(ship, currency);
                    document.getElementById('sum-points-discount').textContent = '-' + fmt(discount, currency);
                    document.getElementById('sum-total').textContent = fmt(Math.max(0, sub+tax+ship-discount), currency);
                });
            });
    }
    ['deliveryType','destination'].forEach(function(n){ var el = sel(n); if (el) { el.addEventListener('change', refreshSummary); }});
    var pointsInput = document.getElementById('loyaltyPointsToApply');
    if (pointsInput) {
        pointsInput.addEventListener('input', function(){
            var bal = parseInt(document.getElementById('loyalty-balance').textContent||'0',10)||0;
            var v = parseInt(pointsInput.value||'0',10)||0;
            if (v < 0) v = 0; if (v > bal) v = bal; pointsInput.value = v;
            refreshSummary();
        });
    }
    var btnAll = document.getElementById('btn-apply-all');
    if (btnAll && pointsInput) {
        btnAll.addEventListener('click', function(){
            var bal = parseInt(document.getElementById('loyalty-balance').textContent||'0',10)||0;
            pointsInput.value = bal;
            refreshSummary();
        });
    }
    refreshSummary();
});
</script>
<script src="https://js.stripe.com/v3"></script>
<script>
document.addEventListener('DOMContentLoaded', function(){
    var stripePk = {{ stripePk ? (stripePk|json_encode|raw) : 'null' }};
    var paymentSelect = document.querySelector('select[name="paymentMethod"]');
    var cardSection = document.getElementById('card-section');
    var form = document.querySelector('form[action="{{ path('app_checkout_confirm') }}"]');
    var submitBtn = form ? form.querySelector('button[type="submit"]') : null;

    function toggleCardSection(){
        var method = paymentSelect ? paymentSelect.value : 'credit card';
        if (method === 'credit card') { cardSection.style.display = ''; }
        else { cardSection.style.display = 'none'; }
    }
    if (paymentSelect && cardSection) {
        toggleCardSection();
        paymentSelect.addEventListener('change', toggleCardSection);
    }

    // Guard: if using credit card but Stripe PK missing, prevent native submit and show message
    if (form) {
        form.addEventListener('submit', function(e){
            var method = paymentSelect ? paymentSelect.value : 'credit card';
            if (method === 'credit card' && !stripePk) {
                e.preventDefault();
                var ce = document.getElementById('card-errors');
                if (ce) { ce.textContent = 'Payment unavailable: missing Stripe publishable key.'; }
                else { alert('Payment unavailable: missing Stripe publishable key.'); }
            }
        }, { capture: true });
    }

    if (!stripePk) { return; }
    var stripe = Stripe(stripePk);
    var elements = stripe.elements();
    var card = elements.create('card');
    var cardMounted = false;
    function ensureCardMounted(){ if (!cardMounted && document.getElementById('card-element')) { card.mount('#card-element'); cardMounted = true; } }
    ensureCardMounted();
    if (paymentSelect) { paymentSelect.addEventListener('change', ensureCardMounted); }

    function setProcessing(on){ if (!submitBtn) return; submitBtn.disabled = !!on; submitBtn.textContent = on ? 'Processing…' : 'Place Order'; }
    function showError(msg){ var el = document.getElementById('card-errors'); if (el) { el.textContent = msg || ''; } }

    if (form) {
        form.addEventListener('submit', async function(e){
            try {
                var method = paymentSelect ? paymentSelect.value : 'credit card';
                if (method !== 'credit card') { return; }
                e.preventDefault();
                showError('');
                setProcessing(true);

                var fd = new FormData(form);
                var payload = {
                    currency: 'EUR',
                    shippingAddress: fd.get('shippingAddress') || '',
                    billingAddress: fd.get('billingAddress') || '',
                    shippingProvider: fd.get('shippingProvider') || 'DHL',
                    deliveryType: fd.get('deliveryType') || 'Standard',
                    destination: fd.get('destination') || 'Domestic',
                    notes: fd.get('notes') || '',
                    loyaltyPointsToApply: parseInt(fd.get('loyaltyPointsToApply') || '0', 10) || 0
                };

                var resp = await fetch('/api/payments/create-intent', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                var data = await resp.json();
                if (!resp.ok || !data.success) { throw new Error(data && data.message ? data.message : 'Failed to initialize payment'); }

                var clientSecret = data.clientSecret;
                var orderId = data.orderId;

                var result = await stripe.confirmCardPayment(clientSecret, {
                    payment_method: { card: card }
                });
                if (result.error) { throw new Error(result.error.message || 'Payment failed'); }
                if (!result.paymentIntent || result.paymentIntent.status !== 'succeeded') { throw new Error('Payment not completed'); }

                var confirmResp = await fetch('/api/payments/confirm', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId: orderId, paymentIntentId: result.paymentIntent.id })
                });
                var confirmData = await confirmResp.json();
                if (!confirmResp.ok || !confirmData.success) { throw new Error(confirmData && confirmData.message ? confirmData.message : 'Failed to confirm order'); }

                var redirectUrl = confirmData.redirect || ('{{ path('app_checkout_confirmation', { id: 0 })|e('js') }}'.replace('/0', '/' + orderId));
                window.location.href = redirectUrl;
            } catch (err) {
                showError(err && err.message ? err.message : 'Payment error');
                setProcessing(false);
            }
        });
    }
});
</script>
{% endblock %}
